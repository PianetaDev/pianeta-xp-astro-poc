---
import { Icon } from 'astro-icon/components';

interface Props {
  current?: string;
}
const { current = '' } = Astro.props;

const nav = [
  { href: '/',         label: 'Hub',      icon: 'lucide:home' },
  { href: '/work',     label: 'Work',     icon: 'lucide:briefcase' },
  { href: '/bulletin', label: 'Bulletin', icon: 'lucide:newspaper' },
  { href: '/services', label: 'Services', icon: 'lucide:sparkles' },
  { href: '/team',     label: 'Team',     icon: 'lucide:users' },
  { href: '/lab',      label: 'Lab',      icon: 'lucide:flask-conical' },
  { href: '/careers',  label: 'Careers',  icon: 'lucide:briefcase-business' },
];

const railStyle = 'position:fixed;left:0;top:0;bottom:0;width:88px;background:#ffffff;color:#0e1116;border-right:1px solid rgba(0,0,0,0.08);display:flex;flex-direction:column;z-index:100;';
const brandStyle = 'display:block;padding:18px 10px 22px;color:#0e1116;text-decoration:none;';
const wordmarkStyle = 'font-weight:900;font-size:11px;line-height:1.1;letter-spacing:1px;text-align:center;margin:0;';
const navStyle = 'flex:1;display:flex;flex-direction:column;justify-content:center;gap:6px;padding:0 6px;overflow-y:auto;';
const linkBase = 'display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 4px;border-radius:8px;color:rgba(14,17,22,0.78);text-decoration:none;font-size:9px;text-transform:uppercase;letter-spacing:0.8px;font-weight:500;';
const linkActive = 'background:#0e1116;color:#fff;';
---
<aside style={railStyle} aria-label="Main navigation" class="site-rail">
  <a href="/" style={brandStyle} aria-label="Pianeta.Studio — home">
    <img src="/brand/logo-mark-orange.svg" alt="" width="36" height="24" style="display:block;margin:0 auto 8px;width:36px;height:auto;" />
    <p style="font-weight:900;font-size:9px;line-height:1.1;letter-spacing:0.5px;text-align:center;margin:0;color:#0e1116;">PIANETA<br>STUDIO</p>
  </a>

  <nav style={navStyle}>
    {nav.map((l) => {
      const isActive = l.href === '/' ? current === '/' : current.startsWith(l.href);
      const section = l.href === '/' ? null : l.href.replace('/', '');
      return (
        <a
          href={l.href}
          aria-label={l.label}
          data-rail-section={section}
          class="site-rail-link"
          style={linkBase + (isActive ? linkActive : '')}
        >
          <Icon name={l.icon} width="16" height="16" />
          <span>{l.label}</span>
        </a>
      );
    })}
  </nav>

  <div style="padding:0 14px 20px;font-size:10px;color:rgba(14,17,22,0.5);">
    <a href="/privacy" style="display:block;color:rgba(14,17,22,0.5);text-decoration:none;margin-top:6px;">Privacy</a>
    <a href="/cookie" style="display:block;color:rgba(14,17,22,0.5);text-decoration:none;margin-top:6px;">Cookie</a>
  </div>
</aside>

<script is:inline>
  (() => {
    const fire = (name, detail) => window.dispatchEvent(new CustomEvent(name, { detail }));

    document.querySelectorAll('.site-rail-link[data-rail-section]').forEach((el) => {
      const section = el.getAttribute('data-rail-section');
      if (!section) return;
      el.addEventListener('click', (e) => { e.preventDefault(); fire('rail-flyout:open', section); });
      el.addEventListener('mouseenter', () => fire('rail-flyout:open', section));
      el.addEventListener('focus', () => fire('rail-flyout:open', section));
    });

    const rail = document.querySelector('.site-rail');
    if (rail) {
      rail.addEventListener('mouseenter', () => fire('rail-flyout:cancel-close'));
      rail.addEventListener('mouseleave', () => fire('rail-flyout:schedule-close'));
    }

    // Hover highlight (no CSS dep)
    document.querySelectorAll('.site-rail-link').forEach((el) => {
      const orig = el.getAttribute('style') || '';
      el.addEventListener('mouseenter', () => {
        if (orig.includes('#0e1116;color:#fff')) return;
        el.setAttribute('style', orig + 'background:rgba(0,0,0,0.05);color:#0e1116;');
      });
      el.addEventListener('mouseleave', () => el.setAttribute('style', orig));
    });
  })();
</script>

<style is:global>
  main.site-main { margin-left: 88px; }
</style>
