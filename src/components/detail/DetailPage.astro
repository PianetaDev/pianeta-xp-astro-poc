---
interface CtaProp { label: string; href?: string; action?: string; external?: boolean; }
interface RelatedItem { type: string; slug: string; label?: string; }
interface NextItem { type: string; slug: string; title: string; deck?: string; cover?: string; kicker?: string; }
interface BylineProp { authors?: string[]; date?: string; meta?: string[]; }
interface MetaItem { label: string; value: string; href?: string; external?: boolean; }

interface Props {
  eyebrowParts?: Array<{ label: string; href?: string }>;
  title: string;
  deck?: string;
  cover?: string;
  heroPortrait?: boolean;
  primaryCta?: CtaProp;
  secondaryCta?: CtaProp;
  backHref?: string;
  backLabel?: string;
  related?: RelatedItem[];
  relatedTitle?: string;
  nextItem?: NextItem;
  byline?: BylineProp;
  metaInline?: MetaItem[];
  twoCol?: boolean;
  jsonLd?: any;
  fallbackBanner?: string;
}
const {
  eyebrowParts = [],
  title,
  deck,
  cover,
  heroPortrait = false,
  primaryCta,
  secondaryCta,
  backHref,
  backLabel,
  related = [],
  relatedTitle = 'Approfondimenti',
  nextItem,
  byline,
  metaInline = [],
  twoCol = false,
  jsonLd,
  fallbackBanner,
} = Astro.props;

const bylineParts: string[] = [];
if (byline?.authors?.length) bylineParts.push('di ' + byline.authors.join(', '));
if (byline?.date) bylineParts.push(byline.date);
if (byline?.meta?.length) bylineParts.push(...byline.meta);

const renderCta = (c: CtaProp, cls: string) => {
  if (c.href) {
    const attrs = c.external ? { target: '_blank', rel: 'noopener' } : {};
    return { tag: 'a' as const, href: c.href, attrs, cls, label: c.label };
  }
  return { tag: 'button' as const, attrs: c.action ? { 'data-action': c.action, type: 'button' } : { type: 'button' }, cls, label: c.label };
};
---
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
{fallbackBanner && (
  <div class="detail-fallback-banner" role="status" style="max-width:1100px;margin:16px auto 0;padding:10px 16px;background:rgba(255,107,51,0.10);border:1px solid rgba(255,107,51,0.25);border-radius:8px;color:var(--pianeta-text);font-size:13px;line-height:1.4;">
    {fallbackBanner}
  </div>
)}
<article class="detail-page">

  <header class="detail-head">
    {eyebrowParts.length > 0 && (
      <p class="detail-eyebrow">
        {eyebrowParts.map((p, i) => (
          <>
            {i > 0 && <span> · </span>}
            {p.href ? <a href={p.href}>{p.label}</a> : <span>{p.label}</span>}
          </>
        ))}
      </p>
    )}
    <h1 class="detail-title">{title}</h1>
    {deck && <p class="detail-deck">{deck}</p>}

    {(primaryCta || secondaryCta) && (
      <div class="detail-cta-row">
        <button type="button" class="cta-btn cta-ghost detail-listen" data-listen aria-label="Ascolta questa pagina"><span aria-hidden="true">▶</span> Ascolta</button>
        {primaryCta && (primaryCta.href
          ? <a href={primaryCta.href} class="cta-btn cta-primary" {...(primaryCta.external ? { target: '_blank', rel: 'noopener' } : {})}>{primaryCta.label}</a>
          : <button type="button" class="cta-btn cta-primary" data-action={primaryCta.action}>{primaryCta.label}</button>
        )}
        {secondaryCta && (secondaryCta.href
          ? <a href={secondaryCta.href} class="cta-btn cta-secondary" {...(secondaryCta.external ? { target: '_blank', rel: 'noopener' } : {})}>{secondaryCta.label}</a>
          : <button type="button" class="cta-btn cta-secondary" data-action={secondaryCta.action}>{secondaryCta.label}</button>
        )}
      </div>
    )}
  </header>

  <div class:list={['detail-hero', heroPortrait && 'is-portrait']}>
    <picture>
      {/^.*\.(png|jpe?g)$/i.test(cover || '') && (
        <source srcset={(cover || '').replace(/\.(png|jpe?g)$/i, '.webp')} type="image/webp" />
      )}
      <img src={cover || '/og/placeholder.svg'} alt={title} loading="eager" fetchpriority="high" decoding="async" />
    </picture>
  </div>

  {bylineParts.length > 0 && (
    <p class="detail-byline">{bylineParts.join(' · ')}</p>
  )}

  {metaInline.length > 0 && (
    <ul class="detail-meta-inline">
      {metaInline.map((m) => (
        <li>
          <span class="detail-meta-label">{m.label}</span>
          {m.href
            ? <a class="detail-meta-value" href={m.href} {...(m.external ? { target: '_blank', rel: 'noopener' } : {})}>{m.value}{m.external && ' ↗'}</a>
            : <span class="detail-meta-value">{m.value}</span>}
        </li>
      ))}
    </ul>
  )}

  <section class="detail-body">
    <div class="detail-prose prose-eclag">
      <slot />
    </div>
  </section>

  <slot name="after" />

  {related.length > 0 && (
    <section class="detail-related">
      <h2 class="detail-related-title">{relatedTitle}</h2>
      <ul class="detail-related-list">
        {related.map((r) => (
          <li><a href={`/${r.type}/${r.slug}`} class="detail-related-card">
            <span class="detail-related-kicker">{r.type}</span>
            <span class="detail-related-name">{r.label || r.slug.replace(/-/g, ' ')}</span>
            <span class="detail-related-arrow">→</span>
          </a></li>
        ))}
      </ul>
    </section>
  )}

  {nextItem && (
    <section class="detail-next">
      <p class="detail-next-eyebrow">Continua a leggere</p>
      <a href={`/${nextItem.type}/${nextItem.slug}`} class="detail-next-card">
        {nextItem.cover && (
          <div class="detail-next-img">
            <picture>
              {/^.*\.(png|jpe?g)$/i.test(nextItem.cover) && (
                <source srcset={nextItem.cover.replace(/\.(png|jpe?g)$/i, '-card.webp')} type="image/webp" />
              )}
              <img src={nextItem.cover} alt={nextItem.title} loading="lazy" decoding="async" />
            </picture>
          </div>
        )}
        <div class="detail-next-body">
          {nextItem.kicker && <p class="detail-next-kicker">{nextItem.kicker}</p>}
          <h3 class="detail-next-title">{nextItem.title}</h3>
          {nextItem.deck && <p class="detail-next-deck">{nextItem.deck}</p>}
          <p class="detail-next-arrow">Leggi →</p>
        </div>
      </a>
    </section>
  )}

  <section class="detail-share">
    <p class="detail-share-label">Condividi</p>
    <div class="detail-share-row">
      <button type="button" class="share-btn" data-share="native" aria-label="Condividi (sistema)">↗ Condividi</button>
      <button type="button" class="share-btn" data-share="copy" aria-label="Copia link">⧉ Copia link</button>
      <a class="share-btn" data-share="email" href="#" aria-label="Email">✉ Email</a>
      <a class="share-btn" data-share="whatsapp" target="_blank" rel="noopener" href="#" aria-label="WhatsApp">WhatsApp</a>
      <a class="share-btn" data-share="linkedin" target="_blank" rel="noopener" href="#" aria-label="LinkedIn">LinkedIn</a>
      <a class="share-btn" data-share="x" target="_blank" rel="noopener" href="#" aria-label="X">X</a>
    </div>
  </section>

  {backHref && (
    <footer class="detail-foot">
      <a href={backHref} class="cta-btn cta-ghost">← {backLabel || 'Indietro'}</a>
    </footer>
  )}

  <script is:inline>
    (() => {
      // Audio "Ascolta" — Web Speech Synthesis, browser-native, zero cost
      const listenInit = () => {
        const btn = document.querySelector('[data-listen]');
        if (!btn) return;
        if (!('speechSynthesis' in window)) { btn.style.display = 'none'; return; }

        let utter = null;
        let playing = false;
        let paused = false;

        function getText() {
          const title = document.querySelector('.detail-title')?.textContent || '';
          const deck = document.querySelector('.detail-deck')?.textContent || '';
          const prose = document.querySelector('.detail-prose')?.textContent || '';
          return `${title}. ${deck}. ${prose}`.replace(/\s+/g, ' ').trim();
        }
        function setLabel(text) {
          btn.innerHTML = `<span aria-hidden="true">${text === 'Ascolta' ? '▶' : (text === 'Pausa' ? '⏸' : '▶')}</span> ${text}`;
        }
        function stop() {
          window.speechSynthesis.cancel();
          playing = false; paused = false;
          setLabel('Ascolta');
        }
        btn.addEventListener('click', () => {
          if (!playing) {
            const text = getText();
            if (!text) return;
            utter = new SpeechSynthesisUtterance(text);
            utter.lang = document.documentElement.lang === 'en' ? 'en-US' : 'it-IT';
            utter.rate = 1.0;
            utter.onend = stop;
            utter.onerror = stop;
            window.speechSynthesis.speak(utter);
            playing = true; paused = false;
            setLabel('Pausa');
          } else if (!paused) {
            window.speechSynthesis.pause();
            paused = true;
            setLabel('Riprendi');
          } else {
            window.speechSynthesis.resume();
            paused = false;
            setLabel('Pausa');
          }
        });
        // Stop on page navigation
        document.addEventListener('astro:before-preparation', stop);
      };
      document.addEventListener('astro:page-load', listenInit);

      const init = () => {
        const url = window.location.href;
        const title = document.title;
        const enc = encodeURIComponent;
        document.querySelectorAll('a[data-share="email"]').forEach((a) => { a.href = `mailto:?subject=${enc(title)}&body=${enc(title + '\n' + url)}`; });
        document.querySelectorAll('a[data-share="whatsapp"]').forEach((a) => { a.href = `https://wa.me/?text=${enc(title + ' — ' + url)}`; });
        document.querySelectorAll('a[data-share="linkedin"]').forEach((a) => { a.href = `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`; });
        document.querySelectorAll('a[data-share="x"]').forEach((a) => { a.href = `https://x.com/intent/post?text=${enc(title)}&url=${enc(url)}`; });

        const native = document.querySelector('[data-share="native"]');
        if (native) {
          if (!navigator.share) { native.style.display = 'none'; }
          else native.addEventListener('click', () => navigator.share({ title, url }).catch(() => {}));
        }
        const copyBtn = document.querySelector('[data-share="copy"]');
        if (copyBtn) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(url);
              const orig = copyBtn.textContent;
              copyBtn.textContent = '✓ Copiato';
              setTimeout(() => { copyBtn.textContent = orig; }, 1600);
            } catch {}
          });
        }
      };
      document.addEventListener('astro:page-load', init);
    })();
  </script>

  <script is:inline>
    document.querySelectorAll('[data-action="open-hire-us"]').forEach((b) => {
      b.addEventListener('click', () => window.dispatchEvent(new CustomEvent('hire-us:open')));
    });
    document.querySelectorAll('[data-action="open-alba"]').forEach((b) => {
      b.addEventListener('click', () => window.dispatchEvent(new CustomEvent('alba:open')));
    });
  </script>
</article>
