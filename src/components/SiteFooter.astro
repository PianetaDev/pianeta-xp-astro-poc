---
const year = new Date().getFullYear();
---
<footer class="site-main site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-brand">
      <img src="/brand/logo-horizontal-color.svg" alt="Pianeta.Studio" width="282" height="80" class="site-footer-logo" loading="lazy" decoding="async" />
      <span class="badge-benefit" aria-label="Società Benefit dal 2023">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 6 6 .5-4.5 4 1.5 6.5L12 16l-6 3 1.5-6.5-4.5-4 6-.5z"/></svg>
        Società Benefit
      </span>
    </div>
    <div class="site-footer-meta">
      <p class="site-footer-tagline">Sustainable Creativity</p>
      <address class="site-footer-address">
        Pianeta.Studio S.r.l. Società Benefit<br />
        Via IV Novembre, 18, 95037 San Giovanni La Punta, CT, Italy
      </address>
      <p class="site-footer-contact">
        <a href="mailto:info@pianeta.studio">info@pianeta.studio</a> ·
        <a href="tel:+393938055439">+39 393 805 5439</a>
      </p>
      <p class="site-footer-fiscal">
        P.IVA 06037730873 · SDI M5UXCR1 · REA CT-459996
      </p>
      <p class="site-footer-founder">
        Founder · <a href="/team/max">Massimiliano Mauro</a> ·
        <a href="https://www.linkedin.com/in/maxmauro/" target="_blank" rel="noopener">LinkedIn</a> ·
        <a href="https://cal.com/maxmauro" target="_blank" rel="noopener">Book a call</a>
      </p>
      <p class="site-footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/cookie">Cookie</a>
        <a href="/contact">Contatti</a>
        <a href="/llms.txt">llms.txt</a>
        <a href="https://www.instagram.com/pianeta.studio/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.linkedin.com/company/pianeta-studio/" target="_blank" rel="noopener">LinkedIn</a>
      </p>
      <p class="site-footer-copy">© {year} Pianeta.Studio S.r.l. SB — All rights reserved</p>
      <div class="theme-switcher" role="group" aria-label="Tema visivo">
        <button type="button" data-theme-set="light" aria-label="Tema chiaro">☀</button>
        <button type="button" data-theme-set="auto" aria-label="Tema automatico (segue il tramonto sui server Pianeta)">◐</button>
        <button type="button" data-theme-set="dark" aria-label="Tema scuro">☾</button>
      </div>
      <script is:inline>
        (() => {
          const root = document.documentElement;
          const sync = () => {
            const cur = root.getAttribute('data-theme') || 'auto';
            document.querySelectorAll('[data-theme-set]').forEach((b) => {
              b.setAttribute('aria-pressed', String(b.getAttribute('data-theme-set') === cur));
            });
          };
          document.querySelectorAll('[data-theme-set]').forEach((b) => {
            b.addEventListener('click', () => {
              const v = b.getAttribute('data-theme-set');
              root.setAttribute('data-theme', v);
              try { localStorage.setItem('pianeta-theme', v); } catch (e) {}
              sync();
            });
          });
          sync();
        })();
      </script>
    </div>
  </div>
</footer>

<style is:global>
  .site-footer {
    margin-left: 88px;
    border-top: 1px solid var(--pianeta-border);
    margin-top: 80px;
    padding: 40px 32px 64px;
    transition: padding-right 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .site-footer-inner { max-width: 1100px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px; align-items: flex-start; }
  @media (min-width: 800px) { .site-footer-inner { flex-direction: row; justify-content: space-between; align-items: flex-start; } }
  .site-footer-brand { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; }
  .site-footer-logo { width: 160px; height: auto; display: block; }
  .badge-benefit { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: rgba(255,107,51,0.10); color: var(--cta-primary); border: 1px solid rgba(255,107,51,0.25); border-radius: 999px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .badge-benefit svg { fill: var(--cta-primary); }
  .site-footer-meta { font-size: 12px; color: var(--pianeta-muted); display: flex; flex-direction: column; gap: 12px; line-height: 1.55; max-width: 540px; }
  @media (min-width: 800px) { .site-footer-meta { text-align: right; max-width: 460px; align-items: flex-end; } }
  .site-footer-tagline { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: var(--cta-primary); font-weight: 700; margin: 0; }
  .site-footer-address { font-style: normal; color: var(--pianeta-muted-strong); margin: 0; }
  .site-footer-contact, .site-footer-fiscal, .site-footer-founder, .site-footer-copy { margin: 0; }
  .site-footer-meta a { color: inherit; text-decoration: none; }
  .site-footer-meta a:hover { color: var(--cta-primary); text-decoration: underline; }
  .site-footer-copy { font-size: 11px; opacity: 0.7; }
  .site-footer-links { display: flex; gap: 14px; flex-wrap: wrap; margin: 0; }
  @media (min-width: 800px) { .site-footer-links { justify-content: flex-end; } }

  .theme-switcher { display: inline-flex; gap: 4px; margin-top: 6px; padding: 4px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 999px; }
  .theme-switcher button { width: 28px; height: 28px; padding: 0; border: 0; background: transparent; color: var(--pianeta-muted); font-size: 14px; border-radius: 999px; cursor: pointer; transition: background 150ms, color 150ms; }
  .theme-switcher button:hover { color: var(--pianeta-text); background: var(--pianeta-border); }
  .theme-switcher button[aria-pressed="true"] { background: var(--cta-primary); color: var(--cta-primary-ink); }

  /* 3-pannel sync col main quando Alba apre */
  @media (min-width: 1024px) {
    body.alba-open .site-footer { padding-right: 480px; }
  }
  @media (min-width: 1280px) {
    body.alba-open .site-footer { padding-right: 560px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-footer { transition: none !important; }
  }
</style>
