---
import { type Offer } from '../../data/offers';
import { getShowcase } from '../../data/showcase';
import { HIRE_STRINGS, type Locale } from './strings';

interface Props { offer: Offer; locale?: Locale; }
const { offer, locale = 'it' } = Astro.props;
const S = HIRE_STRINGS[locale];
const { works: WORKS, foundations: FOUNDATIONS } = getShowcase(locale);
const workPrefix = locale === 'en' ? '/en/work' : '/work';
const worksTitle = locale === 'en' ? 'Selected work' : 'Lavori selezionati';
// stesso overlay ricco della landing /hire: card .work-open → pannello dx con prev/next
const cfg = {
  locale, workPrefix,
  works: WORKS.map((w) => ({ slug: w.href.split('/work/')[1], title: w.title })),
  S: { ovLoading: S.ovLoading, ovFail: S.ovFail, ovWorkFull: S.ovWorkFull, ovLive: S.ovLive },
};

const accents: Record<string, string> = { green: '#1f7a3a', orange: '#FF6B33', dark: '#5a4fcf', blue: '#1f5b8f' };
const accent = accents[offer.accent];
const isQuote = !offer.stripe;
const recurNote = offer.stripe?.mode === 'subscription' ? S.recurMonth : isQuote ? S.quoteNote : S.recurOnce;
const hirePrefix = locale === 'en' ? '/en/hire' : '/hire';
const QUOTE_HREF = `${S.booking}?offer=${offer.slug}`;
const dayPrefix = locale === 'en' ? 'D' : 'G';
const priceMain = offer.price.replace(/\s*\+\s*(IVA|VAT)\s*$/, '');
const clientsStrip = 'Armani · Prada · La Repubblica · Wired · Plenitude · BC3 · ChildFund · WeWorld · ECLAG · ARIES →';

const sprintDays = offer.method ?? [];
const sprintFaqs = offer.faqs ?? [];
const hasMethod = sprintDays.length > 0;
const isDays = offer.methodKind === 'days';

// A/B: ?v=b serve la variante (es. dagli annunci). Default = a. Canonical (BaseLayout) già punta alla base → niente problemi SEO.
const variant = Astro.url.searchParams.get('v') === 'b' ? 'b' : 'a';
const forWho = (variant === 'b' && offer.variantB?.forWho) ? offer.variantB.forWho : offer.forWho;
---
<div class="hire-page" data-offer={offer.slug} data-variant={variant}>
  <main class="wrap">
    <p style="margin:24px 0 18px"><a href={hirePrefix} style="color:var(--mut);text-decoration:none;font-size:13px">{S.allOffers}</a></p>

    <div class="offer-grid">
      <article class="offer-article">
        <p class="offer-kicker" style={`color:${accent}`}>{offer.emoji} {S.offerKicker}</p>
        <h1 class="offer-title">{offer.name}</h1>
        <p class="offer-forwho">{forWho}</p>
        <p class="offer-detail">{offer.detail}</p>

        <h2 class="offer-h2">{S.cosaOttieni}</h2>
        <ul class="offer-list">
          {offer.deliverables.map((d) => <li><span style={`color:${accent}`}>✓</span> {d}</li>)}
        </ul>

        {offer.stats && offer.stats.length > 0 && (
          <div class="offer-stats">
            <h2 class="offer-h2">{locale === 'en' ? 'Measured performance & impact' : 'Performance e impatto, misurati'}</h2>
            <div class="offer-stats-grid">
              {offer.stats.map((s) => (
                <div class="offer-stat"><div class="offer-stat-v" style={`color:${accent}`}>{s.v}</div><div class="offer-stat-k">{s.k}</div></div>
              ))}
            </div>
            {offer.statsNote && <p class="offer-stats-note">{offer.statsNote}</p>}
          </div>
        )}

        {hasMethod && (
          <div class="sprint-method">
            <h2 class="offer-h2">{S.comeFunziona}</h2>
            <ol class="sprint-days">
              {sprintDays.map((d) => (
                <li>
                  <div class="sprint-day-n" style={`color:${accent}`}>{isDays ? dayPrefix : ''}{d.n}</div>
                  <div>
                    <div class="sprint-day-t">{d.title}</div>
                    <div class="sprint-day-b">{d.body}</div>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        )}

        {sprintFaqs.length > 0 && (
          <div class="sprint-faqs-wrap">
            <h2 class="offer-h2">{S.faqTitle}</h2>
            <div class="sprint-faqs">
              {sprintFaqs.map((f) => (
                <div>
                  <div class="sprint-faq-q">{f.q}</div>
                  <div class="sprint-faq-a">{f.a}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {offer.related.length > 0 && (
          <div class="offer-related">
            <h2 class="offer-h2">{S.casiTitle}</h2>
            <div class="offer-related-list">
              {offer.related.map((r) => (
                <a href={r.href} class="offer-related-card">
                  <span class="offer-related-kind" style={`color:${accent}`}>{r.kind === 'case' ? S.caseLabel : S.articleLabel}</span>
                  <span class="offer-related-title">{r.title} →</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="offer-clients">
          <span class="offer-clients-label">{S.clientsLabel}</span>
          <a href={S.workAll} class="offer-clients-names">{clientsStrip}</a>
        </div>
      </article>

      <aside class="offer-buy">
        <div class="offer-price">{priceMain}</div>
        <div class="offer-price-note">{isQuote ? recurNote : `${recurNote} · ${S.vatSuffix}`}</div>
        {offer.valueNote && <p class="offer-value-note">{offer.valueNote}</p>}
        {isQuote ? (
          <>
            <a href={QUOTE_HREF} class="offer-buy-btn quote-cta" style={`background:${accent}`}>{offer.quote?.label}</a>
            <a href={S.booking} class="offer-call-btn">{S.quoteCallAlt}</a>
            <p class="offer-reassure">{S.quoteReassure}</p>
          </>
        ) : (
          <>
            <button id="buy" data-offer={offer.slug} data-locale={locale} data-variant={variant} class="offer-buy-btn" style={`background:${accent}`}>{offer.stripe?.label}</button>
            <a href={S.booking} class="offer-call-btn">{S.callAlt}</a>
            <p class="offer-reassure" set:html={S.payReassure} />
            <div class="offer-after">
              <p class="offer-after-t">{S.afterTitle}</p>
              <ol class="offer-after-list">{S.after.map((x) => <li>{x}</li>)}</ol>
            </div>
          </>
        )}
      </aside>
    </div>

    <section class="offer-proof">
      <div class="offer-proofband" aria-label={S.proofBand}>
        <span class="offer-proofband-t">{S.proofBand}</span>
        <span class="offer-proofband-names">{FOUNDATIONS.map((f) => f.name).join(' · ')}</span>
      </div>

      <div class="offer-works-head">
        <h2 class="offer-works-title">{worksTitle}</h2>
        <a href={S.workAll} class="offer-works-all">{S.worksAll} →</a>
      </div>
      <div class="works-scroll">
        {WORKS.map((w) => (
          <a href={w.href} class="work-card work-open" data-work={w.href.split('/work/')[1]}>
            <div class="work-cover" style={`background-image:url('${w.cover}')`}></div>
            <div class="work-meta"><strong>{w.title}</strong><span>{w.client}</span></div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <!-- Approfondimento lavoro = overlay colonna destra, come la landing /hire -->
  <div id="work-ov" class="work-ov" hidden>
    <div class="work-ov-backdrop" data-close></div>
    <aside class="work-ov-panel" role="dialog" aria-label="Pianeta">
      <div class="work-ov-nav">
        <div class="work-ov-arrows">
          <button class="work-ov-prev" aria-label="Prev">‹</button>
          <span class="work-ov-count" id="work-ov-count"></span>
          <button class="work-ov-next" aria-label="Next">›</button>
        </div>
        <button class="work-ov-x" data-close aria-label="Close">✕</button>
      </div>
      <div id="work-ov-body" class="work-ov-body"></div>
    </aside>
  </div>
  <script type="application/json" id="hire-cfg" set:html={JSON.stringify(cfg)}></script>
</div>

<style>
  .hire-page {
    --card: var(--pianeta-bg-card); --line: var(--pianeta-border);
    --txt: var(--pianeta-text); --mut: var(--pianeta-muted); --acc: var(--cta-primary);
    --orange: var(--cta-primary); --green: #1f7a3a;
  }
  :global(.hub-hire-cta), :global(.hire-us-launcher) { display: none !important; }
  .wrap { max-width: 1040px; margin: 0 auto; padding: 0 24px 72px; }

  .offer-grid { display: grid; grid-template-columns: 1fr; gap: 36px; padding-bottom: 40px; }
  @media (min-width: 860px) { .offer-grid { grid-template-columns: minmax(0,1fr) 320px; gap: 56px; align-items: start; } }
  .offer-article { max-width: 680px; }
  .offer-kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; margin: 0 0 10px; }
  .offer-title { font-size: clamp(32px, 5vw, 44px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 14px; }
  .offer-forwho { color: var(--mut); font-size: 16px; margin: 0 0 28px; }
  .offer-detail { font-size: 18px; line-height: 1.7; margin: 0 0 36px; }
  .offer-h2 { font-size: 12px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--mut); margin: 0 0 14px; }
  .offer-list { list-style: none; display: grid; gap: 12px; font-size: 16px; padding: 0; }
  .offer-list li { display: flex; gap: 10px; }

  .offer-stats { margin-top: 38px; }
  .offer-stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  @media (min-width: 560px) { .offer-stats-grid { grid-template-columns: repeat(4, 1fr); } }
  .offer-stat { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 16px 14px; text-align: center; }
  .offer-stat-v { font-size: 22px; font-weight: 800; letter-spacing: -0.01em; }
  .offer-stat-k { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--mut); margin-top: 4px; }
  .offer-stats-note { font-size: 12px; color: var(--mut); line-height: 1.5; margin: 12px 0 0; }

  .sprint-method { margin-top: 38px; }
  .sprint-faqs-wrap { margin-top: 38px; }

  .offer-value-note {
    font-size: 13px; line-height: 1.5; color: var(--txt); margin: 12px 0 0;
    padding: 11px 13px; background: var(--card); border: 1px solid var(--line); border-radius: 12px;
  }
  .sprint-days { list-style: none; display: grid; gap: 12px; padding: 0; margin: 0 0 4px; }
  .sprint-days li { display: flex; gap: 16px; background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px; }
  .sprint-day-n { font-size: 22px; font-weight: 800; min-width: 40px; }
  .sprint-day-t { font-weight: 600; margin-bottom: 4px; }
  .sprint-day-b { color: var(--mut); font-size: 14px; line-height: 1.5; }
  .sprint-faqs { display: grid; gap: 16px; }
  .sprint-faq-q { font-weight: 600; margin-bottom: 4px; }
  .sprint-faq-a { color: var(--mut); font-size: 14px; line-height: 1.5; }

  .offer-related { margin-top: 38px; }
  .offer-related .offer-h2 { margin-bottom: 12px; }
  .offer-related-list { display: grid; gap: 10px; }
  .offer-related-card { display: flex; flex-direction: column; gap: 3px; padding: 14px 16px;
    border: 1px solid var(--line); border-radius: 12px; text-decoration: none; transition: border-color 150ms; }
  .offer-related-card:hover { border-color: var(--pianeta-border-strong); }
  .offer-related-kind { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
  .offer-related-title { font-size: 15px; font-weight: 600; }
  .offer-clients { margin-top: 34px; padding-top: 24px; border-top: 1px solid var(--line); }
  .offer-clients-label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--mut); margin-bottom: 8px; }
  .offer-clients-names { font-size: 14px; font-weight: 600; line-height: 1.6; color: var(--txt); text-decoration: none; }
  .offer-clients-names:hover { color: var(--acc); }

  .offer-buy { background: var(--card); border: 1px solid var(--line); border-radius: 20px; padding: 26px 24px; display: flex; flex-direction: column; gap: 12px; }
  @media (min-width: 860px) { .offer-buy { position: sticky; top: 86px; } }
  .offer-price { font-size: 30px; font-weight: 800; letter-spacing: -0.02em; }
  .offer-price-note { color: var(--mut); font-size: 13px; margin-top: -6px; }
  .offer-buy-btn { display: block; text-align: center; text-decoration: none; color: #fff; border: 0; font-weight: 700; padding: 14px; border-radius: 11px; cursor: pointer; font-size: 15px; margin-top: 6px; }
  .offer-buy-btn:disabled { opacity: .6; cursor: default; }
  .offer-call-btn { text-align: center; padding: 12px; border: 1px solid var(--line); border-radius: 11px; text-decoration: none; font-weight: 600; font-size: 14px; }
  .offer-call-btn:hover { border-color: var(--pianeta-border-strong); }
  .offer-reassure { color: var(--mut); font-size: 12px; line-height: 1.5; margin-top: 4px; }
  .offer-after { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--line); }
  .offer-after-t { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--mut); margin: 0 0 8px; }
  .offer-after-list { margin: 0; padding-left: 18px; display: grid; gap: 5px; }
  .offer-after-list li { font-size: 13px; line-height: 1.45; }

  /* Banda prova + lavori — la pagina offerta si regge da sola, come la main */
  .offer-proof { margin-top: 8px; padding-top: 40px; border-top: 1px solid var(--line); }
  .offer-proofband {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 14px;
    background: var(--card); border: 1px solid var(--line); border-radius: 14px;
    padding: 16px 20px; margin-bottom: 36px;
  }
  .offer-proofband-t { font-size: 13px; font-weight: 700; }
  .offer-proofband-names { font-size: 13px; color: var(--mut); }

  .offer-works-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 4px; }
  .offer-works-title { font-size: clamp(20px, 3vw, 26px); letter-spacing: -0.01em; margin: 0; }
  .offer-works-all { font-size: 13px; font-weight: 600; color: var(--acc); text-decoration: none; white-space: nowrap; }
  .offer-works-all:hover { text-decoration: underline; }

  /* card lavori = identiche alla landing /hire (aprono l'overlay) */
  .works-scroll { display: flex; gap: 16px; overflow-x: auto; padding: 12px 0 8px; scroll-snap-type: x mandatory; margin: 0 -24px; padding-left: 24px; padding-right: 24px; }
  .works-scroll::-webkit-scrollbar { height: 6px; }
  .work-card { flex: 0 0 300px; scroll-snap-align: start; text-decoration: none; color: inherit; }
  .work-cover { aspect-ratio: 16/10; border-radius: 14px; background-size: cover; background-position: center; border: 1px solid var(--line); transition: transform 180ms ease; }
  .work-card:hover .work-cover { transform: translateY(-3px); }
  .work-meta { padding: 10px 2px; display: flex; flex-direction: column; }
  .work-meta strong { font-size: 15px; }
  .work-meta span { font-size: 12px; color: var(--mut); }
  @media (min-width: 860px) { .works-scroll { margin: 0; padding-left: 0; padding-right: 0; } }

  /* Approfondimento = colonna destra (overlay), come la landing /hire */
  .work-ov { position: fixed; inset: 0; z-index: 60; }
  .work-ov[hidden] { display: none; }
  .work-ov-backdrop { position: absolute; inset: 0; background: rgba(14,17,22,.18); }
  .work-ov-panel { position: absolute; top: 0; right: 0; bottom: 0; width: 100%; max-width: 760px; background: var(--pianeta-bg);
    box-shadow: -24px 0 70px rgba(14,17,22,.16); overflow-y: auto; border-left: 1px solid var(--pianeta-border); }
  .work-ov-nav { position: sticky; top: 0; z-index: 3; display: flex; align-items: center; justify-content: space-between;
    padding: 12px clamp(16px, 3vw, 28px); background: var(--pianeta-bg); border-bottom: 1px solid var(--pianeta-border); }
  .work-ov-arrows { display: flex; align-items: center; gap: 8px; }
  .work-ov-prev, .work-ov-next, .work-ov-x { background: var(--card); border: 1px solid var(--line); width: 38px; height: 38px;
    border-radius: 999px; cursor: pointer; line-height: 1; color: var(--txt); display: inline-flex; align-items: center; justify-content: center; }
  .work-ov-prev, .work-ov-next { font-size: 20px; }
  .work-ov-x { font-size: 14px; }
  .work-ov-prev:hover, .work-ov-next:hover, .work-ov-x:hover { border-color: var(--pianeta-border-strong); }
  .work-ov-count { font-size: 12px; color: var(--mut); min-width: 44px; text-align: center; }
  .work-ov-body { padding: 24px clamp(28px, 4vw, 56px) 72px; }
  :global(.work-ov-cover) { width: 100%; height: clamp(220px, 36vw, 380px); border-radius: 16px; background-size: cover; background-position: center; margin-bottom: 30px; }
  :global(.work-ov-eyebrow) { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: var(--pianeta-muted); margin: 0 0 16px; }
  :global(.work-ov-body h1) { font-size: clamp(30px, 4vw, 44px); font-weight: 900; letter-spacing: -.02em; line-height: 1.05; margin: 0 0 16px; }
  :global(.work-ov-deck) { font-size: clamp(17px, 2vw, 20px); color: var(--pianeta-muted); line-height: 1.5; margin: 0 0 28px; }
  :global(.work-ov-meta) { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 28px; padding: 20px 0; margin: 0 0 30px; border-top: 1px solid var(--pianeta-border); border-bottom: 1px solid var(--pianeta-border); }
  :global(.work-ov-meta li) { display: flex; flex-direction: column; gap: 2px; }
  :global(.work-ov-meta .k) { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--pianeta-muted); }
  :global(.work-ov-meta .v) { font-size: 14px; font-weight: 600; }
  :global(.work-ov-content) { font-size: 17px; line-height: 1.75; max-width: 65ch; }
  :global(.work-ov-content h2), :global(.work-ov-content h3) { font-size: 21px; font-weight: 800; letter-spacing: -.01em; margin: 32px 0 10px; }
  :global(.work-ov-content p) { margin: 0 0 16px; }
  :global(.work-ov-content a) { color: var(--cta-primary); }
  :global(.work-ov-live) { display: inline-block; margin: 32px 14px 0 0; background: var(--cta-primary); color: #fff; font-weight: 600; padding: 12px 22px; border-radius: 999px; text-decoration: none; }
  :global(.work-ov-full) { display: inline-block; margin-top: 32px; color: var(--pianeta-muted); font-weight: 600; text-decoration: none; font-size: 14px; }
  :global(.work-ov-full:hover) { color: var(--pianeta-text); }
</style>

<script is:inline>
  (() => {
    const ck = (n) => (document.cookie.match('(^|;)\\s*' + n + '\\s*=\\s*([^;]+)') || [])[2] || '';
    // cattura gclid (auto-tagging Google Ads) → cookie 90gg, per attribuire la conversione alla campagna
    const g = new URLSearchParams(location.search).get('gclid');
    if (g) document.cookie = 'gclid=' + encodeURIComponent(g) + ';max-age=7776000;path=/';
    const send = (event, offer, variant) => {
      (window.dataLayer = window.dataLayer || []).push({ event, offer, variant });
      const body = JSON.stringify({ event, offer, variant, gclid: decodeURIComponent(ck('gclid') || ''), page: location.pathname });
      try {
        if (navigator.sendBeacon) navigator.sendBeacon('/api/track', new Blob([body], { type: 'application/json' }));
        else fetch('/api/track', { method: 'POST', headers: { 'content-type': 'application/json' }, body, keepalive: true });
      } catch (e) { /* noop */ }
    };
    const bind = () => {
      const root = document.querySelector('.hire-page[data-offer]');
      if (!root || root.dataset.bound) return;
      root.dataset.bound = '1';
      const offer = root.dataset.offer, variant = root.dataset.variant || 'a';
      send('hire_offer_view', offer, variant);
      const q = root.querySelector('.quote-cta');
      if (q) q.addEventListener('click', () => send('hire_lead_intent', offer, variant));
      const btn = document.getElementById('buy');
      if (btn) btn.addEventListener('click', async (e) => {
        const b = e.currentTarget;
        send('hire_begin_checkout', b.dataset.offer, variant);
        b.disabled = true; const orig = b.textContent; b.textContent = '…';
        try {
          const r = await fetch('/api/hire/checkout', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ offer: b.dataset.offer, locale: b.dataset.locale, variant: variant }) });
          const d = await r.json();
          if (d.url) { window.location.href = d.url; } else { b.disabled = false; b.textContent = orig; alert(d.error || 'Error'); }
        } catch { b.disabled = false; b.textContent = orig; }
      });
    };
    bind();
    document.addEventListener('astro:page-load', bind);
  })();
</script>

<script is:inline>
  // Overlay approfondimento lavoro — identico alla landing /hire (pannello dx, prev/next)
  (() => {
    const init = () => {
      const ov = document.getElementById('work-ov');
      if (!ov || ov.dataset.bound) return;
      ov.dataset.bound = '1';
      const cfgEl = document.getElementById('hire-cfg');
      const C = cfgEl ? JSON.parse(cfgEl.textContent) : { locale: 'it', workPrefix: '/work', works: [], S: {} };
      const T = C.S || {};
      const WORKS = Array.isArray(C.works) ? C.works : [];
      const body = document.getElementById('work-ov-body');
      const panel = ov.querySelector('.work-ov-panel');
      const countEl = document.getElementById('work-ov-count');
      let cur = -1;
      const esc = (x) => String(x ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const md = (s) => String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/^#{1,3} (.*)$/gm, '<h2>$1</h2>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
        .split(/\n{2,}/).map((b) => b.match(/^<h2>/) ? b : '<p>' + b.replace(/\n/g, '<br>') + '</p>').join('');
      const setCount = () => { if (countEl) countEl.textContent = (WORKS.length && cur >= 0) ? (cur + 1) + ' / ' + WORKS.length : ''; };
      const loading = () => { body.innerHTML = '<p style="padding:60px 0;text-align:center;color:var(--pianeta-muted)">' + (T.ovLoading || 'Carico…') + '</p>'; ov.hidden = false; document.body.style.overflow = 'hidden'; if (panel) panel.scrollTop = 0; };
      const fail = () => { body.innerHTML = '<p style="padding:40px 0">' + (T.ovFail || 'Contenuto non disponibile.') + '</p>'; };
      const q = '?locale=' + C.locale;
      const renderWork = (d, slug) => {
        const eyebrow = [d.client, d.category].filter(Boolean).map(esc).join(' · ');
        const services = Array.isArray(d.services) ? d.services : (d.services ? [d.services] : []);
        const meta = [
          d.year ? { k: 'Anno', v: esc(d.year) } : null,
          d.sector ? { k: 'Settore', v: esc(d.sector) } : null,
          services.length ? { k: 'Servizi', v: services.map(esc).join(', ') } : null,
        ].filter(Boolean);
        body.innerHTML =
          (d.cover ? '<div class="work-ov-cover" style="background-image:url(\'' + String(d.cover).replace(/'/g, '%27') + '\')"></div>' : '') +
          (eyebrow ? '<p class="work-ov-eyebrow">' + eyebrow + '</p>' : '') +
          '<h1>' + esc(d.name || d.title) + '</h1>' +
          (d.description ? '<p class="work-ov-deck">' + esc(d.description) + '</p>' : '') +
          (meta.length ? '<ul class="work-ov-meta">' + meta.map((m) => '<li><span class="k">' + m.k + '</span><span class="v">' + m.v + '</span></li>').join('') + '</ul>' : '') +
          '<div class="work-ov-content">' + md(d.body || '') + '</div>' +
          (d.live_url ? '<a class="work-ov-live" href="' + esc(d.live_url) + '" target="_blank" rel="noopener">' + (T.ovLive || 'Live →') + '</a>' : '') +
          '<a class="work-ov-full" href="' + C.workPrefix + '/' + encodeURIComponent(slug) + '">' + (T.ovWorkFull || '→') + '</a>';
      };
      const openWork = async (slug) => {
        cur = WORKS.findIndex((w) => w.slug === slug); setCount();
        loading();
        try { renderWork(await (await fetch('/api/work/' + slug + '.json' + q)).json(), slug); }
        catch (e) { fail(); }
      };
      const step = (dir) => { if (!WORKS.length || cur < 0) return; cur = (cur + dir + WORKS.length) % WORKS.length; openWork(WORKS[cur].slug); };
      const close = () => { ov.hidden = true; document.body.style.overflow = ''; };
      document.addEventListener('click', (e) => {
        const c = (sel) => e.target.closest && e.target.closest(sel);
        let el;
        if (c('.work-ov-prev')) { e.preventDefault(); step(-1); return; }
        if (c('.work-ov-next')) { e.preventDefault(); step(1); return; }
        if ((el = c('.work-open'))) { e.preventDefault(); openWork(el.dataset.work); return; }
        if (c('[data-close]')) { close(); return; }
      });
      document.addEventListener('keydown', (e) => {
        if (ov.hidden) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') step(-1);
        else if (e.key === 'ArrowRight') step(1);
      });
    };
    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
