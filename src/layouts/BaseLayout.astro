---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteRail from '../components/SiteRail.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CookieConsent from '../components/vue/site/consent/CookieConsent.vue';
import MobileMenu from '../components/vue/site/MobileMenu.vue';
import SiteRailFlyout from '../components/vue/site/SiteRailFlyout.vue';
import NewsletterPopup from '../components/vue/site/newsletter/NewsletterPopup.vue';
import HireUsLauncher from '../components/vue/site/HireUsLauncher.vue';
import HireUsDrawer from '../components/vue/site/hire-us/HireUsDrawer.vue';
import AlbaFloater from '../components/vue/site/alba/AlbaFloater.vue';
import SiteArtifactPane from '../components/vue/site/SiteArtifactPane.vue';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  chrome?: boolean;
  minimal?: boolean;
}

const { title, description = '', ogImage = '/og/work-eclag.png', chrome = true, minimal = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const showIslands = chrome && !minimal;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="bg-[#fafaf7] text-[#0e1116] antialiased">
    {chrome && <SiteRail current={Astro.url.pathname} />}

    <main class={chrome ? 'site-main' : ''}>
      <slot />
    </main>

    {chrome && <SiteFooter />}

    {showIslands && (
      <>
        <CookieConsent client:only="vue" />
        <MobileMenu client:only="vue" />
        <SiteRailFlyout client:only="vue" />
        <NewsletterPopup client:only="vue" />
        <HireUsLauncher client:only="vue" />
        <HireUsDrawer client:only="vue" />
        <AlbaFloater client:only="vue" />
        <SiteArtifactPane client:only="vue" />
      </>
    )}

    <script is:inline>
      // Reveal-on-scroll (IntersectionObserver, ~700B)
      (() => {
        if (!('IntersectionObserver' in window)) return;
        const init = () => {
          const targets = document.querySelectorAll('.index-card, .bento-tile, .detail-hero, .detail-head, .detail-body, .detail-related');
          targets.forEach((el, i) => {
            el.classList.add('reveal-pre');
            el.style.transitionDelay = (Math.min(i % 6, 5) * 40) + 'ms';
          });
          const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('reveal-in');
                io.unobserve(e.target);
              }
            });
          }, { rootMargin: '-30px 0px', threshold: 0.05 });
          targets.forEach((el) => io.observe(el));
        };
        // Re-init on every Astro client-router navigation
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>
