---
import '../styles/global.css';
import SiteRail from '../components/SiteRail.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CookieConsent from '../components/vue/site/consent/CookieConsent.vue';
import MobileMenu from '../components/vue/site/MobileMenu.vue';
import SiteRailFlyout from '../components/vue/site/SiteRailFlyout.vue';
import NewsletterPopup from '../components/vue/site/newsletter/NewsletterPopup.vue';
import HireUsLauncher from '../components/vue/site/HireUsLauncher.vue';
import HireUsDrawer from '../components/vue/site/hire-us/HireUsDrawer.vue';
import AlbaFloater from '../components/vue/site/alba/AlbaFloater.vue';
import SiteArtifactPane from '../components/vue/site/SiteArtifactPane.vue';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  chrome?: boolean;
  minimal?: boolean;
}

const { title, description = '', ogImage = '/og/work-eclag.png', chrome = true, minimal = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const showIslands = chrome && !minimal;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body class="bg-[#fafaf7] text-[#0e1116] antialiased">
    {chrome && <SiteRail current={Astro.url.pathname} />}

    <main class={chrome ? 'md:ml-[88px]' : ''}>
      <slot />
    </main>

    {chrome && <SiteFooter />}

    {showIslands && (
      <>
        <CookieConsent client:idle />
        <MobileMenu client:idle />
        <SiteRailFlyout client:idle />
        <NewsletterPopup client:idle />
        <HireUsLauncher client:idle />
        <HireUsDrawer client:idle />
        <AlbaFloater client:idle />
        <SiteArtifactPane client:visible />
      </>
    )}
  </body>
</html>
