---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { isNightInItaly } from '../lib/server/sun';
import SiteRail from '../components/SiteRail.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CookieConsent from '../components/vue/site/consent/CookieConsent.vue';
import MobileMenu from '../components/vue/site/MobileMenu.vue';
import SiteRailFlyout from '../components/vue/site/SiteRailFlyout.vue';
import NewsletterPopup from '../components/vue/site/newsletter/NewsletterPopup.vue';
import HireUsLauncher from '../components/vue/site/HireUsLauncher.vue';
import HireUsDrawer from '../components/vue/site/hire-us/HireUsDrawer.vue';
import AlbaFloater from '../components/vue/site/alba/AlbaFloater.vue';
import AlbaProactivePopup from '../components/vue/site/alba/AlbaProactivePopup.vue';
import SiteArtifactPane from '../components/vue/site/SiteArtifactPane.vue';
import SidePane from '../components/vue/site/SidePane.vue';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'work' | 'bulletin' | 'services' | 'lab' | 'team' | 'careers';
  ogSlug?: string;
  chrome?: boolean;
  minimal?: boolean;
  hideNewsletter?: boolean;   // su superfici di conversione (es. /hire) niente popup proattivi
}

const { title, description = '', ogImage = '/og/work-eclag.png', ogType, ogSlug, chrome = true, minimal = false, hideNewsletter = false } = Astro.props;
const ogImageResolved = ogType && ogSlug
  ? new URL(`/api/og/${ogType}/${ogSlug}.png`, Astro.site).toString()
  : ogImage;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const showIslands = chrome && !minimal;
const dataSun = isNightInItaly() ? 'night' : 'day';
const locale: 'it' | 'en' = Astro.url.pathname === '/en' || Astro.url.pathname.startsWith('/en/') ? 'en' : 'it';
---
<!doctype html>
<html lang={locale} data-theme="auto" data-sun={dataSun}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageResolved} />
    <meta name="twitter:image" content={ogImageResolved} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <ClientRouter />
    <script is:inline>
      // Theme: legge localStorage prima del paint per evitare flash.
      // Riapplica anche su astro:after-swap, altrimenti ogni navigazione ClientRouter
      // resetta data-theme al default SSR ("auto") → flip nero→bianco di giorno.
      (() => {
        const apply = () => {
          try {
            const saved = localStorage.getItem('pianeta-theme');
            if (saved === 'light' || saved === 'dark' || saved === 'auto') {
              document.documentElement.setAttribute('data-theme', saved);
            }
          } catch (e) {}
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>

    <!-- Google tag (gtag.js) — account Google Ads AW-16699800788 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-16699800788"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'AW-16699800788');
    </script>
    <!-- Fine Google tag -->

    <slot name="head" />
  </head>
  <body class="site-body antialiased" style="background:var(--pianeta-bg); color:var(--pianeta-text); transition:background 280ms ease, color 280ms ease;">
    {chrome && <SiteRail current={Astro.url.pathname} />}
    {chrome && <a href="/hire" class="hub-hire-cta">Lavoriamo insieme</a>}
    <style is:global>
      .hub-hire-cta {
        position: fixed; top: 16px; right: 16px; z-index: 40;
        background: var(--cta-primary, #FF6B33); color: var(--cta-primary-ink, #fff);
        font-weight: 600; font-size: 14px; padding: 9px 18px; border-radius: 999px;
        text-decoration: none; box-shadow: 0 6px 20px rgba(255,107,51,.30);
        transition: transform 150ms ease;
      }
      .hub-hire-cta:hover { transform: translateY(-1px); }
      @media (max-width: 640px) { .hub-hire-cta { top: 10px; right: 10px; padding: 7px 14px; font-size: 13px; } }
    </style>

    <main class={chrome ? 'site-main' : ''}>
      <slot />
    </main>

    {chrome && <SiteFooter />}

    {showIslands && (
      <>
        <CookieConsent client:only="vue" />
        <MobileMenu client:only="vue" />
        <SiteRailFlyout client:only="vue" />
        {!hideNewsletter && <NewsletterPopup client:only="vue" />}
        <HireUsLauncher client:only="vue" />
        <HireUsDrawer client:only="vue" />
        <AlbaFloater client:only="vue" />
        {!hideNewsletter && <AlbaProactivePopup client:only="vue" />}
        <SiteArtifactPane client:only="vue" />
        <SidePane client:only="vue" />
      </>
    )}


    <!-- LinkedIn Insight Tag — SOSTITUIRE 0000000 con il partner ID reale (Max) -->
    <script is:inline>
      _linkedin_partner_id = "0000000";
      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      window._linkedin_data_partner_ids.push(_linkedin_partner_id);
    </script>
    <script is:inline>
      (function(l) {
        if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
        window.lintrk.q=[]}
        var s = document.getElementsByTagName("script")[0];
        var b = document.createElement("script");
        b.type = "text/javascript";b.async = true;
        b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
        s.parentNode.insertBefore(b, s);
      })(window.lintrk);
    </script>
    <noscript>
      <img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid=0000000&fmt=gif" />
    </noscript>
    <!-- Fine LinkedIn Insight Tag -->

    <script is:inline>
      // Reveal-on-scroll (IntersectionObserver, ~700B)
      (() => {
        if (!('IntersectionObserver' in window)) return;
        const init = () => {
          const targets = document.querySelectorAll('.index-card, .bento-tile, .detail-hero, .detail-head, .detail-body, .detail-related');
          targets.forEach((el, i) => {
            el.classList.add('reveal-pre');
            el.style.transitionDelay = (Math.min(i % 6, 5) * 40) + 'ms';
          });
          const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('reveal-in');
                io.unobserve(e.target);
              }
            });
          }, { rootMargin: '-30px 0px', threshold: 0.05 });
          targets.forEach((el) => io.observe(el));
        };
        // Re-init on every Astro client-router navigation
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>
