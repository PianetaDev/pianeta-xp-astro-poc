---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const live = (e: any) => e.data.draft !== true;
const byDateDesc = (a: any, b: any) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
};

const recentWork = (await getCollection('work')).filter(live).sort(byDateDesc).slice(0, 4);
const recentBulletin = (await getCollection('bulletin')).filter(live).sort(byDateDesc).slice(0, 3);
---
<BaseLayout title="404 — Pianeta.Studio" description="Pagina non trovata">
  <section class="error404-page">
    <div class="error404-head">
      <p class="error404-kicker">404</p>
      <h1 class="error404-title">Pagina non trovata.</h1>
      <p class="error404-deck">Il link che hai seguito non esiste o è cambiato. Riprendi da qui:</p>
      <div class="error404-cta">
        <a href="/" class="cta-btn cta-primary">Hub →</a>
        <a href="/work" class="cta-btn cta-ghost">Vedi i lavori</a>
        <a href="/services" class="cta-btn cta-ghost">Vedi i servizi</a>
      </div>
    </div>

    {recentWork.length > 0 && (
      <section class="error404-section">
        <h2 class="error404-sec-title">Case study recenti</h2>
        <ul class="error404-list">
          {recentWork.map((w: any) => (
            <li>
              <a href={`/work/${w.id}`}>
                <span class="error404-list-title">{w.data.title}</span>
                {w.data.client && <span class="error404-list-meta">{w.data.client}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {recentBulletin.length > 0 && (
      <section class="error404-section">
        <h2 class="error404-sec-title">Articoli recenti</h2>
        <ul class="error404-list">
          {recentBulletin.map((b: any) => (
            <li>
              <a href={`/bulletin/${b.id}`}>
                <span class="error404-list-title">{b.data.title}</span>
                {b.data.description && <span class="error404-list-meta">{b.data.description}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>

  <style>
    .error404-page { max-width: 880px; margin: 0 auto; padding: 80px 32px 96px; }
    .error404-head { text-align: center; max-width: 640px; margin: 0 auto 64px; }
    .error404-kicker { font-size: var(--ty-eyebrow); text-transform: uppercase; letter-spacing: 2px; color: var(--cta-primary); font-weight: 700; margin: 0 0 16px; }
    .error404-title { font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900; letter-spacing: -0.02em; line-height: 1.05; margin: 0 0 16px; }
    .error404-deck { font-size: 1.05rem; color: var(--pianeta-muted); margin: 0 0 28px; }
    .error404-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .error404-section { margin-top: 48px; }
    .error404-sec-title { font-size: var(--ty-eyebrow); text-transform: uppercase; letter-spacing: 2px; color: var(--pianeta-muted); font-weight: 700; margin: 0 0 16px; }
    .error404-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .error404-list a { display: flex; flex-direction: column; gap: 4px; padding: 14px 16px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color 150ms; }
    .error404-list a:hover { border-color: var(--cta-primary); }
    .error404-list-title { font-size: 15px; font-weight: 700; }
    .error404-list-meta { font-size: 12px; color: var(--pianeta-muted); }
  </style>
</BaseLayout>
