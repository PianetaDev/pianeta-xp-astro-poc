---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../lib/next-item';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('services');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'services');
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;
const caseStudies: string[] = data.caseStudies || [];
const ctaLabel = data.pricing?.cta || 'Parla con Alba';

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Servizi', href: '/services' }];

const related = caseStudies.map((slug) => ({ type: 'work', slug }));

const metaInline = [
  data.team?.length && { label: 'Team', value: data.team.join(', ') },
  data.deliverables?.length && { label: 'Deliverables', value: data.deliverables.length + ' voci' },
  data.pricing?.label && { label: 'Pricing', value: data.pricing.label },
].filter(Boolean);

const url = new URL(`/services/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': url,
  name: title,
  description: data.description,
  url,
  image: data.ogImage || cover,
  serviceType: data.category || title,
  category: 'Design & Technology · Sustainable Creativity',
  provider: {
    '@type': 'Organization',
    name: 'Pianeta.Studio',
    legalName: 'PIANETA.STUDIO S.R.L. S.B.',
    taxID: 'IT06037730873',
    url: 'https://xp.pianeta.studio',
    sameAs: ['https://pianeta.studio', 'https://atlas.pianeta.green/atlas'],
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'info@pianeta.studio',
      contactType: 'sales',
      availableLanguage: ['it', 'en'],
    },
  },
  areaServed: { '@type': 'AdministrativeArea', name: 'Europa' },
  audience: { '@type': 'BusinessAudience', name: 'PMI, B-Corp, organizzazioni sostenibilità & food/agri' },
  ...(data.deliverables && Array.isArray(data.deliverables) && data.deliverables.length > 0 && {
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Deliverable inclusi',
      itemListElement: data.deliverables.map((d: string, i: number) => ({
        '@type': 'Offer',
        position: i + 1,
        itemOffered: { '@type': 'Service', name: d },
      })),
    },
  }),
  ...(caseStudies.length > 0 && {
    workExample: caseStudies.map((slug: string) => ({
      '@type': 'CreativeWork',
      url: new URL(`/work/${slug}`, Astro.site).toString(),
    })),
  }),
  potentialAction: {
    '@type': 'ContactAction',
    name: 'Lavoriamo insieme',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://xp.pianeta.studio/contact',
      actionPlatform: ['https://schema.org/DesktopWebPlatform', 'https://schema.org/MobileWebPlatform'],
    },
  },
};
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={{ label: 'Lavoriamo insieme', action: 'open-hire-us' }}
    secondaryCta={{ label: ctaLabel, action: 'open-alba' }}
    backHref="/services"
    backLabel="Tutti i servizi"
    related={related}
    relatedTitle="Case study"
    nextItem={nextItem}
    metaInline={metaInline}
    twoCol={(item.body?.length ?? 0) > 2400}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
