---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('services');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;
const caseStudies: string[] = data.caseStudies || [];
const ctaLabel = data.pricing?.cta || 'Parla con Alba';

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Servizi', href: '/services' }];

const related = caseStudies.map((slug) => ({ type: 'work', slug }));
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={{ label: ctaLabel, action: 'open-alba' }}
    secondaryCta={{ label: 'Lavoriamo insieme', action: 'open-hire-us' }}
    backHref="/services"
    backLabel="Tutti i servizi"
    related={related}
    relatedTitle="Case study"
  >
    <Fragment slot="meta">
      {data.deliverables && data.deliverables.length > 0 && (
        <div>
          <dt>Deliverables</dt>
          <dd>
            <ul style="margin:0;padding:0;list-style:none;">
              {data.deliverables.map((d: string) => <li style="padding:4px 0;border-bottom:1px solid rgba(14,17,22,0.06);">{d}</li>)}
            </ul>
          </dd>
        </div>
      )}
      {data.team && data.team.length > 0 && <div><dt>Team</dt><dd>{data.team.join(', ')}</dd></div>}
      {data.pricing?.label && <div><dt>Pricing</dt><dd>{data.pricing.label}</dd></div>}
    </Fragment>
    <Content />
  </DetailPage>
</BaseLayout>
