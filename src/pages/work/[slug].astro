---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../lib/next-item';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('work');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'work');
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;
const live = data.links?.live;
const bulletinRefs: string[] = data.links?.bulletin || [];

const url = new URL(`/work/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: data.description,
  url,
  image: data.ogImage || cover,
  dateCreated: data.date ? new Date(data.date).toISOString() : undefined,
  dateModified: data.updated ? new Date(data.updated).toISOString() : undefined,
  creator: { '@type': 'Organization', name: 'Pianeta.Studio', url: 'https://xp.pianeta.studio' },
  ...(data.client && { sourceOrganization: { '@type': 'Organization', name: data.client } }),
  ...(live && { sameAs: live }),
  keywords: (data.tags || []).join(', ') || undefined,
};
const eyebrowParts = [{ label: 'Work', href: '/work' }];
if (data.category) eyebrowParts.push({ label: data.category });
if (data.year) eyebrowParts.push({ label: String(data.year) });

const related = bulletinRefs.map((slug) => ({ type: 'bulletin', slug }));
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={live ? { label: 'Visita il sito', href: live, external: true } : undefined}
    secondaryCta={{ label: 'Lavoriamo insieme', action: 'open-hire-us' }}
    backHref="/work"
    backLabel="Tutti i lavori"
    related={related}
    nextItem={nextItem}
    jsonLd={jsonLd}
  >
    <Fragment slot="meta">
      {data.client && <div><dt>Cliente</dt><dd>{data.client}</dd></div>}
      {data.sector && <div><dt>Settore</dt><dd>{data.sector}</dd></div>}
      {data.year && <div><dt>Anno</dt><dd>{data.year}</dd></div>}
      {data.category && <div><dt>Categoria</dt><dd>{data.category}</dd></div>}
      {data.team && data.team.length > 0 && <div><dt>Team</dt><dd>{data.team.join(', ')}</dd></div>}
      {live && <div><dt>Live</dt><dd><a href={live} target="_blank" rel="noopener" class="meta-link">{new URL(live).hostname} ↗</a></dd></div>}
    </Fragment>
    <Content />
  </DetailPage>
</BaseLayout>
