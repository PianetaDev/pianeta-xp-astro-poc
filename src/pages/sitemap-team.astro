              <code class="sg-swatch-name">.hero-cta <em>(HireLanding · variante compatta 13/24)</em></code>
              <pre class="sg-code"><code>{'<a class="hero-cta">Vedi le offerte</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview" style="min-height: 96px; background: var(--soft); border-radius: 12px; padding: 20px; position: relative;">
                <span class="hub-hire-cta-static">Lavoriamo insieme</span>
                <span class="pi-meta-label" style="position:absolute; bottom: 8px; left: 12px;">Overlay: position fixed top-right, z-40</span>
              </div>
              <code class="sg-swatch-name">.hub-hire-cta <em>(fixed overlay · BaseLayout)</em></code>
              <pre class="sg-code"><code>{'<a href="/hire" class="hub-hire-cta">Lavoriamo insieme</a>'}</code></pre>
            </div>
          </div>
