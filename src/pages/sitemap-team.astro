          <div class="sg-btn-grid">
            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="cta-btn cta-primary">Lavoriamo insieme</a></div>
              <code class="sg-swatch-name">.cta-btn .cta-primary</code>
              <pre class="sg-code"><code>{'<a class="cta-btn cta-primary">Lavoriamo insieme</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="cta-btn cta-secondary">Scopri</a></div>
              <code class="sg-swatch-name">.cta-btn .cta-secondary</code>
              <pre class="sg-code"><code>{'<a class="cta-btn cta-secondary">Scopri</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
