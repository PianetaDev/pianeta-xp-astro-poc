  @media (min-width: 640px) { .sg-swatch-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1000px) { .sg-swatch-grid { grid-template-columns: repeat(4, 1fr); } }
  .sg-swatch { border: 1px solid var(--pianeta-border); border-radius: 14px; overflow: hidden; background: var(--pianeta-bg-card); display: flex; flex-direction: column; }
