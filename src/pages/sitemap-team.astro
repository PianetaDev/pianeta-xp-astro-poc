  @media (min-width: 800px) { .sg-typo-label { border-top: 0; padding-top: 0; border-left: 1px solid var(--pianeta-border); padding-left: 20px; } }
  .sg-typo-value { font-size: 11px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; color: var(--pianeta-muted); line-height: 1.5; }

  /* Radii / padding / wrap */
  .sg-radii-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (min-width: 700px) { .sg-radii-grid { grid-template-columns: repeat(4, 1fr); } }
  .sg-radii-item { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 14px; text-align: center; }
  .sg-radii-chip { width: 72px; height: 72px; background: var(--cta-primary); }

  .sg-pad-demo { display: flex; flex-direction: column; gap: 12px; }
  .sg-pad-outer { background: repeating-linear-gradient(45deg, rgba(255,107,51,.10) 0 4px, transparent 4px 12px); border-radius: var(--radius-card); padding: var(--pad-card); border: 1px dashed var(--cta-primary); }
  .sg-pad-inner { background: var(--pianeta-bg-card); border-radius: 10px; padding: 16px; }
  .sg-pad-text { font-size: var(--ty-meta); color: var(--pianeta-muted-strong); line-height: 1.5; margin: 6px 0 0; }
  .sg-pad-text code { background: var(--soft); padding: 1px 5px; border-radius: 4px; }

  .sg-wrap-demo { display: flex; flex-direction: column; gap: 12px; }
  .sg-wrap-box { max-width: var(--wrap-max); background: var(--soft); border: 1px dashed var(--pianeta-border-strong); border-radius: 12px; padding: 20px; text-align: center; }
  .sg-wrap-narrow-box { max-width: var(--wrap-narrow-max); }

  .sg-sec-demo { background: repeating-linear-gradient(0deg, rgba(255,107,51,.06) 0 4px, transparent 4px 12px); border-radius: 12px; padding: var(--sec-pad-y) 0; text-align: center; }
  .sg-sec-band { background: var(--pianeta-bg-card); padding: 20px; border-radius: 10px; margin: 0 20px; border: 1px solid var(--pianeta-border); }

