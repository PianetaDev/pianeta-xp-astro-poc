  .sg-btn-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
  @media (min-width: 700px) { .sg-btn-grid { grid-template-columns: 1fr 1fr; } }
  .sg-btn-cell { display: flex; flex-direction: column; gap: 10px; padding: 20px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 14px; }
  .sg-btn-preview { display: flex; align-items: center; justify-content: center; min-height: 80px; background: var(--soft); border-radius: 10px; padding: 20px; }

  .hub-hire-cta-static {
    display: inline-block;
    background: var(--cta-primary); color: var(--cta-primary-ink, #fff);
    font-weight: 600; font-size: 14px; padding: 9px 18px; border-radius: 999px;
    text-decoration: none; box-shadow: 0 6px 20px rgba(255,107,51,.30);
  }

  .sg-btn-cell .hero-cta { display: inline-block; background: var(--cta-primary); color: #fff; font-weight: 600; padding: 13px 24px; border-radius: 999px; text-decoration: none; font-size: 14px; }

  .sg-code { background: var(--band); color: #f5f4ee; padding: 12px 14px; border-radius: 10px; font-size: 12px; overflow-x: auto; margin: 0; line-height: 1.5; cursor: pointer; }
  .sg-code:hover { outline: 1px solid var(--cta-primary); }
  .sg-code[data-copied="true"] { outline: 2px solid var(--green); }
  .sg-code code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

  /* Cards */
  .sg-cards-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
  @media (min-width: 700px) { .sg-cards-grid { grid-template-columns: 1fr 1fr; } }
  .sg-card-cell { display: flex; flex-direction: column; gap: 10px; }

  .sg-method-card { background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 14px; padding: 18px; }
  .sg-method-n { font-size: 12px; font-weight: 800; color: var(--cta-primary); }
  .sg-method-card strong { display: block; margin: 6px 0; font-size: 15px; }
  .sg-method-card p { color: var(--pianeta-muted-strong); font-size: 13px; line-height: 1.5; margin: 0; }
  .sg-method-card code { background: var(--soft); padding: 1px 4px; border-radius: 3px; font-size: 12px; }

  .sg-offer-card { background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 18px; padding: 22px; display: flex; flex-direction: column; gap: 10px; }
  .sg-offer-price { font-size: 13px; color: var(--pianeta-muted); }
  .sg-offer-name { font-size: 19px; margin: 0; }
  .sg-offer-forwho { font-size: 13px; color: var(--pianeta-muted); }
  .sg-offer-bullets { list-style: none; display: grid; gap: 5px; font-size: 13px; padding: 0; margin: 0; }
  .sg-offer-link { font-weight: 600; font-size: 14px; }

  /* Overlays */
  .sg-overlay-list { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 700px) { .sg-overlay-list { grid-template-columns: 1fr 1fr; } }
  .sg-overlay-list h3 { margin: 0 0 8px; font-size: 15px; }
  .sg-overlay-list .pi-card { display: flex; flex-direction: column; gap: 10px; }

  /* Utility list */
  .sg-util-grid { display: grid; grid-template-columns: 1fr; gap: 8px; }
  @media (min-width: 700px) { .sg-util-grid { grid-template-columns: 1fr 1fr; } }
  .sg-util-row { display: grid; grid-template-columns: 160px 1fr; gap: 12px; align-items: baseline; padding: 10px 14px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 10px; }

  /* Dark table */
  .sg-dark-table { border: 1px solid var(--pianeta-border); border-radius: 14px; overflow: hidden; }
  .sg-dark-row { display: grid; grid-template-columns: 200px 1fr; gap: 20px; padding: 14px 20px; border-bottom: 1px solid var(--pianeta-border); font-size: 13px; line-height: 1.6; }
  .sg-dark-row:last-child { border-bottom: 0; }
  .sg-dark-head { background: var(--soft); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
  .sg-dark-row code { background: var(--soft); padding: 1px 5px; border-radius: 4px; font-size: 12px; }
</style>

<script is:inline>
  (() => {
    const init = () => {
      const root = document.documentElement;

      // 1) Risolvi valori CSS var per swatch + typo labels
      const resolve = (name) => {
        const raw = getComputedStyle(root).getPropertyValue(name).trim();
        return raw || '—';
      };

      const renderValues = () => {
        document.querySelectorAll('[data-var-value]').forEach((el) => {
          const name = el.getAttribute('data-var-value');
          el.textContent = resolve(name);
        });
        document.querySelectorAll('[data-typo-value]').forEach((el) => {
          const name = el.getAttribute('data-typo-value');
          const size = resolve(name);
          let extra = '';
          if (name === '--ty-hero') extra = ' · lh ' + resolve('--ty-hero-lh') + ' · tracking ' + resolve('--ty-hero-tracking');
          if (name === '--ty-sub') extra = ' · lh ' + resolve('--ty-sub-lh');
          if (name === '--ty-body') extra = ' · lh ' + resolve('--ty-body-lh');
          if (name === '--ty-h2-sec') extra = ' · tracking ' + resolve('--ty-h2-sec-tracking');
          if (name === '--ty-eyebrow') extra = ' · tracking ' + resolve('--ty-eyebrow-tracking');
          if (name === '--ty-quote') extra = ' · lh ' + resolve('--ty-quote-lh');
          el.textContent = size + extra;
        });
      };
      renderValues();

      // 2) Copy-to-clipboard sui valori CSS risolti
      document.querySelectorAll('[data-copy-var]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const name = btn.getAttribute('data-copy-var');
          const val = resolve(name);
          try {
            await navigator.clipboard.writeText(val);
            btn.setAttribute('data-copied', 'true');
            setTimeout(() => btn.removeAttribute('data-copied'), 1200);
          } catch (e) {}
        });
      });

      // 2b) Copy-to-clipboard sugli snippet <pre.sg-code>
      document.querySelectorAll('pre.sg-code').forEach((pre) => {
        pre.setAttribute('title', 'Click per copiare snippet');
        pre.addEventListener('click', async () => {
          const txt = pre.textContent || '';
          try {
            await navigator.clipboard.writeText(txt.trim());
            pre.setAttribute('data-copied', 'true');
            setTimeout(() => pre.removeAttribute('data-copied'), 1200);
          } catch (e) {}
        });
      });

      // 3) Theme switcher locale (chiave globale pianeta-theme)
      const KEY = 'pianeta-theme';
      const setTheme = (v) => {
        try { localStorage.setItem(KEY, v); } catch (e) {}
        root.setAttribute('data-theme', v);
        document.querySelectorAll('[data-theme-set]').forEach((b) => {
          b.setAttribute('data-active', b.getAttribute('data-theme-set') === v ? 'true' : 'false');
        });
        setTimeout(renderValues, 40);
      };
      document.querySelectorAll('[data-theme-set]').forEach((btn) => {
        btn.addEventListener('click', () => setTheme(btn.getAttribute('data-theme-set')));
      });
      const current = (() => { try { return localStorage.getItem(KEY) || root.getAttribute('data-theme') || 'auto'; } catch (e) { return 'auto'; } })();
      document.querySelectorAll('[data-theme-set]').forEach((b) => {
        b.setAttribute('data-active', b.getAttribute('data-theme-set') === current ? 'true' : 'false');
      });

      // 4) Anchor attivo su scroll (index sticky)
      const anchors = Array.from(document.querySelectorAll('[data-anchor]'));
      const targets = anchors.map((a) => document.getElementById(a.getAttribute('data-anchor'))).filter(Boolean);
      if ('IntersectionObserver' in window && targets.length) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const id = e.target.id;
              anchors.forEach((a) => a.setAttribute('data-current', a.getAttribute('data-anchor') === id ? 'true' : 'false'));
            }
          });
        }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
        targets.forEach((t) => io.observe(t));
      }
    };

    document.addEventListener('astro:page-load', init);
    // Fallback per primo load senza view transitions
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>
