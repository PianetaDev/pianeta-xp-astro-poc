---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// ============================================================
// TEAM HUB — pagina interna unica
// Unisce sitemap-team (mappa pagine/collezioni) + styleguide (design tokens)
// Auto-generata al build. noindex,nofollow. Non compare in nav.
// ============================================================

// -------- Sezione 1 — Pagine statiche (auto-scan filesystem al build) --------
const pageModules = import.meta.glob('/src/pages/**/*.astro');
const allPagePaths = Object.keys(pageModules).sort();

const isStatic = (p: string) =>
  !p.includes('/pages/api/') &&
  !p.includes('/pages/admin/') &&
  !p.includes('[') &&
  !p.endsWith('/404.astro');

const staticPaths = allPagePaths.filter(isStatic);

const pathToRoute = (p: string): string => {
  let r = p.replace('/src/pages', '').replace(/\.astro$/, '');
  r = r.replace(/\/index$/, '');
  return r === '' ? '/' : r;
};

const itPaths = staticPaths.filter((p) => !p.startsWith('/src/pages/en/'));
const enPaths = new Set(staticPaths.filter((p) => p.startsWith('/src/pages/en/')));

type Row = { route: string; it: boolean; en: boolean; internal: boolean };

// pagine "interne" — noindex, non in sitemap pubblico
const INTERNAL_ROUTES = new Set(['/styleguide', '/sitemap-team']);

const staticRows: Row[] = itPaths.map((itPath) => {
  const route = pathToRoute(itPath);
  const enTwinPath = itPath.replace('/src/pages/', '/src/pages/en/');
  return {
    route,
    it: true,
    en: enPaths.has(enTwinPath),
    internal: INTERNAL_ROUTES.has(route),
  };
});

const enTwinExpected = new Set(itPaths.map((p) => p.replace('/src/pages/', '/src/pages/en/')));
const orphanEn: Row[] = [...enPaths]
  .filter((p) => !enTwinExpected.has(p))
  .map((p) => ({
    route: pathToRoute(p),
    it: false,
    en: true,
    internal: false,
  }));

const allStaticRows = [...staticRows, ...orphanEn].sort((a, b) => a.route.localeCompare(b.route));

// -------- Sezione 2 — Collezioni dinamiche --------
type CollectionRow = {
  key: string;
  label: string;
  indexIt: string;
  indexEn: string | null;
  detailIt: string;
  detailEn: string | null;
  itCount: number;
  enCount: number;
  coverage: number;
};

async function coll(
  key: string,
  label: string,
  itName: string,
  enName: string | null,
): Promise<CollectionRow> {
  const it = await getCollection(itName as any);
  const en = enName ? await getCollection(enName as any) : [];
  const itCount = it.length;
  const enCount = en.length;
  return {
    key,
    label,
    indexIt: `/${key}`,
    indexEn: enName ? `/en/${key}` : null,
    detailIt: `/${key}/[slug]`,
    detailEn: enName ? `/en/${key}/[slug]` : null,
    itCount,
    enCount,
    coverage: itCount === 0 ? 0 : Math.round((enCount / itCount) * 100),
  };
}

const collectionRows: CollectionRow[] = [
  await coll('work', 'Work / case study', 'work', 'workEn'),
  await coll('bulletin', 'Bulletin (newsletter archivio)', 'bulletin', 'bulletinEn'),
  await coll('services', 'Services', 'services', 'servicesEn'),
  await coll('team', 'Team', 'team', 'teamEn'),
  await coll('lab', 'Lab (R&D)', 'lab', 'labEn'),
  await coll('careers', 'Careers', 'careers', 'careersEn'),
];

const hireRoutes = [
  { it: '/hire', en: '/en/hire', name: 'Index' },
  { it: '/hire/[offer]', en: '/en/hire/[offer]', name: 'Offer dettaglio (dinamica)' },
  { it: '/hire/fondazioni', en: '/en/hire/fondazioni', name: 'Fondazioni' },
  { it: '/hire/piattaforme', en: '/en/hire/piattaforme', name: 'Piattaforme' },
  { it: '/hire/metodo', en: '/en/hire/metodo', name: 'Metodo' },
  { it: '/hire/grazie', en: '/en/hire/grazie', name: 'Grazie' },
];

// -------- Sezione 3 — Markdown detail --------
type MdRow = { collection: string; slug: string; title: string; hasEn: boolean };

async function mdRows(itName: string, enName: string | null): Promise<MdRow[]> {
  const it = await getCollection(itName as any);
  const en = enName ? await getCollection(enName as any) : [];
  const enSlugs = new Set(en.map((e: any) => e.id.replace(/\.en$/, '')));
  return it.map((e: any) => ({
    collection: itName,
    slug: e.id,
    title: e.data?.title || e.id,
    hasEn: enSlugs.has(e.id),
  }));
}

const allMd: MdRow[] = [
  ...(await mdRows('work', 'workEn')),
  ...(await mdRows('bulletin', 'bulletinEn')),
  ...(await mdRows('services', 'servicesEn')),
  ...(await mdRows('team', 'teamEn')),
  ...(await mdRows('lab', 'labEn')),
  ...(await mdRows('careers', 'careersEn')),
].sort((a, b) =>
  a.collection === b.collection ? a.slug.localeCompare(b.slug) : a.collection.localeCompare(b.collection),
);

// -------- Sezione 4 — Gap noti (curati a mano) --------
const knownGaps: Array<{ area: string; issue: string; why: string }> = [
  {
    area: '/en/404',
    issue: '404 in inglese assente',
    why: 'Astro serve /404.astro (IT) come fallback per rotte EN inesistenti — accettabile ma non ottimale',
  },
  {
    area: 'Home /',
    issue: 'Bento tile giallo (t-yellow) con testo bianco',
    why: 'Contrast fail WCAG AA — non ricavabile via grep, richiede audit visivo',
  },
  {
    area: 'Alba popup/launcher',
    issue: 'Gradiente pastello hex hardcoded',
    why: 'Non risponde a data-theme, non è ricavabile da import.meta.glob — segnalato a mano',
  },
  {
    area: 'Team /team/[slug]',
    issue: 'Detail page esiste come fallback SEO',
    why: 'La main UX è overlay in /team — la detail page è solo per crawler e link diretti',
  },
];

// -------- Design tokens (dalla ex-styleguide) --------
const colorGroups: Array<{ label: string; tokens: Array<{ name: string; use: string }> }> = [
  {
    label: 'Brand / neutral',
    tokens: [
      { name: '--pianeta-text',           use: 'Body text' },
      { name: '--pianeta-bg',             use: 'Background pagina' },
      { name: '--pianeta-bg-card',        use: 'Surface card' },
      { name: '--pianeta-border',         use: 'Border card default' },
      { name: '--pianeta-border-strong',  use: 'Border card hover' },
      { name: '--pianeta-muted',          use: 'Testo secondario' },
      { name: '--pianeta-muted-strong',   use: 'Testo secondario forte' },
      { name: '--pianeta-accent',         use: 'Link / accento blu' },
      { name: '--pianeta-highlight',      use: 'Highlight giallo' },
    ],
  },
  {
    label: 'CTA',
    tokens: [
      { name: '--cta-primary',            use: 'CTA primary bg (arancio)' },
      { name: '--cta-primary-hover',      use: 'CTA primary hover' },
      { name: '--cta-primary-ink',        use: 'CTA primary testo' },
      { name: '--cta-secondary',          use: 'CTA secondary bg (blu)' },
      { name: '--cta-secondary-hover',    use: 'CTA secondary hover' },
      { name: '--cta-secondary-ink',      use: 'CTA secondary testo' },
    ],
  },
  {
    label: 'Sistema /hire',
    tokens: [
      { name: '--soft',    use: 'Sezione soft (band chiara)' },
      { name: '--band',    use: 'Band scura' },
      { name: '--green',   use: 'Accento green (Pianeta.Green)' },
    ],
  },
];

const typoSamples: Array<{ token: string; tag: string; text: string; note: string }> = [
  { token: '--ty-hero',      tag: 'h1', text: 'Sustainable Creativity dal 2016', note: 'H1 hero (index + detail + landing)' },
  { token: '--ty-h2-sec',    tag: 'h2', text: 'Cosa facciamo, in concreto',       note: 'H2 di sezione in-page' },
  { token: '--ty-h2-prose',  tag: 'h2', text: 'Un pezzo di articolo',              note: 'H2 dentro articoli' },
  { token: '--ty-h3-prose',  tag: 'h3', text: 'Un sotto-titolo',                   note: 'H3 prose' },
  { token: '--ty-sub',       tag: 'p',  text: 'Studio di design e tecnologia. Progetti Pianeta-centric, standard aperti, codice consegnato.', note: 'Deck / hero sub' },
  { token: '--ty-body',      tag: 'p',  text: 'Progettiamo prodotti digitali con vincoli tecnici verificabili: carbon budget, performance budget, accessibilità. Ogni riga di codice consegnata resta di chi la commissiona — niente lock-in, standard aperti, documentazione inclusa.', note: 'Copy longform' },
  { token: '--ty-eyebrow',   tag: 'p',  text: 'TEAM HUB · PIANETA',                note: 'Eyebrow uppercase' },
  { token: '--ty-meta',      tag: 'p',  text: '13px meta inline · usata nelle liste, chip, byline',  note: 'Meta inline / bullets' },
  { token: '--ty-quote',     tag: 'blockquote', text: '“Non causare danno, non prendere alcunché dai sistemi naturali, non sprecare nulla.”', note: 'Blockquote / citazione' },
];

const spatialTokens: Array<{ name: string; label: string }> = [
  { name: '--radius-card',    label: '18px · card standard' },
  { name: '--radius-card-sm', label: '14px · card small' },
  { name: '--radius-chip',    label: '12px · chip' },
  { name: '--radius-pill',    label: '999px · pill / CTA' },
];

const utilityClasses: Array<{ cls: string; desc: string }> = [
  { cls: '.pi-wrap',        desc: 'Container 1040px · padding-x 24' },
  { cls: '.pi-wrap-narrow', desc: 'Container 720px · padding-x 24' },
  { cls: '.pi-sec',         desc: 'Sezione con padding-y 64' },
  { cls: '.pi-sec-soft',    desc: 'Sezione + bg --soft' },
  { cls: '.pi-card',        desc: 'Surface card (radius 18, pad 22)' },
  { cls: '.pi-card--sm',    desc: 'Card small (radius 14, pad 18)' },
  { cls: '.pi-h1',          desc: 'Alias tipografico hero H1' },
  { cls: '.pi-h2',          desc: 'Alias tipografico H2 sezione' },
  { cls: '.pi-hero-sub',    desc: 'Deck sotto hero' },
  { cls: '.pi-eyebrow',     desc: 'Eyebrow uppercase' },
  { cls: '.pi-meta-label',  desc: 'Label meta 10px uppercase' },
  { cls: '.pi-meta-value',  desc: 'Valore meta 13px' },
];

// -------- Anchor index --------
const sections: Array<{ id: string; label: string }> = [
  { id: 'overview',     label: 'Overview' },
  { id: 'pages',        label: 'Pagine statiche' },
  { id: 'collections',  label: 'Sezioni dinamiche' },
  { id: 'markdown',     label: 'Contenuti markdown' },
  { id: 'gaps',         label: 'Gap noti' },
  { id: 'tokens',       label: 'Design tokens' },
  { id: 'colors',       label: '· Colors' },
  { id: 'typo',         label: '· Typography' },
  { id: 'radii',        label: '· Radii · Padding · Wrap' },
  { id: 'buttons',      label: '· Buttons / CTA' },
  { id: 'cards',        label: '· Cards' },
  { id: 'overlays',     label: '· Overlays & Chrome' },
  { id: 'utility',      label: '· Utility classes' },
  { id: 'dark',         label: '· Dark mode' },
  { id: 'meta',         label: 'Update meta' },
];

const now = new Date().toISOString();

const total = allStaticRows.length;
const bothCount = allStaticRows.filter((r) => r.it && r.en).length;
const itOnly = allStaticRows.filter((r) => r.it && !r.en && !r.internal).length;
const enOnly = allStaticRows.filter((r) => !r.it && r.en).length;
---

<BaseLayout
  title="Team Hub — Pianeta.Studio"
  description="Pagina interna: mappa sito + design tokens. Uso solo team."
  chrome={true}
  hideNewsletter={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  <div class="th-root">
    <!-- Hero + toolbar -->
    <header class="th-hero pi-wrap">
      <p class="pi-eyebrow">Interno · Team Pianeta</p>
      <h1 class="pi-h1">Team Hub</h1>
      <p class="pi-hero-sub">
        Pagina di lavoro del team. Unisce <strong>mappa del sito</strong> (auto-generata al build da
        <code>src/pages</code> + <code>src/content</code>) e <strong>design tokens</strong> (valori risolti live
        dal CSS). Non indicizzata, non in nav.
      </p>

      <div class="th-toolbar">
        <div class="th-theme">
          <span class="pi-meta-label">Tema locale</span>
          <div class="th-theme-btns" role="group" aria-label="Cambia tema">
            <button type="button" data-theme-set="light" class="th-theme-btn">Light</button>
            <button type="button" data-theme-set="auto"  class="th-theme-btn">Auto</button>
            <button type="button" data-theme-set="dark"  class="th-theme-btn">Dark</button>
          </div>
        </div>
        <p class="th-hint pi-meta-value">Click su qualsiasi valore <code>#hex</code> o snippet per copiarlo.</p>
      </div>
    </header>

    <div class="th-layout pi-wrap">
      <!-- Contenuto -->
      <div class="th-main">
        <!-- ========== OVERVIEW / STATS ========== -->
        <section id="overview" class="th-section">
          <h2 class="pi-h2">Overview</h2>
          <p class="th-lead">Snapshot volumi statici + copertura IT/EN.</p>

          <div class="stats">
            <div class="stat">
              <div class="stat-n">{total}</div>
              <div class="stat-l">Pagine statiche</div>
            </div>
            <div class="stat">
              <div class="stat-n">{bothCount}</div>
              <div class="stat-l">IT + EN</div>
            </div>
            <div class="stat">
              <div class="stat-n">{itOnly}</div>
              <div class="stat-l">Solo IT (EN mancante)</div>
            </div>
            <div class="stat">
              <div class="stat-n">{enOnly}</div>
              <div class="stat-l">Solo EN (orfane)</div>
            </div>
          </div>
        </section>

        <!-- ========== PAGINE STATICHE ========== -->
        <section id="pages" class="th-section">
          <h2 class="pi-h2">Pagine statiche IT/EN</h2>
          <p class="th-lead">
            Ogni riga è un <code>.astro</code> sotto <code>src/pages</code> (esclusi <code>api/</code>,
            <code>admin/</code>, dinamiche <code>[slug]</code>/<code>[offer]</code>, e <code>404</code>).
          </p>

          <div class="pi-card">
            <table class="tbl">
              <thead>
                <tr><th>Route</th><th class="c">IT</th><th class="c">EN</th><th>Note</th></tr>
              </thead>
              <tbody>
                {allStaticRows.map((r) => (
                  <tr>
                    <td><code>{r.route}</code></td>
                    <td class="c">{r.it ? <span class="ok">✓</span> : <span class="ko">×</span>}</td>
                    <td class="c">{r.en ? <span class="ok">✓</span> : <span class="ko">×</span>}</td>
                    <td class="meta">{r.internal ? 'interno (noindex)' : ''}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ========== COLLEZIONI ========== -->
        <section id="collections" class="th-section">
          <h2 class="pi-h2">Sezioni dinamiche (collezioni)</h2>
          <p class="th-lead">Index + detail template per ogni collezione. Coverage EN = <code>enCount / itCount</code>.</p>

          <div class="grid">
            {collectionRows.map((c) => (
              <div class="pi-card">
                <h3 class="h3">{c.label}</h3>
                <dl class="dl">
                  <dt>Index IT</dt><dd><code>{c.indexIt}</code></dd>
                  <dt>Index EN</dt><dd>{c.indexEn ? <code>{c.indexEn}</code> : <span class="ko">—</span>}</dd>
                  <dt>Detail IT</dt><dd><code>{c.detailIt}</code></dd>
                  <dt>Detail EN</dt><dd>{c.detailEn ? <code>{c.detailEn}</code> : <span class="ko">—</span>}</dd>
                  <dt>Contenuti IT</dt><dd>{c.itCount}</dd>
                  <dt>Contenuti EN</dt><dd>{c.enCount}</dd>
                  <dt>Coverage EN</dt>
                  <dd>
                    <div class="bar">
                      <div class="bar-fill" style={`width:${c.coverage}%`}></div>
                    </div>
                    <span class="meta">{c.coverage}%</span>
                  </dd>
                </dl>
              </div>
            ))}
          </div>

          <h3 class="h3" style="margin-top:32px">Hire (multi-pagina, non collezione)</h3>
          <div class="pi-card">
            <table class="tbl">
              <thead>
                <tr><th>Route IT</th><th>Route EN</th><th>Nome</th></tr>
              </thead>
              <tbody>
                {hireRoutes.map((h) => (
                  <tr>
                    <td><code>{h.it}</code></td>
                    <td><code>{h.en}</code></td>
                    <td class="meta">{h.name}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ========== MARKDOWN ========== -->
        <section id="markdown" class="th-section">
          <h2 class="pi-h2">Contenuti markdown</h2>
          <p class="th-lead">
            Un file per riga da <code>src/content/*/*.md</code>. Il flag EN verifica l'esistenza del sidecar
            <code>&lt;slug&gt;.en.md</code>.
          </p>

          <div class="pi-card">
            <table class="tbl">
              <thead>
                <tr><th>Collezione</th><th>Slug</th><th>Titolo</th><th class="c">EN</th></tr>
              </thead>
              <tbody>
                {allMd.map((r) => (
                  <tr>
                    <td class="meta">{r.collection}</td>
                    <td><code>{r.slug}</code></td>
                    <td>{r.title}</td>
                    <td class="c">{r.hasEn ? <span class="ok">✓</span> : <span class="ko">×</span>}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ========== GAP NOTI ========== -->
        <section id="gaps" class="th-section">
          <h2 class="pi-h2">Gap noti</h2>
          <p class="th-lead">
            Issue rilevate a mano durante audit UX/design: non derivabili da uno scan filesystem —
            elenco curato, da aggiornare quando si risolvono.
          </p>

          <div class="pi-card">
            <table class="tbl">
              <thead>
                <tr><th>Area</th><th>Issue</th><th>Perché non è auto-rilevato</th></tr>
              </thead>
              <tbody>
                {knownGaps.map((g) => (
                  <tr>
                    <td><code>{g.area}</code></td>
                    <td>{g.issue}</td>
                    <td class="meta">{g.why}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- ========== DESIGN TOKENS — cappello ========== -->
        <section id="tokens" class="th-section">
          <h2 class="pi-h2">Design tokens</h2>
          <p class="th-lead">
            Sistema di design di Pianeta.Studio — token, tipografia, componenti. Fonte: <code>/hire</code>.
            I valori qui sotto sono <strong>risolti live</strong> dal CSS: cambiando tema in cima alla
            pagina, si aggiornano.
          </p>
        </section>

        <!-- COLORS -->
        <section id="colors" class="th-section th-subsection">
          <h2 class="pi-h2">Colors</h2>
          <p class="th-lead">Ogni swatch mostra il valore risolto della variabile CSS. Il valore si aggiorna cambiando tema.</p>
          {colorGroups.map((g) => (
            <div class="sg-color-group">
              <h3 class="sg-h3">{g.label}</h3>
              <div class="sg-swatch-grid">
                {g.tokens.map((t) => (
                  <div class="sg-swatch" data-token={t.name}>
                    <div class="sg-swatch-chip" style={`background: var(${t.name});`}></div>
                    <div class="sg-swatch-meta">
                      <code class="sg-swatch-name">{t.name}</code>
                      <button type="button" class="sg-copy" data-copy-var={t.name} title="Copia valore risolto">
                        <span class="sg-swatch-value" data-var-value={t.name}>—</span>
                      </button>
                      <span class="sg-swatch-use pi-meta-label">{t.use}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>

        <!-- TYPOGRAPHY -->
        <section id="typo" class="th-section th-subsection">
          <h2 class="pi-h2">Typography</h2>
          <p class="th-lead">Scala unica, allineata a <code>/hire</code>. A destra: valore risolto (font-size · line-height · letter-spacing).</p>

          <div class="sg-typo-list">
            {typoSamples.map((s) => (
              <div class="sg-typo-row">
                <div class="sg-typo-sample">
                  {s.tag === 'h1' && <h1 style={`font-size: var(${s.token}); line-height: var(--ty-hero-lh); letter-spacing: var(--ty-hero-tracking); font-weight: 900; margin: 0;`}>{s.text}</h1>}
                  {s.tag === 'h2' && s.token === '--ty-h2-sec' && <h2 style={`font-size: var(${s.token}); line-height: 1.15; letter-spacing: var(--ty-h2-sec-tracking); font-weight: 800; margin: 0;`}>{s.text}</h2>}
                  {s.tag === 'h2' && s.token === '--ty-h2-prose' && <h2 style={`font-size: var(${s.token}); line-height: 1.2; letter-spacing: -0.01em; font-weight: 800; margin: 0;`}>{s.text}</h2>}
                  {s.tag === 'h3' && <h3 style={`font-size: var(${s.token}); line-height: 1.3; letter-spacing: -0.01em; font-weight: 700; margin: 0;`}>{s.text}</h3>}
                  {s.tag === 'p' && s.token === '--ty-sub' && <p style={`font-size: var(${s.token}); line-height: var(--ty-sub-lh); color: var(--pianeta-muted-strong); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-body' && <p style={`font-size: var(${s.token}); line-height: var(--ty-body-lh); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-eyebrow' && <p style={`font-size: var(${s.token}); text-transform: uppercase; letter-spacing: var(--ty-eyebrow-tracking); color: var(--pianeta-muted); font-weight: 600; margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-meta' && <p style={`font-size: var(${s.token}); color: var(--pianeta-muted-strong); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'blockquote' && <blockquote style={`font-size: var(${s.token}); line-height: var(--ty-quote-lh); margin: 0; padding-left: 16px; border-left: 3px solid var(--cta-primary);`}>{s.text}</blockquote>}
                </div>
                <div class="sg-typo-label">
                  <code class="sg-swatch-name">{s.token}</code>
                  <span class="pi-meta-label">{s.note}</span>
                  <span class="sg-typo-value" data-typo-value={s.token}>—</span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- RADII / PADDING / WRAP -->
        <section id="radii" class="th-section th-subsection">
          <h2 class="pi-h2">Radii · Padding · Wrap</h2>

          <h3 class="sg-h3">Radii</h3>
