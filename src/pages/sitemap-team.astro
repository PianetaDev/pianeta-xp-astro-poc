  .sg-copy { border: 0; background: transparent; padding: 0; text-align: left; cursor: pointer; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; color: var(--pianeta-muted-strong); font-size: 12px; }
  .sg-copy:hover { color: var(--cta-primary); }
