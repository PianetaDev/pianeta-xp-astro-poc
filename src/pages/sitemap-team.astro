  .sg-swatch-use { margin-top: 2px; }

  /* Typography */
  .sg-typo-list { display: flex; flex-direction: column; gap: 24px; }
  .sg-typo-row { display: grid; grid-template-columns: 1fr; gap: 12px; padding: 20px; background: var(--pianeta-bg-card); border: 1px solid var(--pianeta-border); border-radius: 14px; }
  @media (min-width: 800px) {
    .sg-typo-row { grid-template-columns: minmax(0, 1fr) 220px; align-items: start; gap: 24px; }
  }
  .sg-typo-sample { min-width: 0; }
