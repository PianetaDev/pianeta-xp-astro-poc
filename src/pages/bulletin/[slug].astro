---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../lib/next-item';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('bulletin');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'bulletin');
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;

const formatDate = (d?: Date) => d ? new Date(d).toLocaleDateString('it-IT', { day: '2-digit', month: 'long', year: 'numeric' }) : '';

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Bulletin', href: '/bulletin' }];
if (data.issue) eyebrowParts.push({ label: `#${data.issue}` });
if (data.date) eyebrowParts.push({ label: formatDate(data.date) });

const related = (data.relatedWork || []).map((slug: string) => ({ type: 'work', slug }));

const metaInline = [
  data.authors?.length && { label: 'Autori', value: data.authors.join(', ') },
  data.date && { label: 'Data', value: formatDate(data.date) },
  data.issue && { label: 'Numero', value: '#' + data.issue },
  data.tags?.length && { label: 'Tag', value: data.tags.join(' · ') },
].filter(Boolean);

const url = new URL(`/bulletin/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: data.description,
  image: data.ogImage || cover,
  url,
  datePublished: data.date ? new Date(data.date).toISOString() : undefined,
  author: (data.authors || ['Pianeta.Studio']).map((a: string) => ({ '@type': 'Person', name: a })),
  publisher: { '@type': 'Organization', name: 'Pianeta.Studio', logo: { '@type': 'ImageObject', url: 'https://xp.pianeta.studio/favicon.svg' } },
  keywords: (data.tags || []).join(', ') || undefined,
  mainEntityOfPage: url,
};
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    secondaryCta={{ label: 'Iscriviti al Bulletin', href: '/bulletin/iscrivimi' }}
    backHref="/bulletin"
    backLabel="Tutti gli articoli"
    related={related}
    relatedTitle="Case study collegati"
    nextItem={nextItem}
    byline={{ authors: data.authors, date: data.date ? formatDate(data.date) : undefined, meta: data.issue ? [`#${data.issue}`] : undefined }}
    metaInline={metaInline}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
