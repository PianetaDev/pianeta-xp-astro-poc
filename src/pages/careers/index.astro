---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexCard from '../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('careers');
const items = all.filter((i: any) => i.data.draft !== true);
---
<BaseLayout title="Careers — Pianeta.Studio" description="Posizioni aperte in Pianeta.Studio. Design, ricerca, sviluppo.">
  <div class="index-page">
    <header class="index-head">
      <p class="index-eyebrow">Pianeta.Studio</p>
      <h1 class="index-title">Careers</h1>
      <p class="index-deck">Cerchiamo persone curiose, con un'attenzione vera alle conseguenze del nostro lavoro.</p>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">Nessuna posizione attiva al momento. Scrivici comunque a <a href="mailto:people@pianeta.studio" class="meta-link" style="color:var(--cta-primary);">people@pianeta.studio</a> — leggiamo tutto.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard
            href={`/careers/${it.id}`}
            title={it.data.title || it.id}
            deck={it.data.description}
            kicker={[it.data.employmentType, it.data.location].filter(Boolean).join(' · ')}
            image={it.data.cover || it.data.ogImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
