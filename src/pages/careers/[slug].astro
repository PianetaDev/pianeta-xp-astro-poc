---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('careers');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;
const applyEmail = data.applyEmail || 'people@pianeta.studio';

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Careers', href: '/careers' }];
if (data.employmentType) eyebrowParts.push({ label: data.employmentType });
if (data.location) eyebrowParts.push({ label: data.location });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={{ label: 'Candidati', href: `mailto:${applyEmail}?subject=${encodeURIComponent('Candidatura — ' + title)}` }}
    backHref="/careers"
    backLabel="Tutte le posizioni"
  >
    <Fragment slot="meta">
      {data.employmentType && <div><dt>Contratto</dt><dd>{data.employmentType}</dd></div>}
      {data.location && <div><dt>Dove</dt><dd>{data.location}</dd></div>}
      {data.team && <div><dt>Team</dt><dd>{data.team}</dd></div>}
      {data.startDate && <div><dt>Inizio</dt><dd>{data.startDate}</dd></div>}
      <div><dt>Per candidarsi</dt><dd><a href={`mailto:${applyEmail}`} class="meta-link">{applyEmail}</a></dd></div>
    </Fragment>
    <Content />
  </DetailPage>
</BaseLayout>
