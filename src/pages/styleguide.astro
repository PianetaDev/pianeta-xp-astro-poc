  .sg-typo-sample { min-width: 0; }
  .sg-typo-label { display: flex; flex-direction: column; gap: 4px; padding-top: 4px; border-top: 1px solid var(--pianeta-border); padding-top: 12px; }
  @media (min-width: 800px) { .sg-typo-label { border-top: 0; padding-top: 0; border-left: 1px solid var(--pianeta-border); padding-left: 20px; } }
