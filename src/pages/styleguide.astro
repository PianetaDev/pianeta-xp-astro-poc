---
import BaseLayout from '../layouts/BaseLayout.astro';

// Ordered list of color tokens grouped by category — le fonti sono global.css + DESIGN_TOKENS.md
const colorGroups: Array<{ label: string; tokens: Array<{ name: string; use: string }> }> = [
  {
    label: 'Brand / neutral',
    tokens: [
      { name: '--pianeta-text',           use: 'Body text' },
      { name: '--pianeta-bg',             use: 'Background pagina' },
      { name: '--pianeta-bg-card',        use: 'Surface card' },
      { name: '--pianeta-border',         use: 'Border card default' },
      { name: '--pianeta-border-strong',  use: 'Border card hover' },
      { name: '--pianeta-muted',          use: 'Testo secondario' },
      { name: '--pianeta-muted-strong',   use: 'Testo secondario forte' },
      { name: '--pianeta-accent',         use: 'Link / accento blu' },
      { name: '--pianeta-highlight',      use: 'Highlight giallo' },
    ],
  },
  {
    label: 'CTA',
    tokens: [
      { name: '--cta-primary',            use: 'CTA primary bg (arancio)' },
      { name: '--cta-primary-hover',      use: 'CTA primary hover' },
      { name: '--cta-primary-ink',        use: 'CTA primary testo' },
      { name: '--cta-secondary',          use: 'CTA secondary bg (blu)' },
      { name: '--cta-secondary-hover',    use: 'CTA secondary hover' },
      { name: '--cta-secondary-ink',      use: 'CTA secondary testo' },
    ],
  },
  {
    label: 'Sistema /hire',
    tokens: [
      { name: '--soft',    use: 'Sezione soft (band chiara)' },
      { name: '--band',    use: 'Band scura' },
      { name: '--green',   use: 'Accento green (Pianeta.Green)' },
    ],
  },
];

const typoSamples: Array<{ token: string; tag: string; text: string; note: string }> = [
  { token: '--ty-hero',      tag: 'h1', text: 'Sustainable Creativity dal 2016', note: 'H1 hero (index + detail + landing)' },
  { token: '--ty-h2-sec',    tag: 'h2', text: 'Cosa facciamo, in concreto',       note: 'H2 di sezione in-page' },
  { token: '--ty-h2-prose',  tag: 'h2', text: 'Un pezzo di articolo',              note: 'H2 dentro articoli' },
  { token: '--ty-h3-prose',  tag: 'h3', text: 'Un sotto-titolo',                   note: 'H3 prose' },
  { token: '--ty-sub',       tag: 'p',  text: 'Studio di design e tecnologia. Progetti Pianeta-centric, standard aperti, codice consegnato.', note: 'Deck / hero sub' },
  { token: '--ty-body',      tag: 'p',  text: 'Progettiamo prodotti digitali con vincoli tecnici verificabili: carbon budget, performance budget, accessibilità. Ogni riga di codice consegnata resta di chi la commissiona — niente lock-in, standard aperti, documentazione inclusa.', note: 'Copy longform' },
  { token: '--ty-eyebrow',   tag: 'p',  text: 'STYLEGUIDE · PIANETA',              note: 'Eyebrow uppercase' },
  { token: '--ty-meta',      tag: 'p',  text: '13px meta inline · usata nelle liste, chip, byline',  note: 'Meta inline / bullets' },
  { token: '--ty-quote',     tag: 'blockquote', text: '“Non causare danno, non prendere alcunché dai sistemi naturali, non sprecare nulla.”', note: 'Blockquote / citazione' },
];

const spatialTokens: Array<{ name: string; label: string }> = [
  { name: '--radius-card',    label: '18px · card standard' },
  { name: '--radius-card-sm', label: '14px · card small' },
  { name: '--radius-chip',    label: '12px · chip' },
  { name: '--radius-pill',    label: '999px · pill / CTA' },
];

const utilityClasses: Array<{ cls: string; desc: string }> = [
  { cls: '.pi-wrap',        desc: 'Container 1040px · padding-x 24' },
  { cls: '.pi-wrap-narrow', desc: 'Container 720px · padding-x 24' },
  { cls: '.pi-sec',         desc: 'Sezione con padding-y 64' },
  { cls: '.pi-sec-soft',    desc: 'Sezione + bg --soft' },
  { cls: '.pi-card',        desc: 'Surface card (radius 18, pad 22)' },
  { cls: '.pi-card--sm',    desc: 'Card small (radius 14, pad 18)' },
  { cls: '.pi-h1',          desc: 'Alias tipografico hero H1' },
  { cls: '.pi-h2',          desc: 'Alias tipografico H2 sezione' },
  { cls: '.pi-hero-sub',    desc: 'Deck sotto hero' },
  { cls: '.pi-eyebrow',     desc: 'Eyebrow uppercase' },
  { cls: '.pi-meta-label',  desc: 'Label meta 10px uppercase' },
  { cls: '.pi-meta-value',  desc: 'Valore meta 13px' },
];

const sections: Array<{ id: string; label: string }> = [
  { id: 'colors',    label: 'Colors' },
  { id: 'typo',      label: 'Typography' },
  { id: 'radii',     label: 'Radii · Padding · Wrap' },
  { id: 'buttons',   label: 'Buttons / CTA' },
  { id: 'cards',     label: 'Cards' },
  { id: 'overlays',  label: 'Overlays & Chrome' },
  { id: 'utility',   label: 'Utility classes' },
  { id: 'dark',      label: 'Dark mode' },
];
---

<BaseLayout
  title="Styleguide — Pianeta.Studio"
  description="Sistema di design di Pianeta.Studio: token, tipografia, componenti. Fonte: /hire."
  chrome={true}
  hideNewsletter={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  <div class="sg-root">
    <!-- Hero -->
    <header class="sg-hero pi-wrap">
      <p class="pi-eyebrow">Styleguide · Interno</p>
      <h1 class="pi-h1">Styleguide</h1>
      <p class="pi-hero-sub">Sistema di design di Pianeta.Studio — token, tipografia, componenti. Fonte: <code>/hire</code>. Usato dal team per review, allineamento e onboarding.</p>

      <div class="sg-toolbar">
        <div class="sg-theme">
          <span class="pi-meta-label">Tema locale</span>
          <div class="sg-theme-btns" role="group" aria-label="Cambia tema">
            <button type="button" data-theme-set="light" class="sg-theme-btn">Light</button>
            <button type="button" data-theme-set="auto"  class="sg-theme-btn">Auto</button>
            <button type="button" data-theme-set="dark"  class="sg-theme-btn">Dark</button>
          </div>
        </div>
        <p class="sg-hint pi-meta-value">Click su qualsiasi valore <code>#hex</code> per copiarlo negli appunti.</p>
      </div>
    </header>

    <div class="sg-layout pi-wrap">
      <!-- Contenuto -->
      <div class="sg-main">
        <!-- 2. COLORS -->
        <section id="colors" class="sg-section">
          <h2 class="pi-h2">1. Colors</h2>
          <p class="sg-lead">Ogni swatch mostra il valore risolto della variabile CSS. Il valore si aggiorna cambiando tema.</p>
          {colorGroups.map((g) => (
            <div class="sg-color-group">
              <h3 class="sg-h3">{g.label}</h3>
              <div class="sg-swatch-grid">
                {g.tokens.map((t) => (
                  <div class="sg-swatch" data-token={t.name}>
                    <div class="sg-swatch-chip" style={`background: var(${t.name});`}></div>
                    <div class="sg-swatch-meta">
                      <code class="sg-swatch-name">{t.name}</code>
                      <button type="button" class="sg-copy" data-copy-var={t.name} title="Copia valore risolto">
                        <span class="sg-swatch-value" data-var-value={t.name}>—</span>
                      </button>
                      <span class="sg-swatch-use pi-meta-label">{t.use}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>

        <!-- 3. TYPOGRAPHY -->
        <section id="typo" class="sg-section">
          <h2 class="pi-h2">2. Typography</h2>
          <p class="sg-lead">Scala unica, allineata a <code>/hire</code>. A destra: valore risolto (font-size · line-height · letter-spacing).</p>

          <div class="sg-typo-list">
            {typoSamples.map((s) => (
              <div class="sg-typo-row">
                <div class="sg-typo-sample">
                  {s.tag === 'h1' && <h1 style={`font-size: var(${s.token}); line-height: var(--ty-hero-lh); letter-spacing: var(--ty-hero-tracking); font-weight: 900; margin: 0;`}>{s.text}</h1>}
                  {s.tag === 'h2' && s.token === '--ty-h2-sec' && <h2 style={`font-size: var(${s.token}); line-height: 1.15; letter-spacing: var(--ty-h2-sec-tracking); font-weight: 800; margin: 0;`}>{s.text}</h2>}
                  {s.tag === 'h2' && s.token === '--ty-h2-prose' && <h2 style={`font-size: var(${s.token}); line-height: 1.2; letter-spacing: -0.01em; font-weight: 800; margin: 0;`}>{s.text}</h2>}
                  {s.tag === 'h3' && <h3 style={`font-size: var(${s.token}); line-height: 1.3; letter-spacing: -0.01em; font-weight: 700; margin: 0;`}>{s.text}</h3>}
                  {s.tag === 'p' && s.token === '--ty-sub' && <p style={`font-size: var(${s.token}); line-height: var(--ty-sub-lh); color: var(--pianeta-muted-strong); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-body' && <p style={`font-size: var(${s.token}); line-height: var(--ty-body-lh); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-eyebrow' && <p style={`font-size: var(${s.token}); text-transform: uppercase; letter-spacing: var(--ty-eyebrow-tracking); color: var(--pianeta-muted); font-weight: 600; margin: 0;`}>{s.text}</p>}
                  {s.tag === 'p' && s.token === '--ty-meta' && <p style={`font-size: var(${s.token}); color: var(--pianeta-muted-strong); margin: 0;`}>{s.text}</p>}
                  {s.tag === 'blockquote' && <blockquote style={`font-size: var(${s.token}); line-height: var(--ty-quote-lh); margin: 0; padding-left: 16px; border-left: 3px solid var(--cta-primary);`}>{s.text}</blockquote>}
                </div>
                <div class="sg-typo-label">
                  <code class="sg-swatch-name">{s.token}</code>
                  <span class="pi-meta-label">{s.note}</span>
                  <span class="sg-typo-value" data-typo-value={s.token}>—</span>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- 4. RADII / PADDING / WRAPS -->
        <section id="radii" class="sg-section">
          <h2 class="pi-h2">3. Radii · Padding · Wrap</h2>

          <h3 class="sg-h3">Radii</h3>
          <div class="sg-radii-grid">
            {spatialTokens.map((r) => (
              <div class="sg-radii-item">
                <div class="sg-radii-chip" style={`border-radius: var(${r.name});`}></div>
                <code class="sg-swatch-name">{r.name}</code>
                <span class="pi-meta-label">{r.label}</span>
              </div>
            ))}
          </div>

          <h3 class="sg-h3">Padding card</h3>
          <div class="sg-pad-demo">
            <div class="sg-pad-outer">
              <div class="sg-pad-inner">
                <span class="pi-meta-label">Contenuto card</span>
                <p class="sg-pad-text">Padding <code>--pad-card</code> · 22px su tutti i lati. Radius <code>--radius-card</code> · 18px. Questa è la surface standard usata su tutte le pagine post-refactor.</p>
              </div>
            </div>
            <p class="pi-meta-label">Small: <code>--pad-card-sm</code> 18px · Large: <code>--pad-card-lg</code> 28px 32px</p>
          </div>

          <h3 class="sg-h3">Wrap</h3>
          <div class="sg-wrap-demo">
            <div class="sg-wrap-box"><span class="pi-meta-label">--wrap-max · 1040px</span></div>
            <div class="sg-wrap-box sg-wrap-narrow-box"><span class="pi-meta-label">--wrap-narrow-max · 720px</span></div>
          </div>

          <h3 class="sg-h3">Section padding</h3>
          <div class="sg-sec-demo">
            <div class="sg-sec-band">
              <span class="pi-meta-label">--sec-pad-y · 64px</span>
            </div>
          </div>
        </section>

        <!-- 5. BUTTONS -->
        <section id="buttons" class="sg-section">
          <h2 class="pi-h2">4. Buttons / CTA</h2>
          <p class="sg-lead">Sistema <code>.cta-btn</code> con 3 varianti + due varianti legacy da <code>/hire</code>. La CTA fissa <code>.hub-hire-cta</code> è mostrata statica qui.</p>

          <div class="sg-btn-grid">
            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="cta-btn cta-primary">Lavoriamo insieme</a></div>
              <code class="sg-swatch-name">.cta-btn .cta-primary</code>
              <pre class="sg-code"><code>{'<a class="cta-btn cta-primary">Lavoriamo insieme</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="cta-btn cta-secondary">Scopri</a></div>
              <code class="sg-swatch-name">.cta-btn .cta-secondary</code>
              <pre class="sg-code"><code>{'<a class="cta-btn cta-secondary">Scopri</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="cta-btn cta-ghost">Vedi tutto</a></div>
              <code class="sg-swatch-name">.cta-btn .cta-ghost</code>
              <pre class="sg-code"><code>{'<a class="cta-btn cta-ghost">Vedi tutto</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview"><a href="#" class="hero-cta">Vedi le offerte</a></div>
              <code class="sg-swatch-name">.hero-cta <em>(HireLanding · variante compatta 13/24)</em></code>
              <pre class="sg-code"><code>{'<a class="hero-cta">Vedi le offerte</a>'}</code></pre>
            </div>

            <div class="sg-btn-cell">
              <div class="sg-btn-preview" style="min-height: 96px; background: var(--soft); border-radius: 12px; padding: 20px; position: relative;">
                <span class="hub-hire-cta-static">Lavoriamo insieme</span>
                <span class="pi-meta-label" style="position:absolute; bottom: 8px; left: 12px;">Overlay: position fixed top-right, z-40</span>
              </div>
              <code class="sg-swatch-name">.hub-hire-cta <em>(fixed overlay · BaseLayout)</em></code>
              <pre class="sg-code"><code>{'<a href="/hire" class="hub-hire-cta">Lavoriamo insieme</a>'}</code></pre>
            </div>
          </div>
        </section>

        <!-- 6. CARDS -->
        <section id="cards" class="sg-section">
          <h2 class="pi-h2">5. Cards</h2>
          <p class="sg-lead">Surface e varianti — dal sistema unico.</p>

          <div class="sg-cards-grid">
            <div class="sg-card-cell">
              <div class="pi-card">
                <p class="pi-eyebrow">Card standard</p>
                <h3 style="font-size: var(--ty-h3-prose); margin: 8px 0;">Titolo esempio</h3>
                <p style="font-size: var(--ty-meta); color: var(--pianeta-muted-strong); margin: 0;">Radius 18 · pad 22 · bg card · border default.</p>
              </div>
              <code class="sg-swatch-name">.pi-card</code>
              <pre class="sg-code"><code>{'<div class="pi-card">...</div>'}</code></pre>
            </div>

            <div class="sg-card-cell">
              <div class="pi-card pi-card--sm">
                <p class="pi-eyebrow">Card small</p>
                <h3 style="font-size: var(--ty-h3-prose); margin: 8px 0;">Titolo esempio</h3>
                <p style="font-size: var(--ty-meta); color: var(--pianeta-muted-strong); margin: 0;">Radius 14 · pad 18.</p>
              </div>
              <code class="sg-swatch-name">.pi-card.pi-card--sm</code>
              <pre class="sg-code"><code>{'<div class="pi-card pi-card--sm">...</div>'}</code></pre>
            </div>

            <div class="sg-card-cell">
              <div class="sg-method-card">
                <span class="sg-method-n">01</span>
                <strong>Discovery</strong>
                <p>Il metodo di <code>/hire</code>: chip arancio in cima, titolo bold, descrizione muted.</p>
              </div>
              <code class="sg-swatch-name">.method-card (HireLanding)</code>
              <pre class="sg-code"><code>{'<div class="method-card"><span class="method-n">01</span>...</div>'}</code></pre>
            </div>

            <div class="sg-card-cell">
              <div class="sg-offer-card" style="border-top: 3px solid var(--cta-primary);">
                <div class="sg-offer-price">Da progetto</div>
                <h3 class="sg-offer-name">✳️ Foundation</h3>
                <p class="sg-offer-forwho">Per team che partono da zero.</p>
                <ul class="sg-offer-bullets"><li>✓ Design system</li><li>✓ Landing</li><li>✓ Delivery</li></ul>
                <span class="sg-offer-link" style="color: var(--cta-primary);">Scopri →</span>
              </div>
              <code class="sg-swatch-name">.offer-card (HireLanding)</code>
              <pre class="sg-code"><code>{'<a class="offer-card" style="border-top:3px solid …">...</a>'}</code></pre>
            </div>

            <div class="sg-card-cell">
              <div class="pi-card" style="border-left: 3px solid var(--cta-primary);">
                <blockquote style="font-size: var(--ty-quote); line-height: var(--ty-quote-lh); margin: 0;">
                  “Standard aperti. Codice consegnato.”
                </blockquote>
                <p style="font-size: var(--ty-meta); color: var(--pianeta-muted); margin: 12px 0 0;">— Manifesto Pianeta</p>
              </div>
              <code class="sg-swatch-name">Quote card (composita)</code>
              <pre class="sg-code"><code>{'<div class="pi-card"><blockquote>…</blockquote></div>'}</code></pre>
            </div>
          </div>
        </section>

        <!-- 7. OVERLAYS -->
        <section id="overlays" class="sg-section">
          <h2 class="pi-h2">6. Overlays & Chrome</h2>
          <p class="sg-lead">Elementi di chrome del sito — descrizione + snippet. Nessuna demo interattiva qui (per non rompere lo stato della styleguide).</p>

          <div class="sg-overlay-list">
            <article class="pi-card">
              <h3 class="sg-h3">SiteRail</h3>
              <p class="sg-lead">Rail laterale sinistro (60px), trasparente. Contiene logo Pianeta, eyebrow contestuale, theme switcher (Light/Auto/Dark), locale switcher IT/EN. Persiste su tutte le pagine con <code>chrome=true</code>.</p>
              <pre class="sg-code"><code>{'<SiteRail current={Astro.url.pathname} />'}</code></pre>
            </article>

            <article class="pi-card">
              <h3 class="sg-h3">Detail overlay (.work-ov-panel)</h3>
              <p class="sg-lead">Pannello laterale che scorre da destra su click da index pages (work, bulletin, services). Contiene detail-head + detail-hero + detail-body. Chiude con ESC o click fuori.</p>
              <pre class="sg-code"><code>{'<div class="work-ov-panel">…</div>'}</code></pre>
            </article>

            <article class="pi-card">
              <h3 class="sg-h3">Team overlay (.team-ov-panel)</h3>
              <p class="sg-lead">Variante del detail overlay per pagine team — con foto profilo, ruolo, bio breve, link a progetti.</p>
              <pre class="sg-code"><code>{'<div class="team-ov-panel">…</div>'}</code></pre>
            </article>

            <article class="pi-card">
              <h3 class="sg-h3">NewsletterPopup</h3>
              <p class="sg-lead">Popup proattivo con iscrizione alla Bulletin (audience Resend). Nascosto qui via <code>hideNewsletter=true</code>. Anche AlbaProactivePopup segue lo stesso flag.</p>
              <pre class="sg-code"><code>{'<BaseLayout hideNewsletter={true}>'}</code></pre>
            </article>
          </div>
        </section>

        <!-- 8. UTILITY CLASSES -->
        <section id="utility" class="sg-section">
          <h2 class="pi-h2">7. Utility classes</h2>
          <p class="sg-lead">Prefisso <code>.pi-*</code> — sistema unico condiviso da tutte le pagine.</p>
          <div class="sg-util-grid">
            {utilityClasses.map((u) => (
              <div class="sg-util-row">
                <code class="sg-swatch-name">{u.cls}</code>
                <span class="pi-meta-value">{u.desc}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- 9. DARK MODE -->
        <section id="dark" class="sg-section">
          <h2 class="pi-h2">8. Dark mode</h2>
          <p class="sg-lead">Attivata via <code>data-theme="dark"</code> (o <code>data-theme="auto"</code> + <code>data-sun="night"</code>). Testa qui col toggle in cima alla pagina.</p>

          <div class="sg-dark-table">
              <div class="sg-dark-row sg-dark-head">
                <span>Cosa cambia</span>
                <span>Come lo garantisci</span>
              </div>
              <div class="sg-dark-row">
                <span>Background surface</span>
                <span><code>--pianeta-bg-card</code> passa da <code>#ffffff</code> → <code>#1a1d23</code>. Usa <code>.pi-card</code> o <code>var(--pianeta-bg-card)</code>, mai <code>#fff</code> hard-coded.</span>
              </div>
              <div class="sg-dark-row">
                <span>Text</span>
                <span><code>--pianeta-text</code> passa da <code>#0e1116</code> → <code>#f5f4ee</code>. Non usare mai il valore hex diretto.</span>
              </div>
              <div class="sg-dark-row">
                <span>Muted</span>
                <span><code>--pianeta-muted</code> passa a <code>rgba(245,244,238,0.58)</code>. Le rgba <code>(14,17,22,.xx)</code> vanno tokenizzate.</span>
              </div>
              <div class="sg-dark-row">
                <span>Border</span>
                <span><code>--pianeta-border</code> flippa colore base (bianco su nero). Le border card lo usano già.</span>
              </div>
              <div class="sg-dark-row">
                <span>CTA secondary</span>
                <span><code>--cta-secondary</code> <code>#1f5b8f</code> → <code>#4a8fc4</code> (contrast preservato su bg scuro).</span>
              </div>
              <div class="sg-dark-row">
                <span>--soft</span>
                <span><code>#f3f2ea</code> → <code>#15181e</code>. Le sezioni <code>.pi-sec-soft</code> restano distinte dal background principale.</span>
              </div>
              <div class="sg-dark-row">
                <span>--band</span>
                <span>Resta <code>#14171c</code> in entrambi i temi (design intenzionale).</span>
              </div>
          </div>
        </section>
      </div>

      <!-- ANCHOR NAV -->
      <aside class="sg-aside">
        <p class="pi-eyebrow" style="margin-bottom: 12px;">Indice</p>
        <nav class="sg-anchors" aria-label="Indice sezioni">
          {sections.map((s, i) => (
            <a href={`#${s.id}`} data-anchor={s.id} class="sg-anchor">
              <span class="sg-anchor-num">{String(i + 1).padStart(2, '0')}</span>
              <span>{s.label}</span>
            </a>
          ))}
        </nav>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  /* Nascondi la CTA fissa "Lavoriamo insieme" solo su questa pagina */
  :global(.hub-hire-cta) { display: none !important; }

  .sg-root { padding-top: 40px; padding-bottom: 96px; }

  .sg-hero { text-align: left; padding-top: 32px; padding-bottom: 32px; }
