---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DetailPage from '../../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../../lib/next-item';
import { t } from '../../../lib/i18n/strings';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('teamEn');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'team');
if (nextItem) nextItem.type = 'en/team';
const { Content } = await render(item);
const data: any = item.data;
const title = data.name || data.title || item.id;
const cover = data.photo || data.cover || data.ogImage;

const url = new URL(`/en/team/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name || title,
  jobTitle: data.role,
  description: data.description,
  url,
  image: data.photo || cover,
  email: data.email,
  worksFor: { '@type': 'Organization', name: 'Pianeta.Studio', url: 'https://xp.pianeta.studio' },
};

const metaInline = [
  data.role && { label: 'Role', value: data.role },
  data.employment && { label: 'Type', value: data.employment },
  data.since && { label: 'Since', value: String(new Date(data.since).getFullYear()) },
  data.location && { label: 'Where', value: data.location },
  data.email && { label: 'Email', value: data.email, href: `mailto:${data.email}` },
].filter(Boolean);

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Team', href: '/en/team' }];
if (data.role) eyebrowParts.push({ label: data.role });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover} ogType="team" ogSlug={item.id}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    heroPortrait={true}
    primaryCta={data.email ? { label: 'Get in touch', href: `mailto:${data.email}`, external: false } : undefined}
    backHref="/en/team"
    backLabel="All team"
    nextItem={nextItem}
    byline={{ meta: [data.role, data.location].filter(Boolean) }}
    metaInline={metaInline}
    twoCol={(item.body?.length ?? 0) > 2400}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
