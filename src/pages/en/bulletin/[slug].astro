---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DetailPage from '../../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../../lib/next-item';
import { t } from '../../../lib/i18n/strings';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('bulletinEn');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'bulletin');
if (nextItem) nextItem.type = 'en/bulletin';
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;

const formatDate = (d?: Date) => d ? new Date(d).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }) : '';

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Bulletin', href: '/en/bulletin' }];
if (data.issue) eyebrowParts.push({ label: `#${data.issue}` });
if (data.date) eyebrowParts.push({ label: formatDate(data.date) });

const related = (data.relatedWork || []).map((slug: string) => ({ type: 'en/work', slug }));

const bodyLen = item.body?.length ?? 0;
const wordCount = Math.max(1, Math.round(bodyLen / 5.5));
const minutes = Math.max(1, Math.round(wordCount / 225));
const readingTime = data.readingTime || `${minutes} min`;

const metaInline = [
  data.authors?.length && { label: 'Authors', value: data.authors.join(', ') },
  data.date && { label: 'Date', value: formatDate(data.date) },
  { label: 'Read', value: readingTime },
  data.issue && { label: 'Issue', value: '#' + data.issue },
  data.tags?.length && { label: 'Tags', value: data.tags.join(' · ') },
].filter(Boolean);

const url = new URL(`/en/bulletin/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: data.description,
  image: data.ogImage || cover,
  url,
  datePublished: data.date ? new Date(data.date).toISOString() : undefined,
  author: (data.authors || ['Pianeta.Studio']).map((a: string) => ({ '@type': 'Person', name: a })),
  publisher: { '@type': 'Organization', name: 'Pianeta.Studio', logo: { '@type': 'ImageObject', url: 'https://xp.pianeta.studio/favicon.svg' } },
  keywords: (data.tags || []).join(', ') || undefined,
  mainEntityOfPage: url,
  inLanguage: 'en',
};
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover} ogType="bulletin" ogSlug={item.id}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    secondaryCta={{ label: 'Subscribe to the Bulletin', href: '/bulletin/iscrivimi' }}
    backHref="/en/bulletin"
    backLabel="All articles"
    related={related}
    relatedTitle="Related case studies"
    nextItem={nextItem}
    byline={{ authors: data.authors, date: data.date ? formatDate(data.date) : undefined, meta: data.issue ? [`#${data.issue}`] : undefined }}
    metaInline={metaInline}
    twoCol={(item.body?.length ?? 0) > 2400}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
