---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import IndexCard from '../../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../lib/i18n/strings';

const all = await getCollection('bulletinEn');
const items = all
  .filter((i: any) => i.data.draft !== true)
  .sort((a: any, b: any) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });
const fmt = (d?: Date) => d ? new Date(d).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : '';
---
<BaseLayout title="Bulletin — Pianeta.Studio" description="Articles, real cases, research. 1-2 per month from Pianeta.Studio.">
  <div class="index-page">
    <header class="index-head">      <h1 class="index-title">Bulletin</h1>
      <p class="index-deck">Articles, real cases, research. 1-2 per month.</p>
      <div style="margin-top:24px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/bulletin/iscrivimi" class="cta-btn cta-primary">Subscribe</a>
        <a href="/bulletin/preferenze" class="cta-btn cta-ghost">Preferences</a>
      </div>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">No articles published.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard
            href={`/en/bulletin/${it.id}`}
            title={it.data.title || it.id}
            deck={it.data.description}
            kicker={fmt(it.data.date)}
            image={it.data.cover || it.data.ogImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
