---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import IndexCard from '../../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../lib/i18n/strings';

const all = await getCollection('workEn');
const items = all
  .filter((i: any) => i.data.draft !== true)
  .sort((a: any, b: any) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });
---
<BaseLayout title="Work — Pianeta.Studio" description="Recent work by Pianeta.Studio: campaigns, digital products, design systems.">
  <div class="index-page">
    <header class="index-head">      <h1 class="index-title">Work</h1>
      <p class="index-deck">Recent projects: from strategy to code. Every job is co-design + AI validation + open standards.</p>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">No published work.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard
            href={`/en/work/${it.id}`}
            title={it.data.title || it.id}
            deck={it.data.description}
            kicker={[it.data.client, it.data.year].filter(Boolean).join(' · ')}
            image={it.data.cover || it.data.ogImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
