---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DetailPage from '../../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../../lib/next-item';
import { t } from '../../../lib/i18n/strings';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('lab');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'lab');
if (nextItem) nextItem.type = 'en/lab';
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;

const metaInline = [
  data.kind && { label: 'Type', value: data.kind },
  data.year && { label: 'Year', value: String(data.year) },
  data.status && { label: 'Status', value: data.status },
  data.tags?.length && { label: 'Tags', value: data.tags.join(' · ') },
].filter(Boolean);

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Lab', href: '/en/lab' }];
if (data.kind) eyebrowParts.push({ label: data.kind });
if (data.year) eyebrowParts.push({ label: String(data.year) });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover} ogType="lab" ogSlug={item.id}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={data.links?.external ? { label: 'Open ' + (data.title || 'project') + ' ↗', href: data.links.external, external: true } : undefined}
    secondaryCta={{ label: t('en', 'cta_lavoriamo'), action: 'open-hire-us' }}
    backHref="/en/lab"
    backLabel="All experiments"
    nextItem={nextItem}
    metaInline={metaInline}
    twoCol={(item.body?.length ?? 0) > 2400}
    fallbackBanner={t('en', 'fallback_banner')}
  >
    <Content />
  </DetailPage>
</BaseLayout>
