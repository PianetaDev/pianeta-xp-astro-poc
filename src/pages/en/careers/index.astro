---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import IndexCard from '../../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../lib/i18n/strings';

const all = await getCollection('careers');
const items = all.filter((i: any) => i.data.draft !== true);
---
<BaseLayout title="Careers — Pianeta.Studio" description="Open positions at Pianeta.Studio. Design, research, development.">
  <div class="index-page">
    <div class="detail-fallback-banner" role="status" style="max-width:1100px;margin:16px auto 0;padding:10px 16px;background:rgba(255,107,51,0.10);border:1px solid rgba(255,107,51,0.25);border-radius:8px;font-size:13px;line-height:1.4;">
      {t('en', 'fallback_banner')}
    </div>
    <header class="index-head">
      <p class="index-eyebrow">Pianeta.Studio</p>
      <h1 class="index-title">Careers</h1>
      <p class="index-deck">We look for curious people who care about the consequences of our work.</p>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">No open positions right now. Write us at <a href="mailto:people@pianeta.studio" class="meta-link" style="color:var(--cta-primary);">people@pianeta.studio</a> — we read everything.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard href={`/en/careers/${it.id}`} title={it.data.title || it.id} deck={it.data.description} kicker={[it.data.employmentType, it.data.location].filter(Boolean).join(' · ')} image={it.data.cover || it.data.ogImage} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
