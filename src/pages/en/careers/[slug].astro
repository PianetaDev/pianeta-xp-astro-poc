---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DetailPage from '../../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../../lib/next-item';
import { t } from '../../../lib/i18n/strings';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('careersEn');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'careers');
if (nextItem) nextItem.type = 'en/careers';
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;
const applyEmail = data.applyEmail || 'people@pianeta.studio';

const url = new URL(`/en/careers/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title,
  description: data.description,
  url,
  datePosted: data.date ? new Date(data.date).toISOString() : new Date().toISOString(),
  validThrough: data.validThrough,
  employmentType: data.employmentType,
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Pianeta.Studio',
    sameAs: 'https://xp.pianeta.studio',
    logo: 'https://xp.pianeta.studio/favicon.svg',
  },
  jobLocation: data.location ? {
    '@type': 'Place',
    address: { '@type': 'PostalAddress', addressLocality: data.location, addressCountry: 'IT' },
  } : undefined,
  applicantLocationRequirements: { '@type': 'Country', name: 'IT' },
  applicationContact: { '@type': 'ContactPoint', email: applyEmail },
  industry: 'Design & Technology',
};

const metaInline = [
  data.employmentType && { label: 'Contract', value: data.employmentType },
  data.location && { label: 'Where', value: data.location },
  data.team && { label: 'Team', value: data.team },
  data.startDate && { label: 'Start', value: data.startDate },
  { label: 'Apply', value: applyEmail, href: `mailto:${applyEmail}` },
].filter(Boolean);

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Careers', href: '/en/careers' }];
if (data.employmentType) eyebrowParts.push({ label: data.employmentType });
if (data.location) eyebrowParts.push({ label: data.location });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover} ogType="careers" ogSlug={item.id}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={{ label: 'Apply', href: `mailto:${applyEmail}?subject=${encodeURIComponent('Application — ' + title)}` }}
    backHref="/en/careers"
    backLabel="All positions"
    nextItem={nextItem}
    metaInline={metaInline}
    twoCol={(item.body?.length ?? 0) > 2400}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
