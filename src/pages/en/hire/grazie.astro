---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { offerBySlug } from '../../../data/offers';
const offer = offerBySlug(Astro.url.searchParams.get('offer') ?? '', 'en');
---
<BaseLayout title="Thank you — Pianeta.Studio" hideNewsletter>
  <div class="hire-page" style="--mut:var(--pianeta-muted);--acc:var(--cta-primary)">
  <main class="wrap" style="max-width:620px;margin:0 auto;text-align:center;padding:80px 24px 72px">
    <div style="font-size:40px">✅</div>
    <h1 style="font-size:30px;margin:12px 0">Thank you!</h1>
    <p style="color:var(--mut);font-size:17px;line-height:1.6">
      {offer ? `Purchase started for ${offer.name}.` : 'Purchase received.'} We’ll be in touch shortly to get going — check your inbox.
    </p>
    <p style="margin-top:28px"><a href="/en/hire" style="color:var(--acc)">← Back to offers</a></p>
  </main>
  </div>
  <script is:inline>
    (() => {
      const ck = (n) => (document.cookie.match('(^|;)\\s*' + n + '\\s*=\\s*([^;]+)') || [])[2] || '';
      const params = new URLSearchParams(location.search);
      const o = params.get('offer') || '';
      const sid = params.get('sid') || '';
      (window.dataLayer = window.dataLayer || []).push({ event: 'hire_purchase', offer: o });
      // Google Ads "Purchase" conversion
      try { window.gtag && window.gtag('event', 'conversion', { send_to: 'AW-16699800788/kKaVCPqxq8gcENT5ips-', transaction_id: sid }); } catch (e) { /* noop */ }
      const body = JSON.stringify({ event: 'hire_purchase', offer: o, gclid: decodeURIComponent(ck('gclid') || ''), page: location.pathname });
      try { if (navigator.sendBeacon) navigator.sendBeacon('/api/track', new Blob([body], { type: 'application/json' })); else fetch('/api/track', { method: 'POST', headers: { 'content-type': 'application/json' }, body, keepalive: true }); } catch (e) { /* noop */ }
    })();
  </script>
</BaseLayout>
