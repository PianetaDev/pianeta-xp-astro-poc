---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../lib/i18n/strings';
---
<BaseLayout title="Pianeta.Studio — Sustainable Creativity" description="Pianeta.Studio — Design & Technology for a Human to Planet world.">
  <div class="index-page">
    <header class="index-head">
      <p class="index-eyebrow">Pianeta.Studio</p>
      <h1 class="index-title">Sustainable Creativity</h1>
      <p class="index-deck">Design & Technology — Human to Planet. We turn briefs into opportunities through co-design, AI validation and UX validation.</p>
      <p style="margin-top: 32px;">
        <a href="/en/work" class="cta-btn cta-primary">Explore our work</a>
        <a href="/en/services" class="cta-btn cta-secondary" style="margin-left: 12px;">{t('en', 'cta_come_lavoriamo')}</a>
      </p>
    </header>
  </div>
</BaseLayout>
