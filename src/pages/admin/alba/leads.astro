---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { albaSupabase } from '../../../lib/server/alba/supabase';

export const prerender = false;

const key = Astro.url.searchParams.get('key');
const expected = process.env.NARRATOR_SECRET || '';
const authed = !!(expected && key === expected);

interface LeadRow {
  id: string;
  uid: string;
  session_id: string;
  ts: string;
  event: string;
  payload: Record<string, any>;
  user_email: string | null;
  user_name: string | null;
}

let leads: LeadRow[] = [];
let fetchError: string | null = null;
let totalCount = 0;

if (authed) {
  try {
    const sb = albaSupabase();

    // Fetch lead events (call_booked + handoff_to_max), defensive — handle missing table gracefully
    const { data: events, error: evErr, count } = await sb
      .from('alba_events')
      .select('id, uid, session_id, ts, event, payload', { count: 'exact' })
      .in('event', ['call_booked', 'handoff_to_max'])
      .order('ts', { ascending: false })
      .limit(200);

    if (evErr) {
      // Table may not exist yet — surface gracefully instead of crashing
      fetchError = `alba_events: ${evErr.message}`;
    } else if (events && events.length > 0) {
      totalCount = count ?? events.length;

      // Fetch user info for involved uids
      const uids = [...new Set(events.map((e: any) => e.uid as string))];
      const { data: users } = await sb
        .from('alba_users')
        .select('uid, email, first_name')
        .in('uid', uids);

      const userMap = new Map<string, any>((users ?? []).map((u: any) => [u.uid, u]));

      leads = (events as any[]).map((e) => {
        const user = userMap.get(e.uid);
        // email may be on the user row OR embedded in event payload (book_call saves it)
        const email: string | null =
          user?.email ?? e.payload?.user_email ?? e.payload?.email ?? null;
        return {
          id: e.id,
          uid: e.uid,
          session_id: e.session_id,
          ts: e.ts,
          event: e.event,
          payload: e.payload ?? {},
          user_email: email,
          user_name: user?.first_name ?? null,
        };
      });
    }
  } catch (err: any) {
    fetchError = err?.message ?? 'Errore sconosciuto';
  }
}

const eventBadge = (ev: string) =>
  ev === 'call_booked'
    ? { label: 'Chiamata', color: '#1a8a3a', bg: '#e6f4ec' }
    : ev === 'handoff_to_max'
    ? { label: 'Handoff', color: '#0e1116', bg: '#f0f0f2' }
    : { label: ev, color: '#555', bg: '#f5f5f5' };

const detailSnippet = (lead: LeadRow): string => {
  if (lead.event === 'call_booked') {
    const topic = lead.payload?.topic ?? '';
    const slot = lead.payload?.slot ?? lead.payload?.window ?? '';
    return [topic, slot ? `(${slot})` : ''].filter(Boolean).join(' ').slice(0, 100);
  }
  if (lead.event === 'handoff_to_max') {
    const summary = lead.payload?.summary ?? '';
    const reason = lead.payload?.reason ?? '';
    return [reason, summary].filter(Boolean).join(' — ').slice(0, 100);
  }
  return '';
};

const urgencyLabel = (lead: LeadRow) => {
  if (lead.event !== 'handoff_to_max') return null;
  return lead.payload?.urgency ?? 'normal';
};
---

<BaseLayout title="Admin · Alba · Lead" description="Lista lead Alba" minimal={true} chrome={false}>
  {!authed ? (
    <main style="padding:64px 32px; max-width:560px; margin:0 auto; font-family: Inter, system-ui;">
      <h1>Admin Alba · Lead</h1>
      <p style="color:rgba(14,17,22,0.6);">Aggiungi <code>?key=&lt;NARRATOR_SECRET&gt;</code> in URL per accedere.</p>
    </main>
  ) : (
    <main style="padding:32px; max-width:1300px; margin:0 auto; font-family: Inter, system-ui;">

      {/* Header + nav */}
      <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:32px; gap:16px; flex-wrap:wrap;">
        <div>
          <p style="margin:0 0 4px; font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.4);">Admin · Alba</p>
          <h1 style="margin:0 0 6px; font-size:28px; font-weight:900;">Lead</h1>
          <p style="margin:0; font-size:13px; color:rgba(14,17,22,0.5);">
            {totalCount > 0 ? `${totalCount} lead totali (ultimi 200 mostrati)` : 'Nessun lead ancora.'}
            &nbsp;·&nbsp;Aggiornato al {new Date().toLocaleString('it-IT', { dateStyle: 'long', timeStyle: 'short' })}
          </p>
        </div>
        <a
          href={`/admin/alba?key=${key}`}
          style="display:inline-block; padding:8px 16px; font-size:13px; font-weight:600; border:1px solid rgba(14,17,22,0.2); border-radius:8px; text-decoration:none; color:#0e1116; background:#fff;"
        >
          ← Dashboard Alba
        </a>
      </div>

      {/* KPI row */}
      {leads.length > 0 && (
        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:16px; margin-bottom:32px;">
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Totale lead</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">{totalCount}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Chiamate prenotate</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1; color:#1a8a3a;">{leads.filter(l => l.event === 'call_booked').length}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Handoff a Max</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">{leads.filter(l => l.event === 'handoff_to_max').length}</p>
          </div>
        </div>
      )}

      {/* Error state */}
      {fetchError && (
        <div style="padding:16px 20px; background:#fff3cd; border:1px solid #ffc107; border-radius:8px; margin-bottom:24px; font-size:13px; color:#856404;">
          <strong>Errore nel caricare i lead:</strong> {fetchError}
        </div>
      )}

      {/* Empty state */}
      {!fetchError && leads.length === 0 && (
        <div style="padding:40px; background:#fff; border:1px solid #e5e7eb; border-radius:12px; text-align:center; color:rgba(14,17,22,0.4); font-size:14px;">
          Nessun lead ancora. Le chiamate prenotate e gli handoff a Max appariranno qui.
        </div>
      )}

      {/* Leads table */}
      {leads.length > 0 && (
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
          <table style="width:100%; border-collapse:collapse; font-size:13px;">
            <thead>
              <tr style="background:rgba(14,17,22,0.04);">
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Data</th>
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Nome</th>
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Email</th>
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Tipo</th>
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Dettagli</th>
                <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Urgenza</th>
              </tr>
            </thead>
            <tbody>
              {leads.map((lead) => {
                const badge = eventBadge(lead.event);
                const detail = detailSnippet(lead);
                const urgency = urgencyLabel(lead);
                return (
                  <tr style="border-top:1px solid #e5e7eb;">
                    <td style="padding:10px 16px; white-space:nowrap; color:var(--pianeta-muted-strong);">
                      {new Date(lead.ts).toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' })}
                    </td>
                    <td style="padding:10px 16px; font-weight:600;">
                      {lead.user_name ?? <span style="color:rgba(14,17,22,0.35);">—</span>}
                    </td>
                    <td style="padding:10px 16px; font-family:ui-monospace,'Cascadia Code',monospace; font-size:12px;">
                      {lead.user_email
                        ? <a href={`mailto:${lead.user_email}`} style="color:#0e1116; text-decoration:none;">{lead.user_email}</a>
                        : <span style="color:rgba(14,17,22,0.35);">—</span>
                      }
                    </td>
                    <td style="padding:10px 16px;">
                      <span style={`display:inline-block; padding:2px 10px; border-radius:100px; font-size:11px; font-weight:600; background:${badge.bg}; color:${badge.color};`}>
                        {badge.label}
                      </span>
                    </td>
                    <td style="padding:10px 16px; color:var(--pianeta-muted-strong); max-width:320px;">
                      {detail
                        ? <span title={detail}>{detail.length > 80 ? detail.slice(0, 80) + '…' : detail}</span>
                        : <span style="color:rgba(14,17,22,0.3);">—</span>
                      }
                    </td>
                    <td style="padding:10px 16px;">
                      {urgency === 'high'
                        ? <span style="font-weight:700; color:#cc0000;">Alta</span>
                        : urgency === 'normal'
                        ? <span style="color:rgba(14,17,22,0.5);">Normale</span>
                        : urgency === 'low'
                        ? <span style="color:rgba(14,17,22,0.35);">Bassa</span>
                        : <span style="color:rgba(14,17,22,0.3);">—</span>
                      }
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}

      {/* Note schema */}
      <p style="margin-top:20px; font-size:11px; color:rgba(14,17,22,0.35);">
        Fonte: <code>alba_events</code> (event = call_booked | handoff_to_max) + <code>alba_users</code> (email, nome).
        Azienda non ancora raccolta da Alba — da aggiungere al tool <code>book_call</code> se necessario.
      </p>
    </main>
  )}
</BaseLayout>
