---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { albaSupabase } from '../../../lib/server/alba/supabase';
import { LIMITS } from '../../../lib/server/alba/rate-limit';

export const prerender = false;

const key = Astro.url.searchParams.get('key');
const expected = process.env.NARRATOR_SECRET || '';
const authed = !!(expected && key === expected);

interface SessionRow {
  id: string;
  uid: string;
  started_at: string;
  page_origin: string | null;
  msg_count: number;
  tokens_in: number | null;
  tokens_out: number | null;
  cost_eur: number | null;
}

interface DailyCostRow {
  date: string;
  total_eur: number;
}

let totalCostEur = 0;
let totalTokensIn = 0;
let totalTokensOut = 0;
let totalSessions = 0;
let dailyCosts: DailyCostRow[] = [];
let topSessions: SessionRow[] = [];
let todayCost = 0;
let fetchError: string | null = null;

const CAP_EUR = LIMITS.costEurPerDay;

if (authed) {
  try {
    const sb = albaSupabase();
    const since30 = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
    const todayStr = new Date().toISOString().slice(0, 10);

    // 1. Aggregate totals from alba_sessions (all time)
    const { data: allSessions, error: sessErr } = await sb
      .from('alba_sessions')
      .select('id, uid, started_at, page_origin, msg_count, tokens_in, tokens_out, cost_eur');

    if (sessErr) {
      fetchError = `alba_sessions: ${sessErr.message}`;
    } else {
      const rows = (allSessions ?? []) as SessionRow[];
      totalSessions = rows.length;
      totalCostEur = rows.reduce((s, r) => s + (Number(r.cost_eur) || 0), 0);
      totalTokensIn = rows.reduce((s, r) => s + (Number(r.tokens_in) || 0), 0);
      totalTokensOut = rows.reduce((s, r) => s + (Number(r.tokens_out) || 0), 0);
    }

    // 2. Daily costs last 30 days from alba_daily_costs
    const { data: dc, error: dcErr } = await sb
      .from('alba_daily_costs')
      .select('date, total_eur')
      .gte('date', since30)
      .order('date', { ascending: false });

    if (dcErr) {
      // Non-fatal: table may not exist
      if (!fetchError) fetchError = `alba_daily_costs: ${dcErr.message}`;
    } else {
      dailyCosts = (dc ?? []) as DailyCostRow[];
      const todayRow = dailyCosts.find((d) => d.date === todayStr);
      todayCost = Number(todayRow?.total_eur ?? 0);
    }

    // 3. Top 10 most expensive sessions
    const { data: top, error: topErr } = await sb
      .from('alba_sessions')
      .select('id, uid, started_at, page_origin, msg_count, tokens_in, tokens_out, cost_eur')
      .order('cost_eur', { ascending: false })
      .limit(10);

    if (!topErr) {
      topSessions = (top ?? []) as SessionRow[];
    }
  } catch (err: any) {
    fetchError = err?.message ?? 'Errore sconosciuto';
  }
}

const capPct = Math.min(Math.round((todayCost / CAP_EUR) * 100), 100);
const capStatus = capPct >= 100 ? 'over' : capPct >= 80 ? 'warn' : 'ok';
const capColor = capStatus === 'over' ? '#cc0000' : capStatus === 'warn' ? '#e07000' : '#1a8a3a';
const capBg = capStatus === 'over' ? '#ffeaea' : capStatus === 'warn' ? '#fff5e6' : '#e6f4ec';

const fmtEur = (n: number, digits = 4) => `€${n.toFixed(digits)}`;
const fmtNum = (n: number) => n.toLocaleString('it-IT');
---

<BaseLayout title="Admin · Alba · Costi" description="Token e costi Claude – Alba" minimal={true} chrome={false}>
  {!authed ? (
    <main style="padding:64px 32px; max-width:560px; margin:0 auto; font-family: Inter, system-ui;">
      <h1>Admin Alba · Costi</h1>
      <p style="color:rgba(14,17,22,0.6);">Aggiungi <code>?key=&lt;NARRATOR_SECRET&gt;</code> in URL per accedere.</p>
    </main>
  ) : (
    <main style="padding:32px; max-width:1300px; margin:0 auto; font-family: Inter, system-ui;">

      {/* Header + nav */}
      <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:32px; gap:16px; flex-wrap:wrap;">
        <div>
          <p style="margin:0 0 4px; font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.4);">Admin · Alba</p>
          <h1 style="margin:0 0 6px; font-size:28px; font-weight:900;">Token & Costi Claude</h1>
          <p style="margin:0; font-size:13px; color:rgba(14,17,22,0.5);">
            Aggiornato al {new Date().toLocaleString('it-IT', { dateStyle: 'long', timeStyle: 'short' })}
          </p>
        </div>
        <a
          href={`/admin/alba?key=${key}`}
          style="display:inline-block; padding:8px 16px; font-size:13px; font-weight:600; border:1px solid rgba(14,17,22,0.2); border-radius:8px; text-decoration:none; color:#0e1116; background:#fff;"
        >
          ← Dashboard Alba
        </a>
      </div>

      {/* Error banner */}
      {fetchError && (
        <div style="padding:16px 20px; background:#fff3cd; border:1px solid #ffc107; border-radius:8px; margin-bottom:24px; font-size:13px; color:#856404;">
          <strong>Attenzione:</strong> {fetchError}
        </div>
      )}

      {/* Cap giornaliero */}
      <section style="margin-bottom:32px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Tetto giornaliero</h2>
        <div style={`padding:24px; background:${capBg}; border:1px solid ${capColor}33; border-radius:12px; display:flex; align-items:center; gap:24px; flex-wrap:wrap;`}>
          <div style="flex:1; min-width:200px;">
            <p style="margin:0 0 8px; font-size:13px; font-weight:600; color:rgba(14,17,22,0.7);">Oggi ({new Date().toLocaleDateString('it-IT', { dateStyle: 'medium' })})</p>
            <div style="display:flex; align-items:baseline; gap:8px;">
              <span style={`font-size:42px; font-weight:900; line-height:1; color:${capColor};`}>{fmtEur(todayCost, 4)}</span>
              <span style="font-size:16px; color:rgba(14,17,22,0.5);">/ {fmtEur(CAP_EUR, 0)} cap</span>
            </div>
          </div>
          <div style="flex:2; min-width:240px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:6px; font-size:12px; color:rgba(14,17,22,0.5);">
              <span>0</span>
              <span style={`font-weight:700; color:${capColor};`}>{capPct}%</span>
              <span>{fmtEur(CAP_EUR, 0)}</span>
            </div>
            <div style="background:rgba(14,17,22,0.08); border-radius:100px; height:12px; overflow:hidden;">
              <div style={`width:${capPct}%; height:100%; background:${capColor}; border-radius:100px; transition:width 0.3s;`} />
            </div>
            <p style={`margin:8px 0 0; font-size:13px; font-weight:600; color:${capColor};`}>
              {capStatus === 'over' ? 'CAP RAGGIUNTO — Alba in pausa' : capStatus === 'warn' ? 'Attenzione: quasi al limite' : 'Sotto il tetto — OK'}
            </p>
          </div>
        </div>
      </section>

      {/* KPI totali */}
      <section style="margin-bottom:32px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Totale (tutte le sessioni)</h2>
        <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:16px;">
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Costo totale</p>
            <p style="font-size:32px; font-weight:900; margin:0; line-height:1;">{fmtEur(totalCostEur, 4)}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Token IN</p>
            <p style="font-size:32px; font-weight:900; margin:0; line-height:1;">{fmtNum(totalTokensIn)}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Token OUT</p>
            <p style="font-size:32px; font-weight:900; margin:0; line-height:1;">{fmtNum(totalTokensOut)}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid #e5e7eb; border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Sessioni</p>
            <p style="font-size:32px; font-weight:900; margin:0; line-height:1;">{fmtNum(totalSessions)}</p>
          </div>
        </div>
      </section>

      {/* Costi per giorno — ultimi 30gg */}
      <section style="margin-bottom:32px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Costo per giorno — ultimi 30 giorni</h2>
        {dailyCosts.length === 0 ? (
          <div style="padding:40px; background:#fff; border:1px solid #e5e7eb; border-radius:12px; text-align:center; color:rgba(14,17,22,0.4); font-size:14px;">
            Nessun dato disponibile (tabella <code>alba_daily_costs</code> vuota o assente).
          </div>
        ) : (
          <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse; font-size:13px;">
              <thead>
                <tr style="background:rgba(14,17,22,0.04);">
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Data</th>
                  <th style="text-align:right; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Costo €</th>
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Barra</th>
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">% Cap ({fmtEur(CAP_EUR, 0)})</th>
                </tr>
              </thead>
              <tbody>
                {dailyCosts.map((d) => {
                  const pct = Math.min(Math.round((Number(d.total_eur) / CAP_EUR) * 100), 100);
                  const isOver = pct >= 100;
                  const isHigh = pct >= 80;
                  const barColor = isOver ? '#cc0000' : isHigh ? '#e07000' : '#FF6B33';
                  return (
                    <tr style="border-top:1px solid #e5e7eb;">
                      <td style="padding:10px 16px; font-variant-numeric:tabular-nums;">{d.date}</td>
                      <td style="text-align:right; padding:10px 16px; font-variant-numeric:tabular-nums; font-weight:600;">{Number(d.total_eur).toFixed(4)}</td>
                      <td style="padding:10px 16px; width:240px;">
                        <div style="background:rgba(14,17,22,0.06); border-radius:4px; height:16px; overflow:hidden;">
                          <div style={`width:${pct}%; height:100%; background:${barColor};`} />
                        </div>
                      </td>
                      <td style={`padding:10px 16px; font-weight:600; color:${isOver ? '#cc0000' : isHigh ? '#e07000' : '#1a8a3a'};`}>
                        {pct}% {isOver ? '🔴' : isHigh ? '🟡' : ''}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>

      {/* Top 10 sessioni più costose */}
      <section style="margin-bottom:32px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Top 10 sessioni più costose</h2>
        {topSessions.length === 0 ? (
          <div style="padding:40px; background:#fff; border:1px solid #e5e7eb; border-radius:12px; text-align:center; color:rgba(14,17,22,0.4); font-size:14px;">
            Nessuna sessione trovata.
          </div>
        ) : (
          <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse; font-size:13px;">
              <thead>
                <tr style="background:rgba(14,17,22,0.04);">
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">#</th>
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Data</th>
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">UID</th>
                  <th style="text-align:left; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Pagina</th>
                  <th style="text-align:right; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Msg</th>
                  <th style="text-align:right; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Token IN</th>
                  <th style="text-align:right; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Token OUT</th>
                  <th style="text-align:right; padding:10px 16px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Costo €</th>
                </tr>
              </thead>
              <tbody>
                {topSessions.map((s, i) => (
                  <tr style="border-top:1px solid #e5e7eb;">
                    <td style="padding:10px 16px; color:rgba(14,17,22,0.4); font-weight:600;">{i + 1}</td>
                    <td style="padding:10px 16px; white-space:nowrap; color:rgba(14,17,22,0.7);">
                      {new Date(s.started_at).toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' })}
                    </td>
                    <td style="padding:10px 16px; font-family:ui-monospace,'Cascadia Code',monospace; font-size:12px; color:rgba(14,17,22,0.5);">
                      {s.uid.slice(0, 8)}
                    </td>
                    <td style="padding:10px 16px; color:rgba(14,17,22,0.7);">{s.page_origin ?? '/'}</td>
                    <td style="text-align:right; padding:10px 16px;">{s.msg_count}</td>
                    <td style="text-align:right; padding:10px 16px; font-variant-numeric:tabular-nums;">{fmtNum(Number(s.tokens_in ?? 0))}</td>
                    <td style="text-align:right; padding:10px 16px; font-variant-numeric:tabular-nums;">{fmtNum(Number(s.tokens_out ?? 0))}</td>
                    <td style="text-align:right; padding:10px 16px; font-weight:700; font-variant-numeric:tabular-nums;">
                      {fmtEur(Number(s.cost_eur ?? 0), 4)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <p style="margin-top:12px; font-size:11px; color:rgba(14,17,22,0.35);">
        Fonti: <code>alba_sessions</code> (tokens_in, tokens_out, cost_eur) · <code>alba_daily_costs</code> (tetto giornaliero) · Cap corrente: {fmtEur(CAP_EUR, 0)}/giorno.
      </p>
    </main>
  )}
</BaseLayout>
