---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { albaSupabase } from '../../../lib/server/alba/supabase';

export const prerender = false;

const key = Astro.url.searchParams.get('key');
const expected = process.env.NARRATOR_SECRET || '';
const authed = !!(expected && key === expected);

let data: {
  sessions7: any[];
  events7: any[];
  users7: any[];
  costs14: any[];
  handoffs: any[];
  recentSessions: any[];
} | null = null;

if (authed) {
  const sb = albaSupabase();
  const since7 = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  const since14 = new Date(Date.now() - 14 * 24 * 60 * 60 * 1000).toISOString();

  const [sessions7, events7, users7, costs14, handoffs, recentSessions] = await Promise.all([
    sb.from('alba_sessions').select('id, uid, msg_count, tokens_in, tokens_out, cost_eur, started_at, page_origin').gte('started_at', since7),
    sb.from('alba_events').select('event, ts, variant, payload').gte('ts', since7),
    sb.from('alba_users').select('uid, ab_variant').gte('first_seen_at', since7),
    sb.from('alba_daily_costs').select('*').gte('date', since14.slice(0, 10)).order('date', { ascending: false }),
    sb.from('alba_events').select('ts, payload').eq('event', 'handoff_to_max').order('ts', { ascending: false }).limit(10),
    sb.from('alba_sessions').select('id, uid, started_at, page_origin, msg_count, cost_eur').order('started_at', { ascending: false }).limit(20),
  ]);

  data = {
    sessions7: sessions7.data ?? [],
    events7: events7.data ?? [],
    users7: users7.data ?? [],
    costs14: costs14.data ?? [],
    handoffs: handoffs.data ?? [],
    recentSessions: recentSessions.data ?? [],
  };
}

const countEvent = (events: any[], name: string) => events.filter((e: any) => e.event === name).length;
const sum = (arr: any[], k: string) => arr.reduce((s: number, x: any) => s + (Number(x[k]) || 0), 0);
const uniq = (arr: any[], k: string) => new Set(arr.map((x: any) => x[k])).size;
---

<BaseLayout title="Admin · Alba" description="Dashboard interno Alba" minimal={true} chrome={false}>
  {!authed ? (
    <main style="padding:64px 32px; max-width:560px; margin:0 auto; font-family: Inter, system-ui;">
      <h1>Admin Alba</h1>
      <p style="color:rgba(14,17,22,0.6);">Aggiungi <code>?key=&lt;NARRATOR_SECRET&gt;</code> in URL per accedere.</p>
    </main>
  ) : (
    <main style="padding:32px; max-width:1200px; margin:0 auto; font-family: Inter, system-ui;">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:32px; gap:16px; flex-wrap:wrap;">
        <div>
          <h1 style="margin:0 0 8px; font-size:28px; font-weight:900;">Alba · Dashboard</h1>
          <p style="margin:0; font-size:13px; color:rgba(14,17,22,0.5);">Aggiornato al {new Date().toLocaleString('it-IT', { dateStyle: 'long', timeStyle: 'short' })}</p>
        </div>
        <a
          href={`/admin/alba/leads?key=${key}`}
          style="display:inline-block; padding:8px 16px; font-size:13px; font-weight:600; border:1px solid rgba(14,17,22,0.2); border-radius:8px; text-decoration:none; color:#0e1116; background:#fff; white-space:nowrap;"
        >
          Lead →
        </a>
      </div>

      {/* KPI ultimi 7 giorni */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Ultimi 7 giorni</h2>
        <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:16px;">
          <div style="padding:20px; background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Sessioni</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">{data!.sessions7.length}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Utenti unici</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">{uniq(data!.sessions7, 'uid')}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Messaggi</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">{sum(data!.sessions7, 'msg_count')}</p>
          </div>
          <div style="padding:20px; background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px;">
            <p style="font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5); margin:0 0 8px;">Costo totale</p>
            <p style="font-size:36px; font-weight:900; margin:0; line-height:1;">€{sum(data!.sessions7, 'cost_eur').toFixed(2)}</p>
          </div>
        </div>
      </section>

      {/* Funnel */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Funnel — ultimi 7 giorni</h2>
        <div style="background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px; padding:20px;">
          {(['chat_opened', 'first_user_msg', 'email_captured', 'call_booked', 'handoff_to_max'] as const).map((ev) => {
            const n = countEvent(data!.events7, ev);
            const base = countEvent(data!.events7, 'chat_opened') || 1;
            const pct = Math.round((n / base) * 100);
            return (
              <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px; last-child:margin-bottom:0;">
                <p style="width:160px; font-size:13px; margin:0; flex-shrink:0;">{ev}</p>
                <div style="flex:1; background:rgba(14,17,22,0.06); height:24px; border-radius:6px; overflow:hidden;">
                  <div style={`width:${Math.max(pct, 0)}%; height:100%; background:#FF6B33; transition:width 0.3s;`} />
                </div>
                <p style="width:90px; text-align:right; font-size:13px; margin:0; flex-shrink:0;">{n} <span style="color:rgba(14,17,22,0.4);">({pct}%)</span></p>
              </div>
            );
          })}
        </div>
      </section>

      {/* Costi giornalieri 14gg */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Costi giornalieri — ultimi 14 giorni</h2>
        <div style="background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px; overflow:hidden;">
          <table style="width:100%; border-collapse:collapse; font-size:13px;">
            <thead>
              <tr style="background:rgba(14,17,22,0.04);">
                <th style="text-align:left; padding:10px 16px; font-weight:600;">Data</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Totale €</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">% cap (5€)</th>
                <th style="text-align:left; padding:10px 16px; font-weight:600;">Status</th>
              </tr>
            </thead>
            <tbody>
              {data!.costs14.length === 0 ? (
                <tr><td colspan="4" style="padding:16px; color:rgba(14,17,22,0.4); text-align:center;">Nessun dato disponibile.</td></tr>
              ) : data!.costs14.map((d: any) => {
                const pct = Math.round((Number(d.total_eur) / 5) * 100);
                const isHigh = pct > 80;
                const isOver = pct >= 100;
                return (
                  <tr style="border-top:1px solid var(--pianeta-border, #e5e7eb);">
                    <td style="padding:10px 16px;">{d.date}</td>
                    <td style="text-align:right; padding:10px 16px; font-variant-numeric:tabular-nums;">{Number(d.total_eur).toFixed(4)}</td>
                    <td style={`text-align:right; padding:10px 16px; font-weight:600; ${isOver ? 'color:#cc0000;' : isHigh ? 'color:#e07000;' : 'color:#1a8a3a;'}`}>{pct}%</td>
                    <td style="padding:10px 16px;">{isOver ? '🔴 OVER CAP' : isHigh ? '🟡 Attenzione' : '✅ OK'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

      {/* Handoff recenti */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Handoff recenti (ultimi 10)</h2>
        <div style="background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px; overflow:hidden;">
          {data!.handoffs.length === 0 ? (
            <p style="padding:20px; color:rgba(14,17,22,0.4); margin:0;">Nessun handoff ancora registrato.</p>
          ) : (
            <table style="width:100%; border-collapse:collapse; font-size:13px;">
              <thead>
                <tr style="background:rgba(14,17,22,0.04);">
                  <th style="text-align:left; padding:10px 16px; font-weight:600;">Quando</th>
                  <th style="text-align:left; padding:10px 16px; font-weight:600;">Reason</th>
                  <th style="text-align:left; padding:10px 16px; font-weight:600;">Summary</th>
                  <th style="text-align:left; padding:10px 16px; font-weight:600;">Contatto</th>
                  <th style="text-align:left; padding:10px 16px; font-weight:600;">Urgenza</th>
                </tr>
              </thead>
              <tbody>
                {data!.handoffs.map((h: any) => {
                  const summary = h.payload?.summary || '';
                  return (
                    <tr style="border-top:1px solid var(--pianeta-border, #e5e7eb);">
                      <td style="padding:10px 16px; white-space:nowrap;">{new Date(h.ts).toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' })}</td>
                      <td style="padding:10px 16px;">{h.payload?.reason ?? '—'}</td>
                      <td style="padding:10px 16px; color:rgba(14,17,22,0.7);">{summary.slice(0, 80)}{summary.length > 80 ? '…' : ''}</td>
                      <td style="padding:10px 16px;">{h.payload?.contact ?? '—'}</td>
                      <td style={`padding:10px 16px; font-weight:600; ${h.payload?.urgency === 'high' ? 'color:#cc0000;' : 'color:rgba(14,17,22,0.5);'}`}>{h.payload?.urgency ?? 'normal'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          )}
        </div>
      </section>

      {/* AB Test */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">A/B Variant — ultimi 7 giorni</h2>
        <div style="background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px; overflow:hidden;">
          <table style="width:100%; border-collapse:collapse; font-size:13px;">
            <thead>
              <tr style="background:rgba(14,17,22,0.04);">
                <th style="text-align:left; padding:10px 16px; font-weight:600;">Variant</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Sessioni</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Chat aperte</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Chat / sessioni</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Email captured</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Email / sessioni</th>
              </tr>
            </thead>
            <tbody>
              {(['proactive', 'reactive'] as const).map((v) => {
                const vUsers = data!.users7.filter((u: any) => u.ab_variant === v);
                const vSessions = vUsers.length;
                const vEvents = data!.events7.filter((e: any) => e.variant === v);
                const chats = vEvents.filter((e: any) => e.event === 'chat_opened').length;
                const emails = vEvents.filter((e: any) => e.event === 'email_captured').length;
                const chatPct = vSessions ? Math.round((chats / vSessions) * 100) : 0;
                const emailPct = vSessions ? Math.round((emails / vSessions) * 100) : 0;
                return (
                  <tr style="border-top:1px solid var(--pianeta-border, #e5e7eb);">
                    <td style="padding:10px 16px;"><strong>{v}</strong></td>
                    <td style="text-align:right; padding:10px 16px;">{vSessions}</td>
                    <td style="text-align:right; padding:10px 16px;">{chats}</td>
                    <td style="text-align:right; padding:10px 16px; color:rgba(14,17,22,0.6);">{chatPct}%</td>
                    <td style="text-align:right; padding:10px 16px;">{emails}</td>
                    <td style="text-align:right; padding:10px 16px; color:rgba(14,17,22,0.6);">{emailPct}%</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

      {/* Sessioni recenti */}
      <section style="margin-bottom:40px;">
        <h2 style="margin:0 0 16px; font-size:14px; text-transform:uppercase; letter-spacing:1.5px; color:rgba(14,17,22,0.5);">Ultime 20 sessioni</h2>
        <div style="background:#fff; border:1px solid var(--pianeta-border, #e5e7eb); border-radius:12px; overflow:hidden;">
          <table style="width:100%; border-collapse:collapse; font-size:13px;">
            <thead>
              <tr style="background:rgba(14,17,22,0.04);">
                <th style="text-align:left; padding:10px 16px; font-weight:600;">Quando</th>
                <th style="text-align:left; padding:10px 16px; font-weight:600;">UID</th>
                <th style="text-align:left; padding:10px 16px; font-weight:600;">Pagina</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Msg</th>
                <th style="text-align:right; padding:10px 16px; font-weight:600;">Costo €</th>
              </tr>
            </thead>
            <tbody>
              {data!.recentSessions.map((s: any) => (
                <tr style="border-top:1px solid var(--pianeta-border, #e5e7eb);">
                  <td style="padding:10px 16px; white-space:nowrap;">{new Date(s.started_at).toLocaleString('it-IT', { dateStyle: 'short', timeStyle: 'short' })}</td>
                  <td style="padding:10px 16px; font-family:ui-monospace, 'Cascadia Code', monospace; font-size:12px; color:rgba(14,17,22,0.6);">{s.uid.slice(0, 8)}</td>
                  <td style="padding:10px 16px;">{s.page_origin ?? '/'}</td>
                  <td style="text-align:right; padding:10px 16px;">{s.msg_count}</td>
                  <td style="text-align:right; padding:10px 16px; font-variant-numeric:tabular-nums;">{Number(s.cost_eur).toFixed(4)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>
  )}
</BaseLayout>
