---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../lib/next-item';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('team');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'team');
const { Content } = await render(item);
const data: any = item.data;
const title = data.name || data.title || item.id;
const cover = data.photo || data.cover || data.ogImage;

const url = new URL(`/team/${item.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name || title,
  jobTitle: data.role,
  description: data.description,
  url,
  image: data.photo || cover,
  email: data.email,
  worksFor: { '@type': 'Organization', name: 'Pianeta.Studio', url: 'https://xp.pianeta.studio' },
  ...(data.location && { homeLocation: { '@type': 'Place', name: data.location } }),
};

const metaInline = [
  data.role && { label: 'Ruolo', value: data.role },
  data.employment && { label: 'Rapporto', value: data.employment },
  data.since && { label: 'Dal', value: String(new Date(data.since).getFullYear()) },
  data.location && { label: 'Dove', value: data.location },
  data.email && { label: 'Email', value: data.email, href: `mailto:${data.email}` },
].filter(Boolean);

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Team', href: '/team' }];
if (data.role) eyebrowParts.push({ label: data.role });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    heroPortrait={true}
    primaryCta={data.email ? { label: 'Scrivigli', href: `mailto:${data.email}`, external: false } : undefined}
    backHref="/team"
    backLabel="Tutto il team"
    nextItem={nextItem}
    byline={{ meta: [data.role, data.location].filter(Boolean) }}
    metaInline={metaInline}
    jsonLd={jsonLd}
  >
    <Content />
  </DetailPage>
</BaseLayout>
