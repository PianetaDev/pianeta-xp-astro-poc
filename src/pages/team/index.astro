---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamOverlay from '../../components/team/TeamOverlay.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('team')).filter((i: any) => i.data.draft !== true);

const byKind = (k: string) =>
  all
    .filter((i: any) => (i.data.kind || 'core') === k)
    .sort((a: any, b: any) => (a.data.order ?? 999) - (b.data.order ?? 999));

const core = byKind('core');
const satellite = byKind('satellite');
const ai = byKind('ai');

const sections = [
  { key: 'core', title: 'Core', intro: 'Il team interno dello studio. Operations, design, tecnologia.', items: core, contact: '' },
  { key: 'satellite', title: 'Pianeta.Satellite', intro: 'La community di freelance che orbita intorno al core team — designer, illustratori, sviluppatori che hanno scelto di lavorare con noi su progetti specifici.', items: satellite, contact: 'satellite@pianeta.studio' },
  { key: 'ai', title: 'AI di gruppo', intro: 'Sistemi AI che operano dentro Pianeta.Studio con disclosure esplicita. Niente "human disguised as AI", niente "AI disguised as human".', items: ai, contact: '' },
];
---
<BaseLayout title="Team — Pianeta.Studio" description="Le persone dietro Pianeta.Studio: core team, rete Satellite, agenti AI.">
  <div class="index-page">
    <header class="index-head">
      <h1 class="index-title">Team</h1>
      <p class="index-deck">Persone che progettano, programmano, ricercano. Studio nomade, sedi a Milano · Ardea · Sicilia.</p>
    </header>

    {sections.map((sec) => sec.items.length > 0 && (
      <section class="team-section">
        <header class="team-section-head">
          <h2 class="team-section-title">{sec.title}</h2>
          <p class="team-section-intro">
            {sec.intro}
            {sec.contact && <> Contatto: <a href={`mailto:${sec.contact}`} class="meta-link">{sec.contact}</a></>}
          </p>
        </header>
        <div class="team-grid">
          {sec.items.map((it: any) => {
            const name = it.data.name || it.data.title || it.id;
            const photo = it.data.photo || it.data.cover;
            const initials = String(name).split(/\s+/).map((s: string) => s[0]).filter(Boolean).slice(0, 2).join('').toUpperCase();
            return (
              <a
                href={`/team/${it.id}`}
                class="team-card team-open"
                data-team-slug={it.id}
                aria-label={name}
              >
                <div class="team-card-photo" style={photo ? `background-image:url('${photo}')` : ''}>
                  {!photo && <span class="team-card-initials">{initials}</span>}
                </div>
                <div class="team-card-meta">
                  <strong class="team-card-name">{name}</strong>
                  {it.data.role && <span class="team-card-role">{it.data.role}</span>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    {all.length === 0 && (
      <div class="index-empty">Nessun profilo pubblicato.</div>
    )}
  </div>

  <TeamOverlay locale="it" />

  <style>
    .team-section { margin-top: 64px; }
    .team-section-head { max-width: 760px; margin: 0 auto 32px; text-align: center; }
    .team-section-title { font-size: clamp(1.4rem, 2.2vw, 1.85rem); font-weight: 900; letter-spacing: -0.02em; margin: 0 0 10px; }
    .team-section-intro { font-size: var(--ty-meta); color: var(--pianeta-muted); line-height: 1.55; margin: 0; }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (min-width: 640px)  { .team-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; } }
    @media (min-width: 900px)  { .team-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; } }
    @media (min-width: 1200px) { .team-grid { grid-template-columns: repeat(5, 1fr); gap: 16px; } }

    .team-card {
      display: flex; flex-direction: column;
      text-decoration: none; color: inherit;
      border-radius: var(--radius-card-sm); overflow: hidden;
      background: var(--pianeta-bg-card);
      border: 1px solid var(--pianeta-border);
      transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    }
    .team-card:hover {
      transform: translateY(-3px);
      border-color: var(--pianeta-border-strong);
      box-shadow: 0 10px 24px rgba(14,17,22,.08);
    }
    .team-card-photo {
      position: relative;
      aspect-ratio: 1 / 1;
      background-size: cover; background-position: center top;
      background-color: var(--pianeta-bg);
      display: flex; align-items: center; justify-content: center;
    }
    .team-card-initials {
      font-size: var(--ty-h2-sec); font-weight: 900; letter-spacing: -0.02em;
      color: var(--pianeta-muted);
    }
    .team-card-meta {
      padding: 10px 12px 12px;
      display: flex; flex-direction: column; gap: 2px;
      min-height: 52px;
    }
    .team-card-name {
      font-size: var(--ty-meta); font-weight: 700; line-height: 1.2;
      color: var(--pianeta-text);
    }
    .team-card-role {
      font-size: 12px; color: var(--pianeta-muted); line-height: 1.35;
    }
  </style>
</BaseLayout>
