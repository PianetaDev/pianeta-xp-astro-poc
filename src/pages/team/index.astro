---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexCard from '../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('team');
const items = all
  .filter((i: any) => i.data.draft !== true)
  .sort((a: any, b: any) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<BaseLayout title="Team — Pianeta.Studio" description="Le persone dietro Pianeta.Studio.">
  <div class="index-page">
    <header class="index-head">
      <p class="index-eyebrow">Pianeta.Studio</p>
      <h1 class="index-title">Team</h1>
      <p class="index-deck">Persone che progettano, programmano, ricercano. Studio nomade, sedi a Milano · Ardea · Sicilia.</p>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">Nessun profilo pubblicato.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard
            href={`/team/${it.id}`}
            title={it.data.name || it.data.title || it.id}
            deck={it.data.role}
            kicker={it.data.location}
            image={it.data.photo || it.data.cover}
            portrait={true}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
