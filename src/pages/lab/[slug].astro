---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('lab');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Lab', href: '/lab' }];
if (data.kind) eyebrowParts.push({ label: data.kind });
if (data.year) eyebrowParts.push({ label: String(data.year) });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={data.links?.external ? { label: 'Apri ' + (data.title || 'progetto') + ' ↗', href: data.links.external, external: true } : undefined}
    secondaryCta={{ label: 'Lavoriamo insieme', action: 'open-hire-us' }}
    backHref="/lab"
    backLabel="Tutti gli esperimenti"
  >
    <Fragment slot="meta">
      {data.kind && <div><dt>Tipo</dt><dd>{data.kind}</dd></div>}
      {data.year && <div><dt>Anno</dt><dd>{data.year}</dd></div>}
      {data.status && <div><dt>Stato</dt><dd>{data.status}</dd></div>}
      {data.tags && data.tags.length > 0 && <div><dt>Tag</dt><dd>{data.tags.join(' · ')}</dd></div>}
    </Fragment>
    <Content />
  </DetailPage>
</BaseLayout>
