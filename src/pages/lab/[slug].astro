---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailPage from '../../components/detail/DetailPage.astro';
import { getCollection, render } from 'astro:content';
import { pickNextItem, toNextProp } from '../../lib/next-item';

export const prerender = true;
export async function getStaticPaths() {
  const items = await getCollection('lab');
  return items.map((item) => ({ params: { slug: item.id }, props: { item, allItems: items } }));
}

const { item, allItems } = Astro.props as any;
const nextItem = toNextProp(pickNextItem(allItems, item.id), 'lab');
const { Content } = await render(item);
const data: any = item.data;
const title = data.title || item.id;
const cover = data.cover || data.ogImage;

const metaInline = [
  data.kind && { label: 'Tipo', value: data.kind },
  data.year && { label: 'Anno', value: String(data.year) },
  data.status && { label: 'Stato', value: data.status },
  data.tags?.length && { label: 'Tag', value: data.tags.join(' · ') },
].filter(Boolean);

const eyebrowParts: Array<{label:string;href?:string}> = [{ label: 'Lab', href: '/lab' }];
if (data.kind) eyebrowParts.push({ label: data.kind });
if (data.year) eyebrowParts.push({ label: String(data.year) });
---
<BaseLayout title={`${title} — Pianeta.Studio`} description={data.description} ogImage={data.ogImage || cover}>
  <DetailPage
    eyebrowParts={eyebrowParts}
    title={title}
    deck={data.description}
    cover={cover}
    primaryCta={data.links?.external ? { label: 'Apri ' + (data.title || 'progetto') + ' ↗', href: data.links.external, external: true } : undefined}
    secondaryCta={{ label: 'Lavoriamo insieme', action: 'open-hire-us' }}
    backHref="/lab"
    backLabel="Tutti gli esperimenti"
    nextItem={nextItem}
    metaInline={metaInline}
  >
    <Content />
  </DetailPage>
</BaseLayout>
