---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IndexCard from '../../components/detail/IndexCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('lab');
const items = all
  .filter((i: any) => i.data.draft !== true)
  .sort((a: any, b: any) => {
    const da = a.data.date ? new Date(a.data.date).getTime() : 0;
    const db = b.data.date ? new Date(b.data.date).getTime() : 0;
    return db - da;
  });
---
<BaseLayout title="Lab — Pianeta.Studio" description="Esperimenti e ricerca da Pianeta.Studio. Carbon farming, neuromarketing, AI per la creatività.">
  <div class="index-page">
    <header class="index-head">      <h1 class="index-title">Lab</h1>
      <p class="index-deck">R&D e sperimentazione. AI validation, neuromarketing, carbon-aware design.</p>
    </header>

    {items.length === 0 ? (
      <div class="index-empty">Sperimentazioni in arrivo. Scrivici a <a href="mailto:lab@pianeta.studio" class="meta-link" style="color:var(--cta-primary);">lab@pianeta.studio</a> per collaborare.</div>
    ) : (
      <div class="index-grid">
        {items.map((it: any) => (
          <IndexCard
            href={`/lab/${it.id}`}
            title={it.data.title || it.id}
            deck={it.data.description}
            kicker={it.data.kind}
            image={it.data.cover || it.data.ogImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
