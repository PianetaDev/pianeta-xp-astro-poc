---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Sort helper: date desc, drafts excluded
const byDateDesc = (a: any, b: any) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
};
const live = (e: any) => e.data.draft !== true;

const featuredWork = (await getCollection('work')).filter(live).sort(byDateDesc);
const bulletin = (await getCollection('bulletin')).filter(live).sort(byDateDesc);
const services = (await getCollection('services')).filter(live).sort(byDateDesc);
const team = (await getCollection('team')).filter(live);
const teamCount = team.length;

const w0 = featuredWork[0];
const otherWork = featuredWork.slice(1); // tutti gli altri work dopo il featured
const b0 = bulletin[0];
const b1 = bulletin[1];
const b2 = bulletin[2];
const s0 = services[0];

const description = 'Studio di design & technology. Lavori, articoli, esperimenti.';
const title = 'Pianeta.Studio — Sustainable Creativity dal 2016';

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://xp.pianeta.studio/#organization',
  name: 'Pianeta.Studio',
  alternateName: 'PIANETA.STUDIO S.R.L. S.B.',
  legalName: 'PIANETA.STUDIO S.R.L. SOCIETÀ BENEFIT',
  url: 'https://xp.pianeta.studio',
  logo: { '@type': 'ImageObject', url: 'https://xp.pianeta.studio/logo.png', width: 512, height: 512 },
  description: 'Studio di design e technology · Sustainable Creativity dal 2016 · Italian Benefit Corporation operating at the intersection of sustainable design, technology, and social impact.',
  slogan: 'Sustainable Creativity dal 2016. Design & Technology, una sola disciplina.',
  foundingDate: '2023-09-14',
  founder: { '@type': 'Person', name: 'Massimiliano Mauro', jobTitle: 'Founder & Strategic Director' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via IV Novembre 18',
    addressLocality: 'San Giovanni La Punta',
    addressRegion: 'CT',
    postalCode: '95037',
    addressCountry: 'IT',
  },
  taxID: '06037730873',
  vatID: '06037730873',
  areaServed: ['IT', 'EU'],
  knowsLanguage: ['it', 'en'],
  email: 'info@pianeta.studio',
  sameAs: [
    'https://www.linkedin.com/company/pianeta-studio/',
    'https://github.com/PianetaDev',
    'https://www.instagram.com/pianeta.studio/',
    'https://pianeta.green',
    'https://atlas.pianeta.green',
  ],
};
---
<BaseLayout title={title} description={description} ogImage="/og/home.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  </Fragment>

  <div class="home-page">

    {/* === I NOSTRI PACCHETTI === */}
    <section class="pacchetti-section" aria-label="I nostri pacchetti">
      <p class="pacchetti-eyebrow">I nostri pacchetti</p>
      <div class="pacchetti-grid">

        {/* Sito Green */}
        <div class="pacchetto-card pacchetto-green">
          <div class="pacchetto-inner">
            <p class="pacchetto-kicker">Sito Green</p>
            <p class="pacchetto-price">da 2.000€ <span class="pacchetto-iva">+ IVA</span></p>
            <p class="pacchetto-desc">Un sito sostenibile e veloce, costruito sul nostro design system e a basso impatto: la CO₂ della pagina la misuriamo con GreenMeter. Pacchetto Pianeta.Green.</p>
          </div>
          <button type="button" class="pacchetto-cta" data-action="open-alba">Parla con Alba</button>
        </div>

        {/* Pianeta Sprint */}
        <div class="pacchetto-card pacchetto-sprint">
          <div class="pacchetto-inner">
            <p class="pacchetto-kicker">Pianeta Sprint</p>
            <p class="pacchetto-price">4 giorni · 3.500€ <span class="pacchetto-iva">+ IVA</span></p>
            <p class="pacchetto-desc">Da un'idea confusa a una direzione validata e pronta da produrre. 4 giorni: immersione → direzione → validazione col nostro swarm AI e neuromarketing → consegna.</p>
            <a href="/come-funziona-lo-sprint" class="pacchetto-meta-link">Come funziona lo Sprint →</a>
          </div>
          <button type="button" class="pacchetto-cta" data-action="open-alba">Parla con Alba</button>
        </div>

        {/* Team as a Service */}
        <div class="pacchetto-card pacchetto-taas">
          <div class="pacchetto-inner">
            <p class="pacchetto-kicker">Team as a Service</p>
            <p class="pacchetto-price">4.000€<span class="pacchetto-iva">/mese + IVA</span></p>
            <p class="pacchetto-desc">Un team dedicato (design, web, copy) con meeting settimanale e consegne ogni giovedì. Per chi ha bisogno continuativo.</p>
            <a href="/team-as-a-service" class="pacchetto-meta-link">Scopri il pacchetto →</a>
          </div>
          <button type="button" class="pacchetto-cta" data-action="open-alba">Parla con Alba</button>
        </div>

      </div>
    </section>

    <div class="bento-grid">

      {/* 1. Featured ECLAG video — tall portrait (col-1 row-span-3) */}
      <a href={w0 ? `/work/${w0.id}` : '/work/eclag'} class="bento-tile t-tall t-dark">
        <video poster="/choosetoseethem/cover-v3.png" autoplay muted loop playsinline class="bento-video">
          <source src="https://pub-4c166b51c33040fd98b8f75c2963296e.r2.dev/choosetoseethem/video-restore-web.mp4" type="video/mp4" />
        </video>
        <div class="bento-grad" />
        <div class="bento-content">
          <p class="bento-kicker">Featured · ECLAG</p>
          <div class="bento-spacer" />
          <h2 class="bento-title-xl">{w0?.data.title || 'Choose to See Them'}</h2>
          <p class="bento-sub">{(w0?.data.client || 'ECLAG') + ' · ' + (w0?.data.year || 2026)}</p>
        </div>
      </a>

      {/* 2. Wordmark — square */}
      <a href="/bulletin/chi-siamo" class="bento-tile t-square t-cream bento-wordmark">
        <div class="bento-wordmark-stack">
          <img src="/brand/logo-horizontal-color.svg" alt="Pianeta.Studio" class="bento-wordmark-logo" width="282" height="80" loading="lazy" decoding="async" />
          <span class="badge-benefit" style="background:rgba(255,107,51,0.10); color:#FF6B33; border:1px solid rgba(255,107,51,0.25); border-radius:999px; padding:6px 12px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:1px; display:inline-flex; align-items:center; gap:6px; width:fit-content;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="#FF6B33" stroke="#FF6B33" stroke-width="0"><path d="M12 2l3 6 6 .5-4.5 4 1.5 6.5L12 16l-6 3 1.5-6.5-4.5-4 6-.5z"/></svg>
            Società Benefit · dal 2023
          </span>
          <p class="bento-sub">Sustainable Creativity dal 2016 · Design &amp; Technology · Pianeta-centric design iscritto in statuto</p>
          <p class="sc-clarification">Sustainable Creativity non vuol dire solo no-profit: lavoriamo con brand etici, food, energy, farmaceutica responsabile e PMI green.</p>
        </div>
      </a>

      {/* 3. Bulletin #1 — yellow medium */}
      {b0 && (
        <a href={`/bulletin/${b0.id}`} class="bento-tile t-medium" style="background:#E9FF1F;">
          <div class="bento-content">
            <p class="bento-kicker">{'Bulletin' + (b0.data.issue ? ' · #' + b0.data.issue : '')}</p>
            <div class="bento-spacer" />
            <h2 class="bento-title">{b0.data.title}</h2>
            {b0.data.description && <p class="bento-sub">{b0.data.description}</p>}
          </div>
        </a>
      )}

      {/* 4. Hire Us / Parla con Alba — orange CTA statica */}
      <button type="button" class="bento-tile t-medium t-orange" data-action="open-alba">
        <div class="bento-content">
          <p class="bento-kicker">Studio</p>
          <div class="bento-spacer" />
          <h2 class="bento-title">Parla con Alba</h2>
          <p class="bento-sub">L'AI di gruppo di Pianeta.Studio · ti aiuta a inquadrare brief, fissare call, capire i nostri lavori.</p>
        </div>
      </button>
      <script is:inline>
        document.querySelectorAll('[data-action="open-alba"]').forEach((b) => {
          b.addEventListener('click', () => window.dispatchEvent(new CustomEvent('alba:open')));
        });
      </script>

      {/* 5. Bulletin #2 — blue */}
      {b1 && (
        <a href={`/bulletin/${b1.id}`} class="bento-tile t-medium t-blue">
          <div class="bento-content">
            <p class="bento-kicker">{'Bulletin' + (b1.data.issue ? ' · #' + b1.data.issue : '')}</p>
            <div class="bento-spacer" />
            <h2 class="bento-title">{b1.data.title}</h2>
            {b1.data.description && <p class="bento-sub">{b1.data.description}</p>}
          </div>
        </a>
      )}

      {/* 6. Service — cream tall */}
      {s0 && (
        <a href={`/services/${s0.id}`} class="bento-tile t-tall" style="background:#f7f1d9;">
          <div class="bento-content">
            <p class="bento-kicker">Servizio</p>
            <div class="bento-spacer" />
            <h2 class="bento-title-lg">{s0.data.title}</h2>
            <p class="bento-sub">{s0.data.description}</p>
          </div>
        </a>
      )}

      {/* 7. Tutti gli altri work (image cover) — auto-popola da featuredWork.slice(1) */}
      {otherWork.map((w: any, i: number) => (
        <a href={`/work/${w.id}`} class={`bento-tile ${i === 0 ? 't-tall' : 't-medium'}`} style={`background-image:url('${(w.data.cover || '/og/placeholder.svg').replace(/\.(png|jpe?g)$/i, '-card.webp')}'); background-size:cover; background-position:center; color:#fff;`}>
          <div class="bento-grad" />
          <div class="bento-content">
            <p class="bento-kicker">{'Work · ' + (w.data.year || '')}</p>
            <div class="bento-spacer" />
            <h2 class={i === 0 ? 'bento-title-xl' : 'bento-title'}>{w.data.title}</h2>
            <p class="bento-sub">{w.data.client || w.data.description}</p>
          </div>
        </a>
      ))}

      {/* 8. Team — light */}
      <a href="/team" class="bento-tile t-medium t-cream">
        <div class="bento-content">
          <p class="bento-kicker">Persone</p>
          <div class="bento-spacer" />
          <h2 class="bento-title">{teamCount > 0 ? `${teamCount} voci dentro Pianeta` : '5 voci dentro Pianeta'}</h2>
          <p class="bento-sub">Conosci il team →</p>
        </div>
      </a>

      {/* 8. Bulletin #3 — green */}
      {b2 && (
        <a href={`/bulletin/${b2.id}`} class="bento-tile t-medium" style="background:#1f7a3a; color:#fff;">
          <div class="bento-content">
            <p class="bento-kicker">{'Bulletin' + (b2.data.issue ? ' · #' + b2.data.issue : '')}</p>
            <div class="bento-spacer" />
            <h2 class="bento-title">{b2.data.title}</h2>
            {b2.data.description && <p class="bento-sub">{b2.data.description}</p>}
          </div>
        </a>
      )}

      {/* Client wall — tile larga */}
      <a href="/work" class="bento-tile t-tall t-cream bento-clientwall">
        <div class="bento-content">
          <p class="bento-kicker">Hanno scelto di lavorare con noi</p>
          <div class="bento-spacer" />
          <ul class="clientwall-list" aria-label="Clienti e partner">
            <li>Armani</li>
            <li>Prada</li>
            <li>La Repubblica</li>
            <li>Wired</li>
            <li>Plenitude</li>
            <li>BC3</li>
            <li>ChildFund</li>
            <li>WeWorld</li>
            <li>ECLAG</li>
            <li>Sant'Egidio</li>
            <li>ARIES</li>
            <li>ArtPay</li>
            <li>Morsy</li>
            <li>Latte Creative</li>
            <li>EPOS</li>
            <li>Susdef</li>
            <li>Apotheke</li>
          </ul>
          <p class="bento-sub" style="margin-top:16px;">Vedi i lavori →</p>
        </div>
      </a>

      {/* 9. Lab — black */}
      <a href="/lab" class="bento-tile t-medium t-dark">
        <div class="bento-content">
          <p class="bento-kicker">Lab</p>
          <div class="bento-spacer" />
          <h2 class="bento-title">R&D in corso</h2>
          <p class="bento-sub">Atlas — framework ESG proprietario, live su atlas.pianeta.green →</p>
        </div>
      </a>

      {/* 10. Careers — bright */}
      <a href="/careers" class="bento-tile t-medium" style="background:#FFE7C2;">
        <div class="bento-content">
          <p class="bento-kicker">Careers</p>
          <div class="bento-spacer" />
          <h2 class="bento-title">Cerchiamo un AI Manager</h2>
          <p class="bento-sub">Vedi posizione →</p>
        </div>
      </a>

      {/* 11. Bulletin CTA — pale */}
      <a href="/bulletin/iscrivimi" class="bento-tile t-medium t-cream">
        <div class="bento-content">
          <p class="bento-kicker">Bulletin</p>
          <div class="bento-spacer" />
          <h2 class="bento-title">Iscriviti</h2>
          <p class="bento-sub">1-2 al mese. Topic selezionabili.</p>
        </div>
      </a>

      <script is:inline>
        document.querySelectorAll('[data-action="open-hire-us"]').forEach(b => {
          b.addEventListener('click', () => window.dispatchEvent(new CustomEvent('hire-us:open')))
        })
      </script>

    </div>
  </div>

  <style>
    .home-page {
      padding: 16px;
      max-width: 1500px;
      margin: 0 auto;
    }
    @media (min-width: 768px) { .home-page { padding: 32px; } }

    /* ── Pacchetti section ── */
    .pacchetti-section {
      margin-bottom: 24px;
    }
    .pacchetti-eyebrow {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 700;
      opacity: 0.5;
      margin: 0 0 14px;
    }
    .pacchetti-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    @media (min-width: 700px) {
      .pacchetti-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    }
    .pacchetto-card {
      border-radius: 20px;
      padding: 22px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 16px;
      min-height: 200px;
    }
    .pacchetto-inner { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .pacchetto-kicker {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
      opacity: 0.7;
      margin: 0;
    }
    .pacchetto-price {
      font-size: clamp(1.3rem, 2.5vw, 1.6rem);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0;
    }
    .pacchetto-iva {
      font-size: 0.75em;
      font-weight: 500;
      opacity: 0.6;
    }
    .pacchetto-desc {
      font-size: 13px;
      line-height: 1.5;
      opacity: 0.75;
      margin: 4px 0 0;
    }
    .pacchetto-meta-link {
      font-size: 12px;
      font-weight: 600;
      text-decoration: none;
      opacity: 0.6;
      margin-top: 4px;
    }
    .pacchetto-meta-link:hover { opacity: 1; text-decoration: underline; }
    .pacchetto-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border: 0;
      transition: opacity 150ms, transform 150ms;
      align-self: flex-start;
    }
    .pacchetto-cta:hover { opacity: 0.85; transform: translateY(-1px); }

    /* Colori varianti */
    .pacchetto-green  { background: #e8f5e9; color: #1b5e20; }
    .pacchetto-green .pacchetto-cta { background: #2e7d32; color: #fff; }
    .pacchetto-green .pacchetto-meta-link { color: #2e7d32; }
    .pacchetto-sprint { background: #FF6B33; color: #fff; }
    .pacchetto-sprint .pacchetto-cta { background: #fff; color: #FF6B33; }
    .pacchetto-sprint .pacchetto-meta-link { color: rgba(255,255,255,0.85); }
    .pacchetto-taas   { background: #0e1116; color: #fff; }
    .pacchetto-taas .pacchetto-cta { background: #FF6B33; color: #fff; }
    .pacchetto-taas .pacchetto-meta-link { color: rgba(255,255,255,0.65); }

    /* Dark mode overrides for green card */
    :root[data-theme="dark"] .pacchetto-green,
    :root[data-theme="auto"][data-sun="night"] .pacchetto-green {
      background: rgba(46,125,50,0.18);
      color: #a5d6a7;
    }
    :root[data-theme="dark"] .pacchetto-green .pacchetto-cta,
    :root[data-theme="auto"][data-sun="night"] .pacchetto-green .pacchetto-cta {
      background: #388e3c;
      color: #fff;
    }

    /* Sustainable Creativity clarification */
    .sc-clarification {
      font-size: 11px;
      line-height: 1.5;
      opacity: 0.55;
      margin: 4px 0 0;
      font-style: italic;
    }

    .bento-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
      grid-auto-flow: dense;
    }
    @media (min-width: 700px) {
      .bento-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; grid-auto-rows: 200px; }
    }
    @media (min-width: 1100px) {
      .bento-grid { grid-template-columns: repeat(3, 1fr); gap: 22px; grid-auto-rows: 220px; }
    }

    .bento-tile {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      text-decoration: none;
      color: inherit;
      display: block;
      border: 0;
      background: #fafaf7;
      cursor: pointer;
      text-align: left;
      font: inherit;
      transition: transform 250ms ease;
    }
    .bento-tile:hover { transform: translateY(-2px); }

    /* Sizes — desktop layout */
    .t-tall   { grid-row: span 2; }
    .t-medium { grid-row: span 1; }
    .t-square { grid-row: span 1; }
    @media (min-width: 1100px) {
      .t-tall   { grid-row: span 3; }
      .t-medium { grid-row: span 1; }
      .t-square { grid-row: span 1; }
    }

    /* Color variants */
    .t-dark   { background: #0e1116; color: #ffffff; }
    .t-cream  { background: #fafaf7; color: #0e1116; }
    .t-blue   { background: #1f5b8f; color: #ffffff; }
    .t-orange { background: #FF6B33; color: #ffffff; }

    .bento-content {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      padding: 20px 22px;
    }
    .bento-spacer { flex: 1; }
    .bento-kicker {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      opacity: 0.7;
      margin: 0;
      font-weight: 500;
    }
    .bento-title {
      font-size: clamp(1.05rem, 2vw, 1.45rem);
      font-weight: 900;
      letter-spacing: -0.01em;
      line-height: 1.15;
      margin: 0;
    }
    .bento-title-lg {
      font-size: clamp(1.4rem, 2.5vw, 1.85rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0;
    }
    .bento-title-xl {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin: 0;
    }
    .bento-sub {
      font-size: 13px;
      opacity: 0.75;
      margin: 6px 0 0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
    }

    .bento-video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .bento-grad {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.65), transparent 60%);
      z-index: 1;
    }

    .bento-wordmark {
      display: flex;
      align-items: flex-end;
      padding: 22px;
    }
    .bento-wordmark-stack {
      display: flex;
      flex-direction: column;
      gap: 14px;
      width: 100%;
    }
    .bento-wordmark-logo {
      width: 100%;
      max-width: 240px;
      height: auto;
      display: block;
    }
    .bento-clientwall .clientwall-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 16px;
      align-items: baseline;
    }
    .bento-clientwall .clientwall-list li {
      font-weight: 800;
      font-size: clamp(0.95rem, 1.6vw, 1.25rem);
      letter-spacing: -0.01em;
      color: #0e1116;
      line-height: 1.15;
      white-space: nowrap;
    }
    .bento-clientwall .clientwall-list li + li::before {
      content: '·';
      margin-right: 16px;
      color: rgba(14,17,22,0.3);
      font-weight: 400;
    }
    :root[data-theme="dark"] .bento-clientwall .clientwall-list li,
    :root[data-theme="auto"][data-sun="night"] .bento-clientwall .clientwall-list li {
      color: #f5f4ee;
    }
    :root[data-theme="dark"] .bento-clientwall .clientwall-list li + li::before,
    :root[data-theme="auto"][data-sun="night"] .bento-clientwall .clientwall-list li + li::before {
      color: rgba(245,244,238,0.3);
    }
  </style>
</BaseLayout>
