---
// Superficie hire — landing. Nativa nel sito: rail vero, ClientRouter, Alba, tema.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { OFFERS } from '../../data/offers';
import { WORKS, TEAM, ABOUT, CLIENTS, TESTIMONIALS } from '../../data/showcase';

const BRAND = 'Pianeta.Studio';
const BOOKING = '/lavoriamo-insieme';
const accents: Record<string, string> = { green: 'var(--green)', orange: 'var(--orange)', dark: 'var(--acc)' };

// posizioni del cerchio team
const R = 43;
const circle = TEAM.map((m, i) => {
  const ang = (-90 + i * (360 / TEAM.length)) * Math.PI / 180;
  return { ...m, left: 50 + R * Math.cos(ang), top: 50 + R * Math.sin(ang) };
});

const METHOD = [
  { n: '01', t: 'Design thinking & co-design', d: 'Partiamo dal problema, insieme a te. Niente brief calati dall’alto: co-progettiamo la direzione.' },
  { n: '02', t: 'AI validation', d: 'Validiamo le idee con il nostro swarm AI + neuromarketing — prima di spendere il budget di produzione.' },
  { n: '03', t: 'Design & build', d: 'Dalla direzione validata al prodotto: design system, web, contenuti. Carbon e performance budget come vincoli verificabili.' },
  { n: '04', t: 'Consegna, senza lock-in', d: 'Codice e contenuti consegnati, standard aperti. Quello che costruiamo è tuo.' },
];
---
<BaseLayout title={`Lavoriamo insieme — ${BRAND}`} description="Una direzione creativa validata, prima di spendere il budget. Design, web e validazione con AI.">
  <div class="hire-page">
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <h1 class="hero-h1">Una direzione creativa <em>validata</em> — prima di spendere il budget.</h1>
      <p class="hero-sub">Design, web e validazione con AI per brand e organizzazioni che vogliono fare la cosa giusta, e farla funzionare. Scegli da dove iniziare.</p>
      <a href="#offerte" class="hero-cta">Scegli come iniziare ↓</a>
    </div>
  </section>

  <!-- OFFERTE -->
  <section id="offerte" class="sec"><div class="wrap">
    <h2 class="sec-h2">Tre modi per lavorare con noi</h2>
    <div class="offers">
      {OFFERS.map((o) => (
        <a href={`/hire/${o.slug}`} class="offer-card" style={`border-top:3px solid ${accents[o.accent]}`}>
          <div class="offer-price">{o.price}</div>
          <h3 class="offer-name">{o.emoji} {o.name}</h3>
          <p class="offer-forwho">{o.forWho}</p>
          <ul class="offer-bullets">{o.bullets.map((b) => <li>✓ {b}</li>)}</ul>
          <span class="offer-link" style={`color:${accents[o.accent]}`}>Scopri di più →</span>
        </a>
      ))}
    </div>
  </div></section>

  <!-- LAVORI IN SCROLL -->
  <section id="lavori" class="sec sec-soft"><div class="wrap">
    <div class="sec-head">
      <h2 class="sec-h2">I nostri lavori</h2>
      <a href="/work" class="sec-all">Vedi tutti →</a>
    </div>
  </div>
    <div class="works-scroll">
      {WORKS.map((w) => (
        <a href={w.href} class="work-card work-open" data-work={w.href.split('/work/')[1]}>
          <div class="work-cover" style={`background-image:url('${w.cover}')`}></div>
          <div class="work-meta"><strong>{w.title}</strong><span>{w.client}</span></div>
        </a>
      ))}
    </div>
  </section>

  <!-- CLIENTI (loghi placeholder) -->
  <section class="sec"><div class="wrap">
    <h2 class="sec-h2 center">Hanno scelto Pianeta</h2>
    <div class="clients-grid">
      {CLIENTS.map((c) => <div class="client-logo">{c}</div>)}
    </div>
    <p class="clients-note">Loghi in arrivo — per ora i nomi.</p>
  </div></section>

  <!-- LISTA LAVORI (non cliccabile) -->
  <section class="sec sec-soft"><div class="wrap wrap-narrow">
    <h2 class="sec-h2">Lavori recenti</h2>
    <ul class="works-list">
      {WORKS.map((w) => <li><strong>{w.title}</strong> <span>— {w.client}</span></li>)}
    </ul>
  </div></section>

  <!-- CHI SIAMO -->
  <section class="sec"><div class="wrap wrap-narrow">
    <h2 class="sec-h2">{ABOUT.title}</h2>
    <p class="about-body">{ABOUT.body}</p>
    <a href={ABOUT.href} class="sec-all">Leggi di più →</a>
  </div></section>

  <!-- METODOLOGIA (design thinking, breve) -->
  <section id="metodologia" class="sec sec-soft"><div class="wrap">
    <h2 class="sec-h2 center">Come lavoriamo</h2>
    <p class="method-lead">Metodologie di design thinking, validate con l’AI. Un metodo che riduce il rischio prima di spendere.</p>
    <div class="method-grid">
      {METHOD.map((m) => (
        <div class="method-card">
          <span class="method-n">{m.n}</span>
          <strong>{m.t}</strong>
          <p>{m.d}</p>
        </div>
      ))}
    </div>
  </div></section>

  <!-- TEAM CERCHIO — "No telephone games" -->
  <section class="sec sec-soft"><div class="wrap">
    <h2 class="sec-h2 center">Niente giri a vuoto</h2>
    <div class="circle-wrap">
      <div class="circle">
        {circle.map((m) => (
          <div class="bubble" style={`left:${m.left}%;top:${m.top}%`} title={m.name}>{m.initials}</div>
        ))}
        <div class="circle-center">
          <p class="cc-top">Prenotati. Parliamo del tuo prossimo progetto.</p>
          <a href={BOOKING} class="cc-cta">Lavoriamo insieme</a>
          <p class="cc-bot">Nessuna idea è troppo folle — qui non si giudica.</p>
        </div>
      </div>
    </div>
    <div class="why two-col">
      <div>
        <p>Costruire il tuo brand o il tuo sito dovrebbe essere <strong>entusiasmante</strong> — e dovrebbe portare risultati.</p>
        <p>Coordinare più studi o navigare grandi agenzie distorce la tua visione e ti prosciuga il tempo — energia che è meglio spendere a far crescere il tuo lavoro. Lo capiamo.</p>
      </div>
      <div>
        <p>Lo <strong>studio giusto</strong>: non troppo grande, non troppo piccolo — la solidità di uno studio con la flessibilità di una boutique.</p>
        <p>Niente telefono senza fili. Niente energie sprecate. Solo bel lavoro e buone vibrazioni. Facciamo quadrare tutto.</p>
      </div>
    </div>
  </div></section>

  <!-- TESTIMONIALS -->
  <section class="sec"><div class="wrap wrap-narrow">
    <h2 class="sec-h2 center">Cosa dicono di noi</h2>
    {TESTIMONIALS.map((tt) => (
      <figure class="testi">
        {tt.draft && <span class="testi-draft">bozza · in attesa di citazione + foto reali</span>}
        <blockquote class="testi-quote">“{tt.quote}”</blockquote>
        <figcaption class="testi-by">
          <span class="testi-avatar">{tt.initials}</span>
          <span><strong>{tt.name}</strong>{tt.url && <a href={tt.url} target="_blank" rel="noopener"> · {tt.org} ↗</a>}</span>
        </figcaption>
      </figure>
    ))}
  </div></section>

  <!-- ALBA -->
  <section class="alba-band"><div class="wrap alba-inner">
    <div><strong>Hai dubbi?</strong> Chiedi ad Alba — l'AI di Pianeta ti aiuta a inquadrare il progetto, capire l'offerta giusta, fissare una call.</div>
    <a href={BOOKING} class="alba-cta" data-alba>Parla con Alba</a>
  </div></section>

  <!-- OVERLAY LAVORO (in-place, no fuga) -->
  <div id="work-ov" class="work-ov" hidden>
    <div class="work-ov-backdrop" data-close></div>
    <aside class="work-ov-panel" role="dialog" aria-label="Lavoro">
      <button class="work-ov-x" data-close aria-label="Chiudi">✕</button>
      <div id="work-ov-body" class="work-ov-body"></div>
    </aside>
  </div>
  </div>

  <style>
    /* alias token: la superficie hire usa nomi brevi → mappa ai token del sito, contenuti in .hire-page */
    .hire-page {
      --card: var(--pianeta-bg-card); --line: var(--pianeta-border);
      --txt: var(--pianeta-text); --mut: var(--pianeta-muted); --acc: var(--cta-primary);
      --orange: var(--cta-primary); --green: #1f7a3a;
    }
    /* su /hire le CTA flottanti hire (CTA hub + launcher drawer) sono ridondanti */
    :global(.hub-hire-cta), :global(.hire-us-launcher) { display: none !important; }

    .wrap { max-width: 1040px; margin: 0 auto; padding: 0 24px; }
    .wrap-narrow { max-width: 720px; }
    .sec { padding: 64px 0; }
    .sec-soft { background: var(--pianeta-bg-soft, #fafaf7); }
    .sec-h2 { font-size: clamp(22px, 3vw, 28px); letter-spacing: -0.01em; margin: 0; }
    .sec-h2.center { text-align: center; }
    .sec-head { display: flex; align-items: baseline; justify-content: space-between; }
    .sec-all { color: var(--acc); text-decoration: none; font-size: 14px; font-weight: 600; }

    .hero { padding: 80px 0 56px; }
    .hero-h1 { font-size: clamp(32px, 5.5vw, 52px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 18px; max-width: 880px; }
    .hero-h1 em { font-style: normal; color: var(--cta-primary); }
    .hero-sub { font-size: 18px; color: var(--mut); max-width: 620px; margin: 0 0 28px; line-height: 1.5; }
    .hero-cta { display: inline-block; background: var(--cta-primary); color: #fff; font-weight: 600; padding: 13px 24px; border-radius: 999px; text-decoration: none; }

    .offers { display: grid; grid-template-columns: 1fr; gap: 16px; margin-top: 28px; }
    @media (min-width: 760px) { .offers { grid-template-columns: repeat(3, 1fr); } }
    .offer-card { background: var(--card); border: 1px solid var(--line); border-radius: 18px; padding: 22px; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 10px; transition: transform 150ms; }
    .offer-card:hover { transform: translateY(-3px); }
    .offer-price { font-size: 13px; color: var(--mut); }
    .offer-name { font-size: 19px; margin: 0; }
    .offer-forwho { font-size: 13px; color: var(--mut); flex: 1; }
    .offer-bullets { list-style: none; display: grid; gap: 5px; font-size: 13px; }
    .offer-link { font-weight: 600; font-size: 14px; }

    .works-scroll { display: flex; gap: 16px; overflow-x: auto; padding: 24px 24px 8px; scroll-snap-type: x mandatory; }
    .works-scroll::-webkit-scrollbar { height: 6px; }
    .work-card { flex: 0 0 300px; scroll-snap-align: start; text-decoration: none; color: inherit; }
    .work-cover { aspect-ratio: 16/10; border-radius: 14px; background-size: cover; background-position: center; border: 1px solid var(--line); }
    .work-meta { padding: 10px 2px; display: flex; flex-direction: column; }
    .work-meta strong { font-size: 15px; }
    .work-meta span { font-size: 12px; color: var(--mut); }

    .about-body { font-size: 18px; line-height: 1.7; margin: 16px 0 18px; }

    .clients-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 28px; }
    @media (min-width: 560px) { .clients-grid { grid-template-columns: repeat(4, 1fr); } }
    .client-logo { display: flex; align-items: center; justify-content: center; height: 64px; border: 1px solid var(--line);
      border-radius: 12px; font-weight: 700; font-size: 15px; color: var(--mut); background: var(--card); text-align: center; padding: 0 8px; }
    .clients-note { text-align: center; color: var(--mut); font-size: 12px; margin-top: 14px; }
    .works-list { list-style: none; display: grid; gap: 10px; margin-top: 16px; }
    .works-list li { font-size: 16px; padding-bottom: 10px; border-bottom: 1px solid var(--line); }
    .works-list span { color: var(--mut); }

    .testi { text-align: center; max-width: 660px; margin: 0 auto; }
    .testi-draft { display: inline-block; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--mut);
      background: var(--pianeta-bg-soft, #fafaf7); border: 1px solid var(--line); border-radius: 999px; padding: 4px 12px; margin-bottom: 18px; }
    .testi-quote { font-size: clamp(20px, 3vw, 26px); line-height: 1.45; font-weight: 500; letter-spacing: -0.01em; margin: 0 0 20px; }
    .testi-by { display: inline-flex; align-items: center; gap: 12px; font-size: 15px; }
    .testi-by a { color: var(--acc); text-decoration: none; }
    .testi-avatar { width: 44px; height: 44px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 14px; color: #0e1116; background: linear-gradient(135deg, #fbcfe8, #fed7aa, #fef3c7); }

    .circle-wrap { display: flex; justify-content: center; margin: 32px 0; }
    .circle { position: relative; width: 440px; max-width: 92vw; aspect-ratio: 1; }
    .bubble { position: absolute; transform: translate(-50%, -50%); width: 56px; height: 56px; border-radius: 999px;
      display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 15px; color: #0e1116;
      background: linear-gradient(135deg, #fbcfe8, #fed7aa, #fef3c7); box-shadow: 0 4px 14px rgba(14,17,22,.10); }
    .circle-center { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 62%; text-align: center;
      display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .cc-top, .cc-bot { font-size: 13px; color: var(--mut); margin: 0; }
    .cc-cta { background: var(--cta-primary); color: #fff; font-weight: 700; padding: 12px 22px; border-radius: 999px; text-decoration: none; }

    .why.two-col { display: grid; grid-template-columns: 1fr; gap: 20px; max-width: 820px; margin: 24px auto 0; }
    @media (min-width: 700px) { .why.two-col { grid-template-columns: 1fr 1fr; gap: 40px; } }
    .why p { color: var(--mut); line-height: 1.6; margin: 0 0 12px; }
    .why strong { color: var(--txt); }

    .alba-band { background: #0e1116; color: #fff; padding: 28px 0; }
    .alba-inner { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .alba-inner > div { max-width: 640px; font-size: 15px; line-height: 1.5; }
    .alba-cta { background: var(--cta-primary); color: #fff; font-weight: 600; padding: 11px 20px; border-radius: 999px; text-decoration: none; white-space: nowrap; }

    .method-lead { text-align: center; color: var(--mut); max-width: 620px; margin: 12px auto 28px; font-size: 16px; }
    .method-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
    @media (min-width: 760px) { .method-grid { grid-template-columns: repeat(4, 1fr); } }
    .method-card { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 18px; }
    .method-n { font-size: 12px; font-weight: 800; color: var(--cta-primary); }
    .method-card strong { display: block; margin: 6px 0; font-size: 15px; }
    .method-card p { color: var(--mut); font-size: 13px; line-height: 1.5; margin: 0; }

    /* Approfondimento = colonna destra "come sito": split su desktop, niente scuro pesante */
    .work-ov { position: fixed; inset: 0; z-index: 60; }
    .work-ov[hidden] { display: none; }
    .work-ov-backdrop { position: absolute; inset: 0; background: rgba(14,17,22,.18); }
    .work-ov-panel { position: absolute; top: 0; right: 0; bottom: 0; width: 100%; max-width: 760px; background: var(--pianeta-bg);
      box-shadow: -24px 0 70px rgba(14,17,22,.16); overflow-y: auto; border-left: 1px solid var(--pianeta-border); }
    .work-ov-x { position: sticky; top: 14px; float: right; margin: 14px 18px 0; z-index: 2; background: var(--card); border: 1px solid var(--line);
      width: 38px; height: 38px; border-radius: 999px; cursor: pointer; font-size: 14px; color: var(--txt); }
    .work-ov-body { padding: 28px clamp(28px, 4vw, 56px) 72px; }
    /* contenuto iniettato via innerHTML → niente scope Astro: usare :global */
    :global(.work-ov-cover) { width: 100%; height: clamp(220px, 36vw, 380px); border-radius: 16px; background-size: cover; background-position: center; margin-bottom: 30px; }
    :global(.work-ov-eyebrow) { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: var(--pianeta-muted); margin: 0 0 16px; }
    :global(.work-ov-body h1) { font-size: clamp(30px, 4vw, 44px); font-weight: 900; letter-spacing: -.02em; line-height: 1.05; margin: 0 0 16px; }
    :global(.work-ov-deck) { font-size: clamp(17px, 2vw, 20px); color: var(--pianeta-muted); line-height: 1.5; margin: 0 0 28px; }
    :global(.work-ov-meta) { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 28px; padding: 20px 0; margin: 0 0 30px; border-top: 1px solid var(--pianeta-border); border-bottom: 1px solid var(--pianeta-border); }
    :global(.work-ov-meta li) { display: flex; flex-direction: column; gap: 2px; }
    :global(.work-ov-meta .k) { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--pianeta-muted); }
    :global(.work-ov-meta .v) { font-size: 14px; font-weight: 600; }
    :global(.work-ov-content) { font-size: 17px; line-height: 1.75; max-width: 65ch; }
    :global(.work-ov-content h2), :global(.work-ov-content h3) { font-size: 21px; font-weight: 800; letter-spacing: -.01em; margin: 32px 0 10px; }
    :global(.work-ov-content p) { margin: 0 0 16px; }
    :global(.work-ov-content a) { color: var(--cta-primary); }
    :global(.work-ov-live) { display: inline-block; margin: 32px 14px 0 0; background: var(--cta-primary); color: #fff; font-weight: 600; padding: 12px 22px; border-radius: 999px; text-decoration: none; }
    :global(.work-ov-full) { display: inline-block; margin-top: 32px; color: var(--pianeta-muted); font-weight: 600; text-decoration: none; font-size: 14px; }
    :global(.work-ov-full:hover) { color: var(--pianeta-text); }
  </style>

  <script is:inline>
    (() => {
      const init = () => {
        const ov = document.getElementById('work-ov');
        if (!ov || ov.dataset.bound) return;
        ov.dataset.bound = '1';
        const body = document.getElementById('work-ov-body');
        const md = (s) => s
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/^#{1,3} (.*)$/gm, '<h2>$1</h2>')
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/g, '<em>$1</em>')
          .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
          .split(/\n{2,}/).map((b) => b.match(/^<h2>/) ? b : '<p>' + b.replace(/\n/g, '<br>') + '</p>').join('');
        const open = async (slug) => {
          body.innerHTML = '<p style="padding:60px 0;text-align:center;color:var(--pianeta-muted)">Carico…</p>';
          ov.hidden = false; document.body.style.overflow = 'hidden';
          try {
            const r = await fetch('/api/work/' + slug + '.json'); const d = await r.json();
            const esc = (x) => String(x || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            const eyebrow = [d.client, d.category].filter(Boolean).map(esc).join(' · ');
            const services = Array.isArray(d.services) ? d.services : (d.services ? [d.services] : []);
            const meta = [
              d.year ? { k: 'Anno', v: esc(d.year) } : null,
              d.sector ? { k: 'Settore', v: esc(d.sector) } : null,
              services.length ? { k: 'Servizi', v: services.map(esc).join(', ') } : null,
            ].filter(Boolean);
            body.innerHTML =
              (d.cover ? '<div class="work-ov-cover" style="background-image:url(\'' + String(d.cover).replace(/'/g, "%27") + '\')"></div>' : '') +
              (eyebrow ? '<p class="work-ov-eyebrow">' + eyebrow + '</p>' : '') +
              '<h1>' + esc(d.name) + '</h1>' +
              (d.description ? '<p class="work-ov-deck">' + esc(d.description) + '</p>' : '') +
              (meta.length ? '<ul class="work-ov-meta">' + meta.map((m) => '<li><span class="k">' + m.k + '</span><span class="v">' + m.v + '</span></li>').join('') + '</ul>' : '') +
              '<div class="work-ov-content">' + md(d.body || '') + '</div>' +
              (d.live_url ? '<a class="work-ov-live" href="' + esc(d.live_url) + '" target="_blank" rel="noopener">Vedi il progetto live →</a>' : '') +
              '<a class="work-ov-full" href="/work/' + encodeURIComponent(slug) + '">Apri la scheda completa →</a>';
          } catch (e) { body.innerHTML = '<p>Contenuto non disponibile.</p>'; }
        };
        const close = () => { ov.hidden = true; document.body.style.overflow = ''; };
        document.addEventListener('click', (e) => {
          const a = e.target.closest && e.target.closest('.work-open');
          if (a) { e.preventDefault(); open(a.dataset.work); return; }
          if (e.target.closest && e.target.closest('[data-close]')) close();
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !ov.hidden) close(); });
      };
      init();
      document.addEventListener('astro:page-load', init);
    })();
  </script>
</BaseLayout>
