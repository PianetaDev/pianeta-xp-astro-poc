---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HireOfferDetail from '../../components/hire/HireOfferDetail.astro';
import { offerBySlug } from '../../data/offers';
const offer = offerBySlug(Astro.params.offer ?? '', 'it');
if (!offer) return Astro.redirect('/hire');
---
<BaseLayout title={`${offer.name} — Pianeta.Studio`} description={offer.tagline} hideNewsletter>
  <HireOfferDetail offer={offer} locale="it" />
</BaseLayout>
